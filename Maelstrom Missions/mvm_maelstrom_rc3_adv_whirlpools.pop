	//// WAVES ////

	Wave     //   Wave: 1/4    Credits: 1200
	{
		InitWaveOutput
        {
            Target bignet
            Action RunScriptCode
            Param "SetSkyboxTexture(`sky_alpinestorm_01`)"
        }
		StartWaveOutput
		{
			Target	wave_start_relay
			Action	Trigger
		}
		DoneOutput
		{
			Target	wave_finished_relay
			Action	Trigger
		}
		Explanation
		{
		    Line "{B8383B}Hardhat: Ping to all reprogrammed robots, this is Hardhat Speaking."
			 Line "{B8383B}Hardhat: Robots are attacking the base."
			Line "{B8383B}Hardhat: But looks like they got mulched up pretty bad up north."
			 Line "{B8383B}Hardhat: Weather hit em hard didn't it?"
			Line "{B8383B}Hardhat: Gray Mann's bots seem to be malfuncioning."
			 Line "{B8383B}Hardhat: Or atleast some of them are."
			Line "{B8383B}Hardhat: But be carful of the malfuncioning ones."
			 Line "{B8383B}Hardhat: Never know what they might do."
		}

