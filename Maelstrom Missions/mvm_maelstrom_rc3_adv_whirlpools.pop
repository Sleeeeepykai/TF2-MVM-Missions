// Mission mostly made by: Mr.Enderman22, Helped later on by: SleepyKai.

#base robot_giant.pop
#base robot_standard.pop
#base robot_gatebot.pop

WaveSchedule
{
	StartingCurrency	1450
	RespawnWaveTime	5
	CanBotsAttackWhileInSpawnRoom	No
	AddSentryBusterWhenKillCountExceeds	40
	SentryBusterFriendlyFire 0

	RedPlayersAreRobots 1 
	SniperAllowHeadshots 0
	TextPrintTime 0

