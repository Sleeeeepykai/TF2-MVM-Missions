	//// POINT TEMPLATES ////

	PointTemplates    // same as it ever was
    {
	    Interface
		{
		    NoFixup 1 
            point_populator_interface
			{
			    "TargetName" "populator"
			}
		}
		W4BossPT
        {
            NoFixup 1
            info_target
            {
                "targetname" "boss_target"
                "origin" "0 0 0"
            }

            OnSpawnOutput
            {
                Target boss_target
                Action SetParent
                Param "!activator"
                Delay 0.05
            }
            OnSpawnOutput
            {
                Target temporary_solution
                Action $SetOwner
                Param "@p@boss_target"
                Delay 0.1
            }

            logic_relay
            {
                "targetname" "w5_phase2_relay"

                "OnTrigger" "@p@boss_target,$TauntFromItem,Taunt: Unleashed Rage,1,-1"
                "OnTrigger" "@p@boss_target,$RemoveCond,5,5,-1"
                "OnTrigger" "@p@boss_target,$ChangeAttributes,Phase2,5,-1"
                "OnSpawn" "tf_gamerules,PlayVO,player\invulnerable_off.wav,4,-1"
            }
        }
		StickyBlimp
		{
			OnParentKilledOutput // Clean up stickies
			{
				Target tf_projectile_pipe
				Action Kill
				Delay 0.05
			}
			
			logic_relay
			{
				"targetname" "stickytank_shooter_relay"
				
				"OnTrigger"  "stickytank_mimic,FireOnce,,0,-1"
