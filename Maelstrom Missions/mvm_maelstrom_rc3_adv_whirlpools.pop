                origin "-2819.89 1100.19 1418.11"            // leaving blank but this determines where the ent is, you'll have to do the positioning yourself
            }
			info_particle_system        // https://developer.valvesoftware.com/wiki/Team_Fortress_2/Particles#Sawmill has the rain effect names listed
            {
                targetname rain_particles
                effect_name env_rain_001    // env_rain_002_256 is a 256 one, could use that in case this one clips into interiors
                start_active 1
                flag_as_weather 1 // for those with performance settings that don't want weather
                origin "-2712.83 -151.00 1283.33"            // leaving blank but this determines where the ent is, you'll have to do the positioning yourself
            }
        }
