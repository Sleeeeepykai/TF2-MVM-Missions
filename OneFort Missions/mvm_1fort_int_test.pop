WaveSchedule
{
	Wave
	{
		InitWaveOutput // This must be included on every wave
		{
			Target BigNet
			Action RunScriptCode
			Param "
					// Load popextensions script
					IncludeScript(`popextensions_main.nut`, getroottable())

        			EntFire(`point_commentary_node*`, `Kill`) // point_commentary_nodes screw up the HUD, so we have to remove it
        
					// This is what actually handles weapon restrictions
					IncludeScript(`mvm_1fort_weaponrestricts.nut`, getroottable())
				  "
		}
	}
}