					IncludeScript(`mvm_1fort/main`, getroottable())

					// Setting Bomb Paths
					EntFire(`bombpath_random_relay`, `Trigger`)
				  "
		}
		StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_start_relay`, `Trigger`)
				  "
		}
		DoneOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_finished_relay`, `Trigger`)
				  "
		}

		// Subwave 1
		WaveSpawn // 3 GBurst Soldier and 3 GMedics
		{
			Name "Wave4_Subwave1_GBurstSoldier"
			Where spawnbot
			TotalCount 6
			MaxActive 3
			SpawnCount 2
			WaitBeforeStarting 0
			WaitBetweenSpawns 40
			TotalCurrency 280

			Squad
			{
				TFBot
				{
					Template T_TFBot_Giant_Soldier_Burst
				}
				TFBot
				{
					Template T_TFBot_Giant_Medic_Regen
				}
			}
		}

		WaveSpawn // Support Scouts
		{
			Name "Wave4_Subwave1_Scouts"
			Where spawnbot
			Where spawnbot_flank
			Support 1
			TotalCount 80
			MaxActive 5
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 1
			TotalCurrency 80

			TFBot
			{
				Class Scout
				Skill Easy
			}
		}

		WaveSpawn
		{
			Name "Wave4_Subwave1_Demomen"
			Where spawnbot
			Support 1
			TotalCount 40
			MaxActive 4
			SpawnCount 4
			WaitBeforeStarting 15
			WaitBetweenSpawns 8
			TotalCurrency 40

			TFBot
			{
				Class Demoman
				Skill Normal
			}
		}
	}
}