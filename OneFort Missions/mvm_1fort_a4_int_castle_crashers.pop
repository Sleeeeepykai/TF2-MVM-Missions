#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop

WaveSchedule
{
	StartingCurrency 1000
	RespawnWaveTime 1

	CanBotsAttackWhileInSpawnRoom No
	
	//// ROBOT TEMPLATES ////

	Templates
	{
		T_TFBot_Demoman_Knight_Bottle
		{
			Name "Bottleknight"
			Class Demoman
			ClassIcon demoknight_bottle_lite
			Skill Hard
			WeaponRestrictions MeleeOnly

			Item "The Chargin' Targe"

			ItemAttributes
			{
				ItemName "TF_WEAPON_BOTTLE"
				"critboost on kill" 3
			}
		}
	}

	//// MISSION BOTS ////

	Mission // Spy (Wave 3)
	{
		Objective Spy
		BeginAtWave 3
		RunForThisManyWaves 1
		InitialCooldown 10
		CooldownTime 30
		DesiredCount 2

		TFBot
		{
			Template T_TFBot_Spy
		}
	}

	//// WAVES ////

	Wave
	{
		InitWaveOutput // This must be included on every wave
		{
			Target BigNet
			Action RunScriptCode
			Param "
					// This is what actually handles weapon restrictions
					IncludeScript(`mvm_1fort/main`, getroottable())

					// Setting Bomb Paths
					EntFire(`bombpath_random_relay`, `Trigger`)
				  "
		}
		StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_start_relay`, `Trigger`)
				  "
		}
		DoneOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_finished_relay`, `Trigger`)
				  "
		}

		// Subwave 1
		WaveSpawn // 10 Bottleknights
