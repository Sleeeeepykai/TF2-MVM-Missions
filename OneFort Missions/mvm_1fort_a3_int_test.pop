#base robot_giant.pop
#base robot_standard.pop

WaveSchedule
{
	StartingCurrency 0
	RespawnWaveTime 2

	CanBotsAttackWhileInSpawnRoom No

	Wave
	{
		InitWaveOutput // This must be included on every wave
		{
			Target BigNet
			Action RunScriptCode
			Param "
					// Load popextensions script
					IncludeScript(`popextensions_main.nut`, getroottable())

					EntFire(`point_commentary_node*`, `Kill`) // point_commentary_nodes screw up the HUD, so we have to remove it

					// This is what actually handles weapon restrictions
					IncludeScript(`mvm_1fort_weaponrestricts.nut`, getroottable())

					// Setting Bomb Paths
					EntFire(`bombpath_random_relay`, `Trigger`, null, 5)
				  "
		}
		StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_start_relay`, `Trigger`)
				  "
		}
		DoneOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`wave_finished_relay`, `Trigger`)
				  "
		}

		WaveSpawn
		{
			Name "Wave1_Scout"
			Where spawnbot
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 20

			TFBot
			{
				Class Scout
				Skill Easy
			}
		}

		WaveSpawn
		{
			Name "Wave1_Demo"
			Where spawnbot_tunnel
			TotalCount 20
			MaxActive 20
			SpawnCount 20
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 20

			TFBot
			{
				Name "Persian Demoknight"
				Class Demoman
				ClassIcon demoknight_persian_nys
				Skill Hard
				WeaponRestrictions MeleeOnly

				Item "Ali Baba's Wee Booties"
				Item "The Splendid Screen"	
				Item "The Persian Persuader"

				Item "Sultan's Ceremonial"

				ItemAttributes
				{
					ItemName "The Splendid Screen"
					"attack not cancel charge" 1
				}
				ItemAttributes
				{
					ItemName "The Persian Persuader"
					"critboost on kill" 3
				}	
			}
		}

		WaveSpawn
		{
			Name "Tank"
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 20
			
			Tank
			{
				Name "tankboss_left"
				Speed 75
				StartingPathTrackNode "tank_path_start"

				OnBombDroppedOutput
				{
					Target boss_deploy_relay
					Action Trigger
				}
			}
		}

		WaveSpawn
		{
			Name "Tank"
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 0
			TotalCurrency 20
			
			Tank
			{
				Name "tankboss_right"
				Speed 75
				StartingPathTrackNode "tank_path_start"

				OnBombDroppedOutput
				{
					Target boss_deploy_relay
					Action Trigger
				}
			}
		}
	}
}