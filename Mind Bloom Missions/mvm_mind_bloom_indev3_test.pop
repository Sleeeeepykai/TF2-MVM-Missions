WaveSchedule
{
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    Convars.SetValue(`tf_bot_flag_escort_max_count`, 0)
                  "
        }
        
        WaveSpawn
        {
            Where spawnbot_bomb
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0

            TFBot
            {
                Class Heavy
                WeaponRestrictions MeleeOnly
            }
        }

        WaveSpawn
        {
            Where spawnbot_support
            TotalCount 10
            MaxActive 10
            SpawnCount 1
            WaitBeforeStarting 2
            WaitBetweenSpawns 2

            TFBot
            {
                Class Heavy
                WeaponRestrictions MeleeOnly
            }
        }
    }
}