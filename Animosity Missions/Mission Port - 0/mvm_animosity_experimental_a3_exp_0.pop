	//// WAVES ////

	Wave 
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_left_relay`, `Trigger`)
					EntFire(`bombpath_lowerhatch_relay`, `Trigger`)
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		// Subwave 1
		WaveSpawn
		{
			FirstSpawnOutput
			{
				Target robot_bomb
				Action SetReturnTime
				Param 45
			}
		}
		WaveSpawn
		{
			FirstSpawnOutput
			{
				Target robot_bomb
				Action ShowTimer
				Param 1
			}
		}
		WaveSpawn // 6 Giant Scouts
		{
			Name 1aa
			Where	spawnbot
			TotalCount 6
			SpawnCount 1
			MaxActive 3
			WaitBeforeStarting	0
			WaitBetweenSpawns	6
			TotalCurrency 75
			
			TFBot
			{
				Template T_TFBot_Giant_Scout
				Attributes HoldFireUntilFullReload
				Name "Fallen Giant Scout"
				Tag bot_giant
			}
		}
		WaveSpawn // 32 Bowmen
		{
			Name 1ab
			Where spawnbot_invasion
			TotalCount 32
			SpawnCount 8
			MaxActive 16
			WaitBeforeStarting	2
			WaitBetweenSpawns	7
			TotalCurrency 75
			
			TFBot
			{
				Template T_TFBot_Sniper_Huntsman
				ItemAttributes //damage fix from halloween update
				{
					ItemName "The Huntsman"
					"damage bonus" 0.65
				}
				Name "Fallen Bowman"
			}
		}
		
		WaveSpawn // 1 Tank
		{
			Name	wave1tanks1
			TotalCurrency	100
			TotalCount	1
			MaxActive	1
			SpawnCount	1
			WaitBeforeStarting	6

			Tank
			{
				Name "tankboss_a"
				Health	30000
				Speed	75
				StartingPathTrackNode "tank_path_start"

				OnBombDroppedOutput
				{
					Target	boss_deploy_relay
					Action	Trigger
				}
			}

			FirstSpawnOutput
			{
				Target wave_start_relay
