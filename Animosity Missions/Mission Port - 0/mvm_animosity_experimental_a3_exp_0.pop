	Wave 
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_left_relay`, `Trigger`)
					EntFire(`bombpath_upperhatch_relay`, `Trigger`)

					IncludeScript(`tankextensions_main`, getroottable())
					IncludeScript(`tankextensions/vactank`, getroottable())

					TankExt.SetValueOverrides({
						VACTANK_RESIST_MULT = 0.15
					})
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
		}

