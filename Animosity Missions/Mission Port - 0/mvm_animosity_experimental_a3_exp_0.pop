	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_right_relay`, `Trigger`)
					EntFire(`bombpath_upperhatch_relay`, `Trigger`)

					IncludeScript(`tankextensions_main`, getroottable())
					IncludeScript(`tankextensions/ubertank`, getroottable())
					IncludeScript(`tankextensions/stickytank`, getroottable())
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
		}

		// Explanation Text
		WaveSpawn
		{
			WaitBeforeStarting	0
			FirstSpawnOutput
			{
				Target gamerules
				Action RunScriptCode
				Param "ClientPrint(null,3,`\x08FFFF00FFThe bomb will take additional time to reset (70 seconds). `);"
			}
		}
		WaveSpawn
		{
			FirstSpawnOutput
			{
				Target robot_bomb
				Action SetReturnTime
				Param 70
			}
		}
		WaveSpawn
		{
			FirstSpawnOutput
			{
				Target robot_bomb
				Action ShowTimer
				Param 1
			}
		}

