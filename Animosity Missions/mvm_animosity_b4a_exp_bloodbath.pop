			}
		}

		// Subwave 3
		WaveSpawn // 1 GSoldier and 4 Battalions
		{
			Name "Wave2_Subwave3_GSoldier"
			WaitForAllDead "Wave2_Subwave2_GSoldier"
			Where spawnbot_arena_right
			TotalCount 5
			MaxActive 5
			SpawnCount 5
