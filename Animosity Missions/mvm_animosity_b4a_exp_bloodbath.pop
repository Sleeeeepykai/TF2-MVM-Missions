			WaitBeforeStarting 20
			WaitBetweenSpawns 2
			TotalCurrency 80

			TFBot
			{
				Template T_TFBot_Scout_Melee
			}
		}

		WaveSpawn // 1 GDemo
		{
			Name "Wave1_Subwave3_GDemo"
			WaitForAllSpawned "Wave1_Subwave3_Soldiers"
			Where spawnbot_arena_left
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 10
			WaitBetweenSpawns 0
			TotalCurrency 40

			TFBot
			{
				Template T_TFBot_Giant_Demoman
				Tag Glow
			}
		}
		WaveSpawn // 1 GDemo
		{
			Name "Wave1_Subwave3_GDemo2"
			WaitForAllSpawned "Wave1_Subwave3_Soldiers"
			Where spawnbot_arena_right
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 10
			WaitBetweenSpawns 0
			TotalCurrency 40

			TFBot
			{
				Template T_TFBot_Giant_Demoman
				Tag Glow
			}
		}

		// Wavespawn Check
		WaveSpawn // Steel Gauntlets Check
		{
			Name "Wave1_Subwave3_Complete"
			WaitForAllDead "Wave1_Subwave3_GDemo"
		}
		WaveSpawn // GSoldier Check
		{
			Name "Wave1_Subwave3_Complete"
			WaitForAllDead "Wave1_Subwave3_GDemo"
		}

		// Wave Complete
		WaveSpawn // Victory Laugh
		{
			Name "Wave1_Complete"
			WaitForAllSpawned "Wave1_Subwave3_Complete"
			DoneWarningSound "vo/mvm/mght/demoman_mvm_m_autocappedintelligence01.mp3"
		}
		WaveSpawn
		{
			Name "Wave1_Complete"
			WaitForAllDead "Wave1_Subwave3_GDemo"
			WaitBeforeStarting 3.9

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`arena_mode_loss_relay`, `Disable`)
					  "
			}
		}
		WaveSpawn 
		{
			Name "Wave1_Complete"
			WaitForAllDead "Wave1_Subwave3_GDemo"
			WaitBeforeStarting 4
			
			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						MVMAnimosity_ArenaMode.RemoveRobot(`The Commander`)
					  "
			}
		}
	}
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					IncludeScript(`mvm_animosity_arena_mode`, getroottable())
					EntFire(`arena_mode_relay`, `Trigger`)
					EntFire(`arena_mode_loss_relay`, `Enable`)

					Convars.SetValue(`tf_bot_flag_escort_max_count`, 0)
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`wave_start_relay`, `Trigger`)
                  "
        }

		// VIP Spawn
		WaveSpawn // Spawn Enable
		{
			Name "Wave1_SpawnEnable"
			WaitBeforeStarting 1.9
			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
					EntFire(`spawnbot_arena_objective`, `Enable`)
					  "
			}
		}
		WaveSpawn // Spawn-In
		{
			Name "Wave1_Objective"
			Where spawnbot_arena_objective
			Support Limited
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 2
			WaitBetweenSpawns 0

			DoneWarningSound "mvm/sentrybuster/mvm_sentrybuster_explode.wav"

			Squad
			{
				Squad
				{
					TFBot
					{
						Template T_TFBot_Objective
					}
				}
			}

			DoneOutput
			{
				Target BigNet
            	Action RunScriptCode
            	Param "
                    EntFire(`arena_mode_loss_relay`, `Trigger`)
					MVMAnimosity_ArenaMode.RemoveRobot(`The Commander`)
                  "
			}
		}
		WaveSpawn // Spawn Disable
		{
			WaitBeforeStarting 2.1
			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`spawnbot_arena_objective`, `Disable`)
					  "
			}
		}

		// Subwave 1
		WaveSpawn // 6 Steel Gauntlets and 6 Quick-ubers
		{
			Name "Wave2_Subwave1_SteelSquads"
			Where spawnbot_arena_left
			TotalCount 12
			MaxActive 8
			SpawnCount 2
			WaitBeforeStarting 8
			WaitBetweenSpawns 8
			TotalCurrency 120

			Squad
			{
				TFBot
				{
					Template T_TFBot_Heavy_SteelFist
					Tag Glow
				}
				TFBot
				{
					Template T_TFBot_Medic_QuickUber
					Tag Glow
				}
			}
		}
		WaveSpawn // 36 Flare Pyros
		{
			Name "Wave2_Subwave1_FlarePyros"
			Where spawnbot_arena_left
			TotalCount 36
			MaxActive 12
			SpawnCount 3
			WaitBeforeStarting 8
			WaitBetweenSpawns 4
			TotalCurrency 120

			TFBot
			{
				Template T_TFBot_Pyro_Flaregun
			}
		}

		// Subwave 2
		WaveSpawn // 2 GSoldiers, 4 Battalions and 4 Scouts
		{
			Name "Wave2_Subwave2_GSoldier"
			WaitForAllSpawned "Wave2_Subwave1_SteelSquads"
			Where spawnbot_arena_right
			TotalCount 10
			MaxActive 10
			SpawnCount 5
			WaitBeforeStarting 16
			WaitBetweenSpawns 20
			TotalCurrency 120

			Squad
			{
				TFBot
				{
					Template T_TFBot_Giant_Soldier
					Tag Glow
				}
				TFBot
				{
