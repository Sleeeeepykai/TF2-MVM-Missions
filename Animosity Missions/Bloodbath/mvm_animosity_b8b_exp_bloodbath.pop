	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    IncludeScript(`mvm_animosity_arena_mode`, getroottable())
					MVMAnimosity_ArenaMode.ArenaVIPInit()

					EntFire(`arena_mode_relay`, `Trigger`)
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
		DoneOutput
		{
			Target BigNet
            Action RunScriptCode
            Param "
                    EmitSoundEx({
						sound_name = `vo/mvm/mght/demoman_mvm_m_autocappedcontrolpoint02.mp3`
						channel = 2	
						filter_type = 5
					})
                  "
		}

		WaveSpawn // Dummy Bomb Carrier
		{
			Name "Dummy_Bomb_Carrier"
			Where spawnbot_left
			Support Limited
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 0

			Squad
			{
				Squad
				{
					TFBot
					{
						Template T_TFBot_Dummy_Bomb
					}
				}
			}
		}

