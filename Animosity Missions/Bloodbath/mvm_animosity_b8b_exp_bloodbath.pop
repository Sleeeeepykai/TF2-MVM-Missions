#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop

WaveSchedule
{
    StartingCurrency 600
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No
    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	//// TEMPLATES ////

	Templates
	{
		T_TFBot_Dummy_Bomb
		{
			Name "the goog"
			Class Heavy
			Skill Expert
			Health 1
			Scale 0.001
			WeaponRestrictions MeleeOnly

			Tag NoGlow

			CharacterAttributes
			{
				"move speed bonus" 0.0001
				"dmg from ranged reduced" 0.0001
				"dmg from melee increased" 0.0001
			}
		}
	}

    //// MISSION BOTS ////

    Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_arena_left
		BeginAtWave 1
		RunForThisManyWaves 7
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
			Tag LethalBot
		}
	}

	Mission // Spy (Wave 2)
	{
		Objective Spy
		Where spawnbot_arena_right
		BeginAtWave 2
		RunForThisManyWaves 1
		InitialCooldown 5
		CooldownTime 40
		DesiredCount 3

		TFBot
		{
			Template T_TFBot_Spy
			Tag LethalBot
		}
	}

	Mission // Sniper (Wave 5)
	{
		Objective Sniper
		Where spawnbot_arena_left
		Where spawnbot_arena_right
		BeginAtWave 5
		RunForThisManyWaves 1
		InitialCooldown 5
		CooldownTime 30
		DesiredCount 3

		TFBot
		{
			Template T_TFBot_Sniper
		}
	}

	//// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    NetProps.SetPropString(Entities.FindByClassname(null, `tf_objective_resource`), `m_iszMvMPopfileName`, `Bloodbath (Exp)`)

					IncludeScript(`mvm_animosity_arena_mode`, getroottable())
					MVMAnimosity_ArenaMode.ArenaVIPInit()

					EntFire(`arena_mode_maingate_close`, `Trigger`)
					EntFire(`arena_mode_flankgateleft_close`, `Trigger`)
					EntFire(`arena_mode_flankgateright_close`, `Trigger`)
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)

					EntFire(`arena_mode_transition_relay`, `Trigger`)
                  "
        }
		DoneOutput
		{
			Target BigNet
            Action RunScriptCode
            Param "
                    EmitSoundEx({
						sound_name = `vo/mvm/mght/demoman_mvm_m_autocappedintelligence01.mp3`
						channel = 2	
						filter_type = 5
					})
                  "
		}

		WaveSpawn
		{
			Name "Wave1_Demo"
			WaitBeforeStarting 0

			FirstSpawnWarningSound "vo/mvm/mght/demoman_mvm_m_laughhappy02.mp3"
		}

		WaveSpawn // Dummy Bomb Carrier
		{
			Name "Dummy_Bomb_Carrier"
			Where spawnbot_left
			Support Limited
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 0

			Squad
			{
				Squad
				{
					TFBot
					{
						Template T_TFBot_Dummy_Bomb
					}
				}
			}
		}

		// Intro Sequence
		WaveSpawn // Launchpad Notif
		{
			Name "Wave1_Notif"
			WaitBeforeStarting 2

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						SendGlobalGameEvent(`show_annotation`, {
							worldPosX = -640
							worldPosY = 1525
							worldPosZ = 80
							id = `arena_launchpad_1`
							text = `Launchpad available!`
							lifetime = 3
							play_sound = `ui/hint.wav`
							show_effect = 1
						})
					  "
			}
		}
		WaveSpawn // Objective 1 Display
		{
			Name "Wave1_Demo"
			WaitBeforeStarting 5

			FirstSpawnWarningSound "vo/mvm/mght/demoman_mvm_m_autocappedcontrolpoint03.mp3"

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						SendGlobalGameEvent(`show_annotation`, {
							worldPosX = 578
							worldPosY = 2726
							worldPosZ = 300
							id = `arena_objective_1`
							text = `The bomb is now ours!`
							lifetime = 5
							play_sound = `ui/hint.wav`
							show_effect = 1
						})
					  "
			}
		}
		WaveSpawn // Objective 2 Display
		{
			Name "Wave1_LeftSpawnOpen"
			WaitBeforeStarting 10

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						EntFire(`arena_mode_sidefence_break`, `Trigger`)
						EntFire(`arena_mode_sidefence_spawnbot_enable`, `Trigger`)

						SendGlobalGameEvent(`show_annotation`, {
							worldPosX = 578
							worldPosY = 2726
							worldPosZ = 300
							id = `arena_objective_2`
							text = `But Gray Mann's robots are not happy...`
							lifetime = 5
							play_sound = `ui/hint.wav`
							show_effect = 1
						})
					  "
			}
		}
		WaveSpawn // Objective 3 Display
		{
			Name "Wave1_Demo"
			WaitBeforeStarting 15

			FirstSpawnWarningSound "vo/mvm/mght/demoman_mvm_m_helpmedefend02.mp3"

			FirstSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						SendGlobalGameEvent(`show_annotation`, {
							worldPosX = 578
							worldPosY = 2726
							worldPosZ = 300
							id = `arena_objective_3`
							text = `Defend the RED Robot, or you will lose!`
							lifetime = 5
							play_sound = `ui/hint.wav`
							show_effect = 1
						})
					  "
			}
		}

