                "OnTrigger" "CarrierPodSmoke4A,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke4B,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke4C,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke4D,Stop,,12,-1"
            }
            OnSpawnOutput
            {
                Target CarrierPodSequence4
                Action Trigger
            }
        }
