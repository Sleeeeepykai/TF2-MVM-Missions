        // Manual Lose Template
        ManualLose // Lose Condition and Relay
        {
            game_round_win // Red Lose Condition
            {
                "TeamNum" "3"
                "targetname" "Red_Lose"
                "switch_teams" "0"
                "force_map_reset" "1"
                "classname" "game_round_win"
            }
            logic_timer
            {
                "targetname"    "Red_Lose_Timer"
                "RefireTime"    "5"
                "StartDisabled" 1
                "OnTimer"       "Red_Lose,RoundWin,,0,-1"
            }
        }
