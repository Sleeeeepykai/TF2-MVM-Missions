    SpawnTemplate "ManualLose"

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action runscriptcode
            Param "
            EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `(Expert) Bloodbath`)
            EntFire(`PlayerLifeCountSet`, `GetValue`)
            IncludeScript(`tankextensions_main`, getroottable())
            IncludeScript(`tankextensions/combattank`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/minigun`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/fireball`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())
            "
        }
        StartWaveOutput
		{
			Target wave_start_relay
			Action Trigger
		}
	    DoneOutput					
		{
			Target wave_finished_relay
			Action Trigger
		}
        
        //// WAVE INIT TEXT ////

        //// WAVE 1 TEMPLATES ////

        SpawnTemplate IntroSequence

        //// INTRO SEQUENCE ////
        WaveSpawn
        {
            Name "Intro"
            WaitBeforeStarting 0

            FirstSpawnOutput
            {
                Target IntroSequenceRelay
                Action Trigger
            }
        }
        
        // Subwave 1
        WaveSpawn // Carrier Pod 1 Sequence
        {
            Name "Wave1_Subwave1_GSoldierPod"
            WaitBeforeStarting 20

            FirstSpawnOutput
            {
                Target BotCarrierPod1
                Action ForceSpawn
            }
        }
        WaveSpawn // 1 GSoldier in Carrier Pod 1
        {
            Name "Wave1_Subwave1_GSoldierPod"
            Where spawnbot_carrierpod1 [$SIGSEGV]
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 30
            WaitBetweenSpawns 0
            TotalCurrency 40

            TFBot
            {
                Template T_TFBot_Giant_Soldier
                Action Mobber
            }
        }
        WaveSpawn // 8 Scouts on Invasion
        {
            Name "Wave1_Subwave1_Scouts"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierPod"
            Where spawnbot_invasion
            TotalCount 8
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 1
            TotalCurrency 16

            TFBot
            {
                Class Scout
                Action Mobber
            }
        }
        WaveSpawn // 1 GSoldier on Left
        {
            Name "Wave1_Subwave1_GSoldierLeft"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierPod"
            Where spawnbot_left
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 8
            WaitBetweenSpawns 0
            TotalCurrency 40

            TFBot
            {
                Template T_TFBot_Giant_Soldier
                Action Mobber
            }
        }
        WaveSpawn // 1 GSoldier on Right
        {
            Name "Wave1_Subwave1_GSoldierRight"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierPod"
            Where spawnbot_right
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 8
            WaitBetweenSpawns 0
            TotalCurrency 40

            TFBot
            {
                Template T_TFBot_Giant_Soldier
                Action Mobber
            }
        }
        WaveSpawn // 16 Scouts on Main
        {
            Name "Wave1_Subwave1_Scouts"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierPod"
            Where spawnbot
            TotalCount 16
            MaxActive 8
            SpawnCount 4
            WaitBeforeStarting 0
            WaitBetweenSpawns 4
            TotalCurrency 32

            TFBot
            {
                Class Scout
                Action Mobber
            }
        }

        // Subwave 2
        WaveSpawn // 2 GPyros on Main
        {
            Name "Wave1_Subwave2_GPyro"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierLeft"
            Where spawnbot
            TotalCount 2
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 12
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Giant_Pyro
                WeaponRestrictions SecondaryOnly
                Attributes HoldFireUntilFullReload
                Name "Giant Shotgun Pyro"
                ClassIcon heavy_shotgun_giant
                Action Mobber
            }
        }
        WaveSpawn // 24 Bowmen on Invasion
        {
            Name "Wave1_Subwave2_Bowmen"
            WaitForAllSpawned "Wave1_Subwave1_GSoldierLeft"
            Where spawnbot_invasion
            RandomSpawn 1
            TotalCount 24
            MaxActive 16
            SpawnCount 2
            WaitBeforeStarting 16
            WaitBetweenSpawns 2
            TotalCurrency 48

            TFBot
            {
                Template T_TFBot_Sniper_Huntsman
                Skill Normal
                Action Mobber
            }
        }

        // Subwave 3
        WaveSpawn // Carrier Pod 2 Sequence
        {
            Name "Wave3_Subwave1_GDemoPod"
            WaitForAllSpawned "Wave1_Subwave2_GPyro"
            WaitBeforeStarting 16

            FirstSpawnOutput
            {
                Target BotCarrierPod2
                Action ForceSpawn
            }
        }
        WaveSpawn // 1 GBurst Demo in Carrier Pod 2
        {
            Name "Wave1_Subwave3_GDemo"
            WaitForAllSpawned "Wave1_Subwave2_GPyro"
            Where spawnbot_carrierpod2 [$SIGSEGV]
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 26
            WaitBetweenSpawns 0
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Giant_Demo_Burst
                Health 8000
                Scale 1.9
                Name "Giant Armoured Burst Demo"
                ClassIcon demo_burst_armored_revamp
                Attributes UseBossHealthBar
                Action Mobber
            }
        }
        WaveSpawn // Punchies and Bigheals on Support
        {
            Name "Wave1_Subwave3_Punchies"
            WaitForAllSpawned "Wave1_Subwave2_GPyro"
            Where spawnbot_invasion
            Support Limited
            TotalCount 32
            MaxActive 16
            SpawnCount 2
            WaitBeforeStarting 16
            WaitBetweenSpawns 2
            TotalCurrency 104

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Heavyweight_Champ
                    Action Mobber
                }
                TFBot
                {
                    Template T_TFBot_Medic_BigHeal
                    Action Mobber
                }
            }
        }
    }
}