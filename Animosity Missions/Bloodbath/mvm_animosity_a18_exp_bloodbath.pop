        Node "1581 -3786 1519"
        Node "535 -2396 64"
    }

    //// POINT TEMPLATES ////

    PointTemplates
    {
        // Sequence Templates
        IntroSequence // Wave 1 Arena Mode Setup
        {
            game_text
			{
				"origin" "0 0 0"
				"targetname" "Intro1"
				"message" "You've been chosen to partake in an exercise that will test you greatly."
				"spawnflags" "1"
				"x" "-1"
				"y" "0.25"
				"effect" "2"
				"color" "255 255 255"
				"fadeout" "0.5"
				"holdtime" "4"
				"fxtime" "0.5"
				"channel" "1"
			}
            game_text
			{
				"origin" "0 0 0"
				"targetname" "Intro2"
				"message" "You will contest against various enemies in a brutal, relentless gauntlet."
				"spawnflags" "1"
				"x" "-1"
				"y" "0.25"
				"effect" "2"
				"color" "255 255 255"
				"fadeout" "0.5"
				"holdtime" "4"
				"fxtime" "0.5"
				"channel" "1"
			}
            game_text
			{
				"origin" "0 0 0"
				"targetname" "Intro3"
				"message" "Your goal?"
				"spawnflags" "1"
				"x" "-1"
				"y" "0.25"
				"effect" "2"
				"color" "255 255 255"
				"fadeout" "0.5"
				"holdtime" "2"
				"fxtime" "0.5"
				"channel" "1"
			}
            game_text
			{
				"origin" "0 0 0"
				"targetname" "Intro4"
				"message" "FIGHT FOR YOUR LIVES"
				"spawnflags" "1"
				"x" "-1"
				"y" "0.25"
				"effect" "2"
				"color" "225 0 0"
                "fadein" "0.075"
				"fadeout" "0.5"
				"holdtime" "2"
				"fxtime" "0.5"
				"channel" "1"
			}
            info_target // Arena Zone Teleport Position
            {
                "targetname" "arena_zone_target"
                "origin" "433 -2706 64"
                "angles" "0 90 0"
            }
            trigger_teleport // Arena Zone Teleport
            {
                "targetname" "arena_zone"
                "origin" "255 -1895 143"
                "spawnflags" "1"
                "target" "arena_zone_target"
                "mins" "-5000 -5000 -5000"
                "maxs" "5000 5000 5000"
                "disableshadows" "1"
                "startdisabled" "1"
            }
            logic_relay // Intro Sequence Relay
            {
                "targetname" "IntroSequenceRelay"
                "OnTrigger" "Intro1,Display,,0,-1"
                "OnTrigger" "Intro2,Display,,5,-1"
                "OnTrigger" "Intro3,Display,,10,-1"
                "OnTrigger" "Intro4,Display,,13,-1"
                "OnTrigger" "arena_mode_relay,Trigger,,16,-1"
                "OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_warning.wav,18,-1"
                "OnTrigger" "arena_zone,Enable,,17.9,-1"
                "OnTrigger" "arena_zone,Disable,,18,-1"
            }
        }

        // Carrier Drop Pod Templates
        BotCarrierPod1 // Bot Drop-Pod for in-Arena Spawns
        {
            NoFixUp 1
            
            prop_dynamic // Carrier Pod Model
            {
                "targetname" "CarrierPod1"
