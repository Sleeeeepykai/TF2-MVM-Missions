        TeamNum 3
        StartDisabled 0
    }
    ExtraSpawnPoint // Carrier Pod 4
    {
        Name "spawnbot_carrierpod4"
        X 611 Y -894 Z 68
        TeamNum 3
        StartDisabled 0
    }
    ExtraSpawnPoint // Carrier Pod 5
    {
        Name "spawnbot_carrierpod5"
        X 535 Y -2396 Z 68
        TeamNum 3
        StartDisabled 0
    }

    //// TANK PATHS ////

    // Carrier Pod Paths 

    ExtraTankPath // Carrier Pod 1
    {
        Name "carrierpod1_path"
        Node "2062 -1570 1519"
        Node "1164 -1585 96"
    }
    ExtraTankPath // Carrier Pod 2
    {
        Name "carrierpod2_path"
        Node "-1297 -1417 1519"
