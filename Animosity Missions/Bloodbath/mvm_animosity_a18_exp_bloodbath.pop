            {
                "targetname" "CarrierPodIndicator1"
                "origin" "1164 -1585 96"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "5"
                "skin" "5"
                "defaultanim" "start"
                "disableshadows" "1"
                "startdisabled" "1"
            }
            env_shake // Carrier Pod Impact Shake
            {
                "targetname" "CarrierPodShake1"
                "parentname" "CarrierPodLauncher1"
                "amplitude" "16"
                "frequency" "8"
                "duration" "4"
                "spawnflags" "5"
            }
            logic_relay // Carrier Pod Launch Sequence
            {
                "targetname" "CarrierPodSequence1"
                "OnTrigger" "tf_gamerules,PlayVO,npc/env_headcrabcanister/launch.wav,0,-1"
                "OnTrigger" "CarrierPodIndicator1,Enable,,2,-1"
                "OnTrigger" "tf_gamerules,PlayVO,ui/rd_2base_alarm.wav,2,-1"

                "OnTrigger" "CarrierPod1,Enable,,6,-1"
                "OnTrigger" "CarrierPodLauncher1,SetSpeed,0.1,6,-1"
                "OnTrigger" "CarrierPodTrail1,Start,,6,-1"
                "OnTrigger" "CarrierPodLauncher1,SetSpeed,1,7,-1"
                "OnTrigger" "tf_gamerules,PlayVO,npc/env_headcrabcanister/incoming.wav,7,-1"

                "OnTrigger" "CarrierPodIndicator1,Disable,,7.75,-1"
                "OnTrigger" "CarrierPodTrail1,Stop,,7.75,-1"
                "OnTrigger" "CarrierPodImpact1,Start,,7.75,-1"
                "OnTrigger" "CarrierPodShake1,StartShake,,7.75,-1"
                "OnTrigger" "tf_gamerules,PlayVO,ambient/explosions/explode_4.wav,7.75,-1"

                "OnTrigger" "CarrierPodSmoke1A,Start,,10,-1"
                "OnTrigger" "CarrierPodSmoke1B,Start,,10,-1"
                "OnTrigger" "CarrierPodSmoke1C,Start,,11,-1"
                "OnTrigger" "CarrierPodSmoke1D,Start,,11,-1"
                "OnTrigger" "tf_gamerules,PlayVO,misc/doomsday_cap_close_start.wav,10,-1"

                "OnTrigger" "CarrierPod1,Disable,,12,-1"
                "OnTrigger" "CarrierPodSmoke1A,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke1B,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke1C,Stop,,12,-1"
                "OnTrigger" "CarrierPodSmoke1D,Stop,,12,-1"
            }
