#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop

WaveSchedule
{
    StartingCurrency 3000
    RespawnWaveTime 2
    FixedRespawnWaveTime Yes
    CanBotsAttackWhileInSpawnRoom No

    //// ROBOT TEMPLATES ////

    //// MISSION BOTS ////

    Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_mission_sentrybuster
		BeginAtWave 1
		RunForThisManyWaves 1
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}

    //// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    NetProps.SetPropString(Entities.FindByClassname(null, `tf_objective_resource`), `m_iszMvMPopfileName`, `War Without Reason (Nightmare)`)
					EntFire(`bombpath_left_relay`, `Trigger`)
					EntFire(`bombpath_lowerhatch_relay`, `Trigger`)
                    EntFire(`robot_bomb`, `SetReturnTime`, 45)
                    EntFire(`robot_bomb`, `ShowTimer`, 1)

                    IncludeScript(`robot_scripts_kai`, getroottable())
                    IncludeScript(`tankextensions_main`, getroottable())
                    IncludeScript(`tankextensions/combattank`, getroottable())
                    IncludeScript(`tankextensions/combattank_weapons/minigun`, getroottable())
                    IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
                    IncludeScript(`tankextensions/combattank_weapons/fireball`, getroottable())
                    IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        //// PHASE 1 ////

        // Subwave 1
        WaveSpawn // 2 GSoldiers
        {
            Name "Nightmare_Subwave1_GSoldier"
            Where spawnbot_left
            TotalCount 2
            MaxActive 2
            SpawnCount 2
            WaitBeforeStarting 0.1
            WaitBetweenSpawns 0
            TotalCurrency 40

            TFBot
            {
                Template T_TFBot_Giant_Soldier
                Tag bot_giant
            }
        }
        WaveSpawn // 2 GSoldiers
        {
            Name "Nightmare_Subwave1_GSoldier"
            Where spawnbot_right
