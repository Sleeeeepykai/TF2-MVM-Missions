    // Drop Pod Spawn Points
    ExtraSpawnPoint
    {
        Name "missile_spawn_a"
        X 2206 Y -82 Z -0
        TeamNum 3
    }
    ExtraSpawnPoint
    {
        Name "missile_spawn_b"
        X 705 Y -774 Z -130
