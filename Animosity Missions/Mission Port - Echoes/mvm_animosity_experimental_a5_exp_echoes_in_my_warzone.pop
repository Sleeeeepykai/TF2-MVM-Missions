            }
            info_particle_system // Big Bomb Particle
            {
                "targetname" "BIGBombParticle"
                "origin" "704 2880 160"
                "effect_name" "dxhr_lightningball_parent_blue"
                "start_active" "0"
            }

            env_shake // Big Bomb Shake
			{
                "targetname" "BIGBombShake"
                "spawnflags" "5" 
                "amplitude" "16"	
                "duration" "3"	
                "frequency" "9"	
            }
            training_annotation // Big Bomb Warning
			{
				"targetname"   "BIGBombWarning"
                "origin" "704 2880 612"
