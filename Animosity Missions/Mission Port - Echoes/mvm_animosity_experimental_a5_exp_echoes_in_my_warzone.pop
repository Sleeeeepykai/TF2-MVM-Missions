            logic_relay // Timer Loss Relay
			{
				"targetname" "TimerLossRelay"
                "OnTrigger" "playerRunScriptCodeself.ViewPunch(QAngle(-80,10,0))0-1"
                "OnTrigger" "player*,$AddCond,22,0,-1"

                "OnTrigger" "tf_gamerules,PlayVO,ambient\explosions\citadel_end_explosion1.wav,0,1"
                "OnTrigger" "tf_gamerules,PlayVO,ambient\explosions\citadel_end_explosion1.wav,0,1"
                "OnTrigger" "tf_gamerules,PlayVO,misc\doomsday_missile_explosion.wav,0,1"

                "OnTrigger" "pop_interface,PauseBotSpawning,,0,1"

                "OnTrigger" "Add5Seconds,Disable,,0,1"
                "OnTrigger" "Add15Seconds,Disable,,0,1"
                "OnTrigger" "Add30Seconds,Disable,,0,1"
                "OnTrigger" "Add45Seconds,Disable,,0,1"
                "OnTrigger" "Add60Seconds,Disable,,0,1"
                "OnTrigger" "Add120Seconds,Disable,,0,1"

                "OnTrigger" "BIGBombParticle*,Kill,,0,1"
                "OnTrigger" "TimerLossFade,Fade,,0.1,-1"
                "OnTrigger" "TheBIGBomb*,Disable,,0.15,1"
                "OnTrigger" "BotRemoverEnable,,0.3,-1"
				"OnTrigger" "bots_win,RoundWin,,1,-1"
			}

