    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Where spawnbot_arena_left
        Where spawnbot_arena_right
        Objective DestroySentries
        BeginAtWave 1
        RunForThisManyWaves 1
        DesiredCount 1

        InitialCooldown 20
        CooldownTime 30

        TFBot
        {
            Template T_TFBot_SentryBuster
        }
    }
    Mission // Sniper
    {
        Where spawnbot_arena_left
        Where spawnbot_arena_right
