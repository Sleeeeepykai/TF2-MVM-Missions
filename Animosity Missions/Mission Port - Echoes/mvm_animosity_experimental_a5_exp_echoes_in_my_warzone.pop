            {
                target "roundbeamtest"
                action "TurnOff"
                delay "4.5"
            }
            OnSpawnOutput
            {
                target "roundbeamtest"
                action "StrikeOnce"
                delay "0"
            }
            OnSpawnOutput
            {
                target "roundbeamtest"
                action "kill"
                delay "5.0"
            }
            OnSpawnOutput
            {
                target "ringmarkerone"
                action "RunScriptCode"
                param "SetMoveIgnoreSolid(self, 200)"
            }
            OnSpawnOutput
            {
                target "roundbeamtest"
