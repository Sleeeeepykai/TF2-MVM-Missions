WaveSchedule
{
	//// POINT TEMPLATES ////

	PointTemplates
	{
		PlasmaSniper_BeamPT
		{
			RemoveIfKilled "PlasmaAimBeam"

			OnSpawnOutput
			{
				Target "PlasmaAimStart"
				Action ClearParent
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "PlasmaAimEnd"
				Action ClearParent
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "PlasmaAimBeam"
				Action TurnOn
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "PlasmaAimBeam"
				Action Kill
				Delay 3.5
			}

			env_beam
			{
				"targetname" "PlasmaAimBeam"
				"origin" "0 0 0"
				"LightningStart" "PlasmaAimStart"
				"LightningEnd" "PlasmaAimEnd"
				"life" "0"
				"BoltWidth" "5"
				"TextureScroll" "-20"
				"texture" "sprites/laserbeam.vmt"
				"rendermode" "1"
				"renderamt" "144"
				"rendercolor" "192 0 255"
			}
			prop_dynamic
			{
				"targetname" "PlasmaAimStart"
				"origin" "0 0 0"
				"model" "models/empty.mdl"
				"disableshadows" "1"
			}
			prop_dynamic
			{
				"targetname" "PlasmaAimEnd"
				"origin" "5000 0 0"
				"model" "models/empty.mdl"
				"disableshadows" "1"
			}
		}
	}

	Templates
