	//// MISSION BOTS ////
	
	Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot
		BeginAtWave 1
		RunForThisManyWaves 8
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}
	Mission	// Engineer (Wave 3)
	{
		Objective	Engineer
		Where	spawnbot
		BeginAtWave	3
		RunForThisManyWaves	1
		InitialCooldown	50
		CooldownTime	30
		DesiredCount	1
		TFBot
		{
			Template T_TFBot_Engineer_Sentry_Teleporter_TeleIn
			ClassIcon engineer_telein
			TeleportWhere spawnbot
			TeleportWhere spawnbot_giant
		}
	}
	Mission	// Engineer (Wave 5)
	{
		Objective	Engineer
		Where	spawnbot
		BeginAtWave	5
		RunForThisManyWaves	1
		InitialCooldown	30
		CooldownTime	45
		DesiredCount	1
		TFBot
		{
			Template	T_TFBot_Engineer_Sentry_Teleporter_TeleIn
			ClassIcon	engineer_telein
			TeleportWhere	spawnbot
		}
	}
	Mission // Spy (Wave 6)
	{
		Objective Spy
		Where spawnbot
		BeginAtWave 6
		RunForThisManyWaves 1
		InitialCooldown 30
		CooldownTime 45
		DesiredCount 4

		TFBot
		{
			Template T_TFBot_Spy
		}
	}

	//// WAVES ////

	// General Notes

	// Wave 1 Notes
	// 1st subwave rework; have a bulk giant and common groups with an uber medic expert skill mixed in
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_holograms_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_left_relay`, `Trigger`, null, 6.1)
            	  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		// Subwave 1
		WaveSpawn // 5 Steel Gauntlets, 5 Full-Uber Medics and 5 Pyros
		{
			Name "Wave1_Subwave1_SteelGauntlets"
			Where spawnbot
			TotalCount 15
			MaxActive 7
			SpawnCount 3
			WaitBeforeStarting 0
			WaitBetweenSpawns 6
			TotalCurrency 100

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Template T_TFBot_Heavy_SteelFist
				}
				TFBot
				{
					Template T_TFBot_Medic_Uber
				}
				TFBot
				{
					Class Pyro
					Skill Easy
				}
			}
		}
		WaveSpawn // 30 Scatter-Bonk Scouts
		{
			Name "Wave1_Subwave1_Scatterbonks"
			Where spawnbot
			TotalCount 30
			MaxActive 12
			SpawnCount 10
			WaitBeforeStarting 2
			WaitBetweenSpawns 10
			TotalCurrency 100

			TFBot
			{
				Template T_TFBot_Scout_Bonk_Scatter
			}
		}
		WaveSpawn // 7 Pyros
		{
			Name "Wave1_Subwave1_Pyros"
			Where spawnbot
			TotalCount 7
			MaxActive 3
			SpawnCount 1
			WaitBeforeStarting 6
			WaitBetweenSpawns 3
			TotalCurrency 100

			TFBot
			{
				Class Pyro
				Skill Easy
			}
		}

		// Subwave 2
		WaveSpawn // 4 Armored Shotgun Heavies and 8 Blast Soldiers
		{
			Name "Wave1_Subwave2_ArmoredHeavySquads"
			WaitForAllSpawned "Wave1_Subwave1_SteelGauntlets"
			Where spawnbot
			TotalCount 12
			MaxActive 9
			SpawnCount 3
			WaitBeforeStarting 12
			WaitBetweenSpawns 6
			TotalCurrency 150

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Template T_TFBot_Heavy_Shotgun_Armored
				}
				TFBot
				{
					Template T_TFBot_Soldier_Blast
				}
				TFBot
				{
					Template T_TFBot_Soldier_Blast
				}
			}
		}
		WaveSpawn // 15 Soldiers
		{
			Name "Wave1_Subwave2_Soldiers"
			WaitForAllSpawned "Wave1_Subwave1_SteelGauntlets"
			Where spawnbot
			TotalCount 15
			MaxActive 10
			SpawnCount 5
			WaitBeforeStarting 14
			WaitBetweenSpawns 6
			TotalCurrency 150

			TFBot
			{
				Class Soldier
				Skill Easy
			}
		}
	}
