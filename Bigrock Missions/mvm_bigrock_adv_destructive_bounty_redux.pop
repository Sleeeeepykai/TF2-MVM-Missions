			TotalCount 6
			MaxActive 6
			SpawnCount 3
			WaitBeforeStarting 15
			WaitBetweenSpawns 18
			TotalCurrency 200

			Squad
			{
				TFBot
				{
					Template T_TFBot_Giant_Pyro
					Attributes AlwaysFireWeapon
				}
				TFBot
				{
					Template T_TFBot_Medic_BigHeal
				}
				TFBot
				{
					Template T_TFBot_Medic_BigHeal
				}
			}
		}
		WaveSpawn // 30 Burst Demos
		{
			Name "Wave2_Subwave2_BurstDemos"
			WaitForAllSpawned "Wave2_Subwave1_GRapidSoldier"
			Where spawnbot
			TotalCount 30
			MaxActive 8
			SpawnCount 2
			WaitBeforeStarting 8
			WaitBetweenSpawns 1
			TotalCurrency 150

			TFBot
			{
				Template T_TFBot_Demoman_Burst
			}
		}
	}
	// Wave 3 Notes
	// Condense blast soldiers into rapid fire bowmen and use a different common
