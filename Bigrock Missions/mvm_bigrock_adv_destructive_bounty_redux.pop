			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 16
			WaitBetweenSpawns 0
			TotalCurrency 200

			Tank
			{
				Name "tankboss"
				Health 22000
				Speed 75
				StartingPathTrackNode "boss_path_1"

				OnBombDroppedOutput
				{
					Target boss_deploy_relay
					Action Trigger
				}
			}
			FirstSpawnOutput
			{
				Target "player"
				Action "$DisplayTextHint"
				Param "Tank inbound with 22,000 HP"
			}
		}

		// Subwave 2
		WaveSpawn // 2 GPyros and 4 Bigheal Medics
