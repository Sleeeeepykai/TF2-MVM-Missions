#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 500
	RespawnWaveTime	2
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	//// PRECACHES ////

	// Precached Models
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_combat_tank_chassis.mdl" [$SIGSEGV]
    PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_minigun.mdl" [$SIGSEGV]
    PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_rocket_dumbfire.mdl" [$SIGSEGV]
    PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_rocket_pod.mdl" [$SIGSEGV]

	//// CUSTOM WEAPONS ////

	CustomWeapon
	{
		"PickaxeRocks"
		{
			OriginalItemName "The Iron Bomber"
			"faster reload rate" 0
			"projectile speed decreased" 0.75
			"mult projectile scale" 0.5
			"custom projectile size" 24
			"custom projectile model" "models/props_forest/cliff_wall_09c.mdl"
			"projectile spread angle penalty" 4
			"mult projectile count" 3
		}
		"Rocket_Attack"
		{
			OriginalItemName "TF_WEAPON_ROCKETLAUNCHER"
			"damage bonus" 1
			"projectile speed decreased" 0.4
			"mod projectile heat seek power" 180
			"mod projectile heat aim error" 360
			"mod projectile heat aim time" 0.5
			"mod projectile heat no predict target speed" 1
			"projectile trail particle" "eyeboss_projectile"
		}
		"Bigrock_Rocket"
        {
            OriginalItemName "Highland High Heels"
            "custom item model" "models/weapons/c_models/c_rocketlauncher/c_rocketlauncher.mdl" 
            "attachment name" "flag"
            "attachment angles" "0 270 0"

            "attachment offset" "25 0 0"
            // X: Positive = Left | Negative = Right
            // Y: Positive = Down | Negative = Up
            // Z: Positive = Further | Negative = Closer
        }
		"Bigrock_Rocket2"
        {
            OriginalItemName "Potato of Labor"
            "custom item model" "models/weapons/c_models/c_rocketlauncher/c_rocketlauncher.mdl" 
            "attachment name" "flag"
            "attachment angles" "0 270 0"

            "attachment offset" "-25 0 0"
            // X: Positive = Left | Negative = Right
            // Y: Positive = Down | Negative = Up
            // Z: Positive = Further | Negative = Closer
        }
	}

	//// POINT TEMPLATES ////

	PointTemplates
	{
		soldier_boss_logic
		{
			OnSpawnOutput
			{
				Target "PickaxeAttack"
				Action "$SetOwner"
				Param "!activator"
				Delay 0.02
			}
			OnSpawnOutput
			{
				Target "PickaxeAttack"
				Action "$RotateTowards"
				Param "!activator"
				Delay 0.02
			}
			OnSpawnOutput
			{
				Target "RocketAttackLeft"
				Action "$SetOwner"
				Param "!activator"
				Delay 0.02
			}
			OnSpawnOutput
			{
				Target "RocketAttackRight"
				Action "$SetOwner"
				Param "!activator"
				Delay 0.02
			}
			tf_point_weapon_mimic
			{
				"spawnflags" "1"
				"targetname" "PickaxeAttack"
				"$weaponname" "PickaxeRocks"
				"origin" "40 0 80"
				"angles" "-40 0 0"
				"$preventshootparent" "1"
				"teamnum" "3"
				"Crits" "false"
				"modelscale" "1"

				"$modules" "rotator"
				"$lookat" "aim"
				"$rotationspeedx" "300"
				"$rotationspeedy" "300"
				"$rotationlimitx" "180"
				"$rotationlimity" "180"
			}
			tf_point_weapon_mimic
			{
				"targetname" "RocketAttackLeft"
				"origin" "25 50 150"
				"angles" "315 0 0"

				"$weaponname" "Rocket_Attack"
				"teamnum" "3"
				"crits" "false"
				"$preventshootparent" "1"

				"spawnflags" "1"
			}
			tf_point_weapon_mimic
			{
				"targetname" "RocketAttackRight"
				"origin" "25 -50 150"
				"angles" "315 0 0"

				"$weaponname" "Rocket_Attack"
				"teamnum" "3"
				"crits" "false"
				"$preventshootparent" "1"

				"spawnflags" "1"
			}
		}
	}

