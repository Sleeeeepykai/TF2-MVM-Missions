#base robot_standard.pop 
#base robot_giant.pop
#base robot_moonlight_nai.pop

//Collab Mission by SleepyKai & Nai

WaveSchedule
{
	StartingCurrency 400
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	MaxRedPlayers 6
	AllowBotExtraSlots 1
	RobotLimit 28

	//// PRECACHES ////

	// Precached Models
	PrecacheModel "models/mvm/bots/bot_medic.mdl"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PTs
		{
			point_populator_interface
			{
				"targetname" "pop_interface"
			}
		}

		Global_PTs
		{
			logic_case
			{
				"targetname" "Soldier_LimitBreakVoiceline"

				"OnCase01" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts02.mp3,0,-1"
				"OnCase01" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts02.mp3,0,-1"
				"OnCase02" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts03.mp3,0,-1"
				"OnCase02" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts03.mp3,0,-1"
				"OnCase03" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts05.mp3,0,-1"
				"OnCase03" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts05.mp3,0,-1"
			}

			info_target
			{
				"targetname" "spawnbot_boss1"
				"origin" "5000 3575 730"
				"angles" "0 90 0"
			}
			info_target
			{
				"targetname" "spawnbot_boss2"
				"origin" "4715 3575 730"
				"angles" "0 90 0"
			}
		}

		//// Limitbreaker Part 1 PTs ////

		LimitbreakerPart1CoreLogic
		{
			OnSpawnOutput
            {
                Target bosstarget
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			info_target
            {
                "TargetName" "bosstarget"
                "origin" "0 0 0"
            }

			trigger_multiple
			{
				"targetname" "LimitbreakerDetector"
				"origin" "0 0 100"
				"mins" "-384 -384 -256"
				"maxs" "384 384 256"

				"wait" "0.5"
				"filtername" "LimitbreakerGiantFilter"
				"spawnflags" "1"
				"startdisabled" "1"

				"OnStartTouch" "!parent,$ChangeAttributes,LimitbreakerTetherAbility,0,-1"
			}
			filter_tf_bot_has_tag
			{
				"targetname" "LimitbreakerGiantFilter"
				"tags" "LimitbreakerGiant"
				"require_all_tags" "1"
			}

			// Limitbreaker Main Relays

			logic_relay // Limitbreaker Intro Relay
			{
				"targetname" "LimitbreakerIntroRelay"

				"OnTrigger" "!activator,$Taunt,,0,-1"
				"OnTrigger" "!activator,$Taunt,,0.1,-1"
				"OnTrigger" "!activator,$Taunt,,0.2,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierLimitBreakIntro,3.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted02.mp3,4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted02.mp3,4,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,4,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,4.1,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,4.2,-1"
				"OnTrigger" "LimitbreakerTetherSpawner,ForceSpawnAtEntityOrigin,!activator,7.33,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,7.33,-1"
				"OnTrigger" "@p@patienttarget,$Taunt,,7.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,7.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,items\powerup_pickup_supernova.wav,7.33,-1"
				"OnTrigger" "PlayerRunScriptCodeScreenShake(self.GetOrigin(), 5, 5, 2, 50000, 0, true)7.33-1"
				"OnTrigger" "LimitbreakerTetherBuilding,SetBuilder,,7.4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted04.mp3,10,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted04.mp3,10,-1"
				"OnTrigger" "TetherIntroNote1,Show,,10,-1"
				"OnTrigger" "Soldier_LimitBreakVoiceline,PickRandom,,11.33,-1"
				"OnTrigger" "TetherIntroNote2,Show,,15,-1"
				"OnTrigger" "!activator,$ChangeAttributes,LimitbreakerDefaultTether,20,-1"
			}

			// Limitbreaker Tether Ability
			logic_relay // Limitbreaker Tether Beam Attach Relay
			{
				"targetname" "LimitbreakerTetherAttachRelay"
				"OnTrigger" "LimitbreakerDetector,Disable,,0,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,0,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,0.1,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Doctor's Defibrillators,0.2,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierLimitBreak,3.33,-1"
				"OnTrigger" "LimitbreakerTetherSpawner,ForceSpawnAtEntityOrigin,!activator,3.33,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,3.33,-1"
				"OnTrigger" "@p@patienttarget,$Taunt,,3.33,-1"
				"OnTrigger" "@p@patienttarget,$AddCond,51 2,3.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,3.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,items\powerup_pickup_supernova.wav,3.33,-1"
				"OnTrigger" "PlayerRunScriptCodeScreenShake(self.GetOrigin(), 5, 5, 2, 50000, 0, true)3.33-1"
				"OnTrigger" "LimitbreakerTetherBuilding,SetBuilder,,3.4,-1"
				"OnTrigger" "Soldier_LimitBreakVoiceline,PickRandom,,7.33,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Sustain Relay
			{
				"targetname" "LimitbreakerTetherSustainRelay"
				"OnTrigger" "LimitbreakerTether,StrikeOnce,,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,0.15,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Beam Break Relay
			{
				"targetname" "LimitbreakerTetherBreakRelay"
				"OnTrigger" "tf_gamerules,PlayVO,player/invulnerable_off.wav,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc\halloween\spell_spawn_boss_disappear.wav,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Disable,,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,LimitbreakerStun,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierStun,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Enable,,10,-1"
				"OnTrigger" "LimitbreakerDetector,Enable,,10,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Patient Break Relay
			{
				"targetname" "LimitbreakerTetherPatientBreakRelay"
				"OnTrigger" "tf_gamerules,PlayVO,player/invulnerable_off.wav,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc\halloween\spell_spawn_boss_disappear.wav,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Disable,,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,LimitbreakerDefault,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Enable,,10,-1"
				"OnTrigger" "LimitbreakerDetector,Enable,,10,-1"

				"spawnflags" "2"
			}

			env_entity_maker // Limitbreaker Tether Spawner
			{
				"targetname" "LimitbreakerTetherSpawner"
				"entitytemplate" "LimitbreakerTether"
				"$autoparent" "1"
			}
			env_beam // Limitbreaker Tether Beam
            {
                "targetname" "LimitbreakerTether"
                "BoltWidth" "8"
                "LightningStart" "LimitBreakerTetherStart"
                "LightningEnd" "LimitBreakerTetherEnd"
                "origin" "0 0 0"
                "renderamt" "200"
                "rendercolor" "200 200 255"
                "damage" "0"
                "NoiseAmplitude" "1"
                "dissolvetype" "1"
                "texture" "sprites/laserbeam.spr"
                "TouchType" "1"
				"life" "0.16"
				"spawnflags" "96"
            }
			prop_dynamic // Limitbreaker Tether Beam Start Point
            {
                "targetname" "LimitbreakerTetherStart"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }
		}

		LimitbreakerTether
		{
			OnSpawnOutput
			{
				Target LimitBreakerTetherBuilding
				Action $SetOwner
				Param !parent
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "LimitbreakerTetherBuilding"
				Action "SetHealth"
				Param 1000
                Delay 0.1
			}
			obj_dispenser
			{
				"targetname" "LimitbreakerTetherBuilding"
				"angles" "-70 0 0"
				"origin" "-25 0 90"
				"teamnum" "3"
				"defaultupgrade" "2"
				"solid" "0"
				"$radiusmult" "0.01"
                "$cannotbesapped" "1"
                "$dispensermodelprefix" "models/buildables/amplifier_test/amplifier.mdl"

				"OnDestroyed" "LimitbreakerTetherBreakRelay,Trigger,,0,-1"
			}
		}

		LimitBreakerTetherPatient
		{
			OnSpawnOutput
            {
                Target patienttarget
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			info_target
            {
                "TargetName" "patienttarget"
                "origin" "0 0 0"
            }

			OnParentKilledOutput
			{
				Target LimitBreakerPatientBreakRelay
				Action Trigger
				Delay -1
			}

			prop_dynamic // Limitbreaker Tether Beam End Point
            {
                "targetname" "LimitbreakerTetherEnd"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }

			training_annotation
			{
				"targetname" "TetherIntroNote1"
				"origin" "0 0 200"
				"display_text" "This giant has been Reforged!"
				"lifetime" "5"
			}
			training_annotation
			{
				"targetname" "TetherIntroNote2"
				"origin" "0 0 200"
				"display_text" "He will become stronger over time, but you can break the tether powering his strength!"
				"lifetime" "5"
			}
		}
	}

	//// SPAWNED POINT TEMPLATES ////

	SpawnTemplate "Core_PTs"
	SpawnTemplate "Global_PTs"

	//// EXTRA SPAWNPOINTS ////

	//// ROBOT TEMPLATES ////

	Templates
	{
