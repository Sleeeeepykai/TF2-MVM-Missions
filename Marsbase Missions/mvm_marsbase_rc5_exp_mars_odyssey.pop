#base robot_standard.pop 
#base robot_giant.pop
#base robot_moonlight_nai.pop

//Collab Mission by SleepyKai & Nai

WaveSchedule
{
	StartingCurrency 400
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	MaxRedPlayers 6
	AllowBotExtraSlots 1
	RobotLimit 28

	//// PRECACHES ////

	// Precached Models
	PrecacheModel "models/mvm/bots/bot_medic.mdl"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PTs
		{
			point_populator_interface
			{
				"targetname" "pop_interface"
			}
		}

		//// Limitbreaker Part 1 PTs ////

		LimitBreakerPart1_CoreLogic
		{
			OnSpawnOutput
            {
                Target bosstarget
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			info_target
            {
                "TargetName" "bosstarget"
                "origin" "0 0 0"
            }

			// Limitbreaker Main Relays

			logic_relay
			{
				"targetname" "LimitbreakerIntroRelay"

				"OnTrigger" "!activator,$Taunt,,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "!activator,$ChangeAttributes,Limitbreaker_Tether_Ability,5,-1"
			}

			// Limitbreaker Tether Ability
			logic_relay // Limitbreaker Tether Beam Attach Relay
			{
				"targetname" "Limitbreaker_Tether_Attach_Relay"
				"OnTrigger" "Limitbreaker_Tether_Spawner,ForceSpawnAtEntityOrigin,!activator,0,-1"
				"OnTrigger" "Limitbreaker_Tether_Sustain_Relay,Trigger,,0,-1"
				"OnTrigger" "@p@bosstarget,$TauntFromItem,Taunt: Burstchester,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldier_LimitBreak,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,items\powerup_pickup_supernova.wav,0,-1"
				"OnTrigger" "PlayerRunScriptCodeScreenShake(self.GetOrigin(), 5, 5, 2, 50000, 0, true)0-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Sustain Relay
			{
				"targetname" "Limitbreaker_Tether_Sustain_Relay"
				"OnTrigger" "Limitbreaker_Tether,StrikeOnce,,0,-1"
				"OnTrigger" "Limitbreaker_Tether_Sustain_Relay,Trigger,,0.15,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Beam Break Relay
			{
				"targetname" "Limitbreaker_Tether_Break"
				"OnTrigger" "tf_gamerules,PlayVO,misc\halloween\spell_spawn_boss_disappear.wav,0,-1"

				"spawnflags" "2"
			}

			env_entity_maker // Limitbreaker Tether Spawner
			{
				"targetname" "Limitbreaker_Tether_Spawner"
				"entitytemplate" "Limitbreaker_Tether"
				"$autoparent" "1"
				"$Parambone" "bip_spine_2"
			}
			env_beam // Limitbreaker Tether Beam
            {
                "targetname" "Limitbreaker_Tether"
                "BoltWidth" "10"
                "LightningStart" "LimitBreaker_Tether_Start"
                "LightningEnd" "LimitBreaker_Tether_End"
                "origin" "0 0 0"
                "renderamt" "200"
                "rendercolor" "200 200 255"
                "damage" "0"
                "NoiseAmplitude" "1"
                "dissolvetype" "1"
                "texture" "sprites/laserbeam.spr"
                "TouchType" "1"
				"life" "0.16"
				"spawnflags" "96"
            }
			prop_dynamic // Limitbreaker Tether Beam Start Point
            {
                "targetname" "Limitbreaker_Tether_Start"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }
		}

		Limitbreaker_Tether // Limitbreaker Tether
		{
			RemoveIfKilled "Limitbreaker_TetherBuilding"

			OnSpawnOutput
			{
				Target Limitbreaker_TetherBuilding
				Action SetBuilder
				Param !parent
				Delay 0.01
			}
			OnSpawnOutput
			{
				Target "Limitbreaker_TetherBuilding"
				Action "SetHealth"
				Param 864
                Delay 0.1
			}
			obj_dispenser
			{
				"targetname" "Limitbreaker_TetherBuilding"
				"angles" "0 0 0"
				"origin" "0 0 0"
				"teamnum" "3"
				"defaultupgrade" "2"
				"solid" "0"
				"$radiusmult" "0.01"
                "$cannotbesapped" "1"
                "$dispensermodelprefix" "models/buildables/amplifier_test/amplifier.mdl"
			}
		}

		LimitBreaker_Tether_Patient
		{
			prop_dynamic // Limitbreaker Tether Beam End Point
            {
                "targetname" "Limitbreaker_Tether_End"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }
		}
	}

	//// SPAWNED POINT TEMPLATES ////

	SpawnTemplate "Core_PTs"

	//// EXTRA SPAWNPOINTS ////

	ExtraSpawnPoint
	{
		Name "spawnbot_boss_1"
		TeamNum 3
		X 4986 
		Y 3789
		Z 685
	}
	ExtraSpawnPoint
	{
		Name "spawnbot_boss_2"
		TeamNum 3
		X 4665
		Y 3738
		Z 681
	}

	//// ROBOT TEMPLATES ////

	Templates
	{
		// Boss concept:
		// Tether ability using chestburster to attach to specifically Giant Bots with an env_beam
		// Tether empowers the target with a buff (resistances, mini-crits, firing speed, etc.)
		// Tether buff increases the longer it is maintained
		// Object spawned on the boss that powers the tether
		// When the object is destroyed, both the boss and the pocket are stunned, and the tether is broken
		T_TFBot_Boss_Medic_Limitbreaker_Part1
		{
			Name "The Limitbreaker"
			Class Medic
			ClassIcon medic_hyper
			Skill Expert
			Health 15000
			Scale 2
			Attributes MiniBoss
			Attributes UseBossHealthBar
			WeaponRestrictions SecondaryOnly
			Action FetchFlag

			UseCustomModel "models/mvm/bots/bot_medic.mdl"
			UseHumanAnimations 1

			SpawnTemplate "LimitBreaker_CoreLogic"

			Item "The Quick-Fix"

			Item "Ghostly Gibus"
			Item "The Surgeon's Space Suit"
			Item "Emerald Jarate"
			Item "The Quadwrangler"
			Item "The Lo-Grav Loafers"

			Item "Taunt: Burstchester"

			CharacterAttributes
			{
				"move speed penalty" 0.4
				"damage force reduction" 0.1
				"airblast vulnerability multiplier" 0.1
				"override footstep sound set" 4
				"mod weapon blocks healing" 1
				"always allow taunt" 1
			}

			FireInput
			{
				Target !self
				Action $ChangeAttributes
				Param Limitbreaker_Intro
				Delay 0.1
				Repeats 1
				Cooldown -1
			}

			EventChangeAttributes
			{
				Limitbreaker_Intro [$SIGSEGV]
				{
					CharacterAttributes
					{
						"move speed penalty" 0.5
						"damage force reduction" 0.6
						"airblast vulnerability multiplier" 0.6
						"override footstep sound set" 4
						"mod weapon blocks healing" 1
					}

					Addcond
					{
						Index 51
						Duration 10
					}

					FireInput
					{
						Target LimitbreakerIntroRelay
						Action Trigger
						Delay 0
						Repeats 1
						Cooldown -1
					}
				}
				Limitbreaker_Default [$SIGSEGV]
				{
					CharacterAttributes
					{
						"move speed penalty" 0.5
						"damage force reduction" 0.6
						"airblast vulnerability multiplier" 0.6
						"override footstep sound set" 4
						"mod weapon blocks healing" 1
					}
				}
				Limitbreaker_Tether_Ability [$SIGSEGV]
				{
					FireInput
					{
						Target Limitbreaker_Tether_Attach_Relay
						Action Trigger
						Delay 0
						Repeats 1
						Cooldown -1
					}
				}
			}
		}
		T_TFBot_Giant_Soldier_Limitbreaker
		{
			Name "Giant Soldier"
			Class Soldier
			ClassIcon soldier_giant
			Skill Expert
			Health 3800
			Attributes MiniBoss
			Attributes HoldFireUntilFullReload
			WeaponRestrictions PrimaryOnly

			SpawnTemplate "LimitBreaker_Tether_Patient"

			CharacterAttributes
			{
				"move speed penalty" 0.5
				"damage force reduction" 0.4
				"airblast vulnerability multiplier" 0.4
				"override footstep sound set" 3
			}

			EventChangeAttributes
			{
				GSoldier_Default [$SIGSEGV]
				{
					CharacterAttributes
					{
						"move speed penalty" 0.5
						"damage force reduction" 0.4
						"airblast vulnerability multiplier" 0.4
						"override footstep sound set" 3
					}
				}
				GSoldier_LimitBreak [$SIGSEGV]
				{
					CharacterAttributes
					{
						"move speed penalty" 0.5
						"damage force reduction" 0.4
						"airblast vulnerability multiplier" 0.4
						"override footstep sound set" 3
					}

					FireInput
					{
						Target !activator
