		// Subwave 1
		WaveSpawn // 2 GLaser Heavy and 8 Conch Soldiers
		{
			Name "Wave2_Subwave1_GLaserHeavy"
			Where spawnbot
			TotalCount 10
			MaxActive 8
			SpawnCount 5
			WaitBeforeStarting 0
			WaitBetweenSpawns 16
			TotalCurrency 200

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Name "Homelander from Temu"
					Template T_TFBot_Giant_Heavy_Laser
				}
				TFBot
				{
					Template T_TFBot_Soldier_Extended_Concheror
