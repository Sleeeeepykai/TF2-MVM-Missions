			Name "Wave4_Subwave2_Reforger"
			WaitForAllSpawned "Wave4_Subwave1_GDemo2"
			Where spawnbot
			TotalCount 2
			MaxActive 2
			SpawnCount 2
			WaitBeforeStarting 25
			WaitBetweenSpawns 0
			TotalCurrency 100

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Template T_TFBot_Giant_Demo_Burst
				}
				TFBot
				{
					Template T_TFBot_Giant_Engineer_Reforger
				}
			}
		}
	}
	// Wave 5 Notes
	Wave
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `Mars Odyssey (EXP) `)

					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_right_relay`, `Trigger`, null, 6.1)

					local bomb = Entities.FindByName(null, `bomb`)
					bomb.AcceptInput(`RunScriptFile`, `bombhop.nut`, null, null)
					if (!(`SetParams` in bomb.GetScriptScope())) return
					bomb.GetScriptScope().SetParams(
						[`spawndistance_multiplier_max`, 0.25],
						[`hoptime_max`, 20],
						[`considerburiedareas`, `true`],
						[`hopheight`, 150.0],
						[`hoprange`, 625.0]
					)
				  "
		}
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
					EntFire(`HeadTechnicianIntroRelay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }
		
		// Subwave 1
		WaveSpawn // Head Technician Boss
		{
			Name "Wave3_Subwave1_HeadTechnicianBoss"
			Where spawnbot
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 4
			WaitBetweenSpawns 0
			TotalCurrency 100

			FirstSpawnWarningSound "mvm/mvm_tele_deliver.wav"

			TFBot
			{
				Template T_TFBot_Boss_Engineer_HeadTechnician_Part1
			}
		}
	}
}