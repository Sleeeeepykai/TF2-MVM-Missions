#base robot_standard.pop 
#base robot_giant.pop
#base robot_moonlight_nai.pop

//Collab Mission by SleepyKai & Nai

WaveSchedule
{
	StartingCurrency 400
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	MaxRedPlayers 6
	AllowBotExtraSlots 1
	RobotLimit 28

	//// PRECACHES ////

	// Precached Models
	PrecacheModel "models/mvm/bots/bot_medic.mdl"
	PrecacheModel "models/props_mvm/indicator/indicator_circle.mdl"
	PrecacheModel "models/buildables/amplifier_test/amplifier.mdl"
    PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib1.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib2.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib3.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib4.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib5.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib6.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib7.mdl"
	PrecacheModel "models/buildables/amplifier_test/gibs/amp_gib8.mdl"
	

	//// CUSTOM WEAPONS ////

	CustomWeapon
	{
		//// Head Technician Part 1 Custom Weapons ////

		Engie_Clawbomb
		{
			OriginalItemName "TF_WEAPON_PIPEBOMBLAUNCHER"
			"custom item model" "models/empty.mdl"
			"stickybomb stick to enemies" 1
			"custom projectile model" "models/weapons/w_models/w_repair_claw.mdl"
			"spread angle pattern" "0 0 0|0 45 0|0 90 0|0 135 0|0 180 0|0 225 0|0 270 0|0 315 0"
			"projectile speed increased" 0.17
			"projectile spread angle penalty" 5
			"damage bonus" 1.5
			"no self blast dmg" 1
			"self dmg push force decreased" 0
			"mod projectile heat no predict target speed" 1  
			"projectile trail particle" "eyeboss_projectile"
            "mod projectile heat seek power" 360
            "mod projectile heat aim error" 300
            "mod projectile heat aim time" 1
			"mod projectile heat aim start time" 0.1
			"penetrate teammates" 1
			"max pipebombs increased" 24
			"ignores other projectiles" 1
			
		}
		Engie_DazeLightning
		{
			OriginalItemName "tf_weapon_rocketlauncher"
			"damage bonus" "0"
			"stun on hit" 1.5
            "penetrate teammates" "1"
            "projectile spread angle penalty" "90"
            "projectile speed increased" "0.75"
            "projectile gravity" "1500"
            "no explosion particles" "1"
			//"projectile trail particle" "~"
			"custom projectile model" "models/empty.mdl"
		}
	}

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PTs
		{
			point_populator_interface
			{
				"targetname" "pop_interface"
			}
			point_clientcommand
			{
				"targetname" "client_command"
			}
		}

		Global_PTs
		{
			logic_case
			{
				"targetname" "Soldier_LimitBreakVoiceline"

				"OnCase01" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts02.mp3,0,-1"
				"OnCase01" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts02.mp3,0,-1"
				"OnCase02" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts03.mp3,0,-1"
				"OnCase02" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts03.mp3,0,-1"
				"OnCase03" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts05.mp3,0,-1"
				"OnCase03" "tf_gamerules,PlayVO,vo/mvm/mght/taunts/soldier_mvm_m_taunts05.mp3,0,-1"
			}

			info_target
			{
				"targetname" "spawnbot_boss1"
				"origin" "5000 3575 730"
				"angles" "0 90 0"
			}
			info_target
			{
				"targetname" "spawnbot_boss2"
				"origin" "4715 3575 730"
				"angles" "0 90 0"
			}
			info_target
			{
				"targetname" "spawnbot_boss3"
				"origin" "4848 3584 730"
				"angles" "0 90 0"
			}

			info_particle_system
			{
				"targetname" "HeadTechnicianPortal1"
				"effect_name" "eyeboss_death_vortex" 
				"origin" "4848 3584 730"
				"flag_as_weather" "0"
				"start_active" "0"
			}
			info_particle_system
			{
				"targetname" "HeadTechnicianPortal2"
				"effect_name" "dxhr_lightningball_parent_blue" 
				"origin" "4848 3584 730"
				"flag_as_weather" "0"
				"start_active" "0"
			}

			logic_relay
			{
				"targetname" "HeadTechnicianIntroRelay"
				"OnTrigger" "HeadTechnicianPortal1,Start,,1,-1"
				"OnTrigger" "HeadTechnicianPortal2,Start,,1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\halloween\windgust_10.wav,1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\halloween\windgust_10.wav,1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\nucleus_electricity.wav,1.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\nucleus_electricity.wav,1.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\halloween\thunder_04.wav,4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,ambient\halloween\thunder_04.wav,4,-1"
				"OnTrigger" "tf_gamerules,$StopVO,ambient\nucleus_electricity.wav,4,-1"
				"OnTrigger" "tf_gamerules,$StopVO,ambient\nucleus_electricity.wav,4,-1"
				"OnTrigger" "tf_gamerules,$StopVO,ambient\halloween\windgust_10.wav,4,-1"
				"OnTrigger" "tf_gamerules,$StopVO,ambient\halloween\windgust_10.wav,4,-1"
				"OnTrigger" "HeadTechnicianPortal1,Stop,,4,-1"
				"OnTrigger" "HeadTechnicianPortal2,Stop,,4,-1"
				"OnTrigger" "@p@HeadTechnicianPart1Target,$AddCond,51,4.1"
				"OnTrigger" "@p@HeadTechnicianPart1Target,$TauntFromItem,Taunt: Flying Colors,5.1,-1"
				"OnTrigger" "@p@HeadTechnicianPart1Target,$RemoveCond,51,11.5"
				"OnTrigger" "@p@HeadTechnicianPart1Target,$RemoveCond,7,11.5"
			}
		}

		//// Limitbreaker Part 1 PTs ////

		LimitbreakerPart1CoreLogic
		{
			OnSpawnOutput
            {
                Target LimitbreakerPart1Target
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			info_target
            {
                "TargetName" "LimitbreakerPart1Target"
                "origin" "0 0 0"
            }

			trigger_multiple
			{
				"targetname" "LimitbreakerDetector"
				"origin" "0 0 100"
				"mins" "-384 -384 -256"
				"maxs" "384 384 256"

				"wait" "0.5"
				"filtername" "LimitbreakerGiantFilter"
				"spawnflags" "1"
				"startdisabled" "1"

				"OnStartTouch" "!parent,$ChangeAttributes,LimitbreakerTetherAbility,0,-1"
			}
			filter_tf_bot_has_tag
			{
				"targetname" "LimitbreakerGiantFilter"
				"tags" "LimitbreakerGiant"
				"require_all_tags" "1"
			}

			// Limitbreaker Main Relays

			logic_relay // Limitbreaker Intro Relay
			{
				"targetname" "LimitbreakerIntroRelay"

				"OnTrigger" "@p@LimitbreakerPart1Target,$Taunt,,0,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$Taunt,,0.1,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$Taunt,,0.2,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_laughhappy01.mp3,0,-1"
				"OnTrigger" "@p@patienttarget,$TeleportToEntity,spawnbot_boss2,3.1,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierLimitBreakIntro,3.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted02.mp3,4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted02.mp3,4,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,4,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,4.1,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,4.2,-1"
				"OnTrigger" "LimitbreakerTetherSpawner,ForceSpawnAtEntityOrigin,!activator,7.33,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,7.33,-1"
				"OnTrigger" "@p@patienttarget,$Taunt,,7.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,7.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,items\powerup_pickup_supernova.wav,7.33,-1"
				"OnTrigger" "PlayerRunScriptCodeScreenShake(self.GetOrigin(), 5, 5, 2, 50000, 0, true)7.33-1"
				"OnTrigger" "LimitbreakerTetherBuilding,SetBuilder,,7.4,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted04.mp3,10,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/norm/medic_mvm_specialcompleted04.mp3,10,-1"
				"OnTrigger" "TetherIntroNote1,Show,,10,-1"
				"OnTrigger" "Soldier_LimitBreakVoiceline,PickRandom,,11.33,-1"
				"OnTrigger" "TetherIntroNote2,Show,,15,-1"
				"OnTrigger" "!activator,$ChangeAttributes,LimitbreakerDefaultTether,20,-1"
			}

			// Limitbreaker Tether Ability
			logic_relay // Limitbreaker Tether Beam Attach Relay
			{
				"targetname" "LimitbreakerTetherAttachRelay"
				"OnTrigger" "LimitbreakerDetector,Disable,,0,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,0,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,0.1,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: Doctor's Defibrillators,0.2,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierLimitBreak,3.33,-1"
				"OnTrigger" "LimitbreakerTetherSpawner,ForceSpawnAtEntityOrigin,!activator,3.33,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,3.33,-1"
				"OnTrigger" "@p@patienttarget,$Taunt,,3.33,-1"
				"OnTrigger" "@p@patienttarget,$Taunt,,3.34,-1"
				"OnTrigger" "@p@patienttarget,$AddCond,51 3,3.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,3.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,items\powerup_pickup_supernova.wav,3.33,-1"
				"OnTrigger" "PlayerRunScriptCodeScreenShake(self.GetOrigin(), 5, 5, 2, 50000, 0, true)3.33-1"
				"OnTrigger" "LimitbreakerTetherBuilding,SetBuilder,,3.4,-1"
				"OnTrigger" "Soldier_LimitBreakVoiceline,PickRandom,,7.33,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Sustain Relay
			{
				"targetname" "LimitbreakerTetherSustainRelay"
				"OnTrigger" "LimitbreakerTether,StrikeOnce,,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Trigger,,0.15,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Beam Break Relay
			{
				"targetname" "LimitbreakerTetherBreakRelay"
				"OnTrigger" "tf_gamerules,PlayVO,player/invulnerable_off.wav,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc\halloween\spell_spawn_boss_disappear.wav,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Disable,,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,LimitbreakerStun,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierStun,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Enable,,10,-1"
				"OnTrigger" "LimitbreakerDetector,Enable,,10,-1"

				"spawnflags" "2"
			}
			logic_relay // Limitbreaker Tether Patient Break Relay
			{
				"targetname" "LimitbreakerTetherPatientBreakRelay"
				"OnTrigger" "tf_gamerules,PlayVO,player/invulnerable_off.wav,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc\halloween\spell_spawn_boss_disappear.wav,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Disable,,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,LimitbreakerDefault,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Enable,,10,-1"
				"OnTrigger" "LimitbreakerDetector,Enable,,10,-1"

				"spawnflags" "2"
			}

			env_entity_maker // Limitbreaker Tether Spawner
			{
				"targetname" "LimitbreakerTetherSpawner"
				"entitytemplate" "LimitbreakerTether"
				"$autoparent" "1"
			}
			env_beam // Limitbreaker Tether Beam
            {
                "targetname" "LimitbreakerTether"
                "BoltWidth" "8"
                "LightningStart" "LimitBreakerTetherStart"
                "LightningEnd" "LimitBreakerTetherEnd"
                "origin" "0 0 0"
                "renderamt" "200"
                "rendercolor" "200 200 255"
                "damage" "0"
                "NoiseAmplitude" "1"
                "dissolvetype" "1"
                "texture" "sprites/laserbeam.spr"
                "TouchType" "1"
				"life" "0.16"
				"spawnflags" "96"
            }
			prop_dynamic // Limitbreaker Tether Beam Start Point
            {
                "targetname" "LimitbreakerTetherStart"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }

			// Limitbreaker Leave

			logic_relay // Limitbreaker Leave Relay
			{
				"targetname" "LimitbreakerLeaveRelay"
				"OnTrigger" "LimitbreakerDetector,Disable,,0,-1"
				"OnTrigger" "LimitbreakerTetherSustainRelay,Disable,,0,-1"
				"OnTrigger" "LimitbreakerTetherAttachRelay,CancelPending,,0,-1"
				"OnTrigger" "pop_interface,ChangeBotAttributes,GSoldierStun,0,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TauntFromItem,Taunt: The Critical Fail,0,-1"
				"OnTrigger" "pop_interface,$KillWaveSpawn,Wave3_Subwave1_SupportCrew,0,-1"
				"OnTrigger" "pop_interface,$FinishWaveSpawn,Wave3_Subwave1_SupportCrew,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\norm\medic_mvm_jeers04.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\norm\medic_mvm_jeers04.mp3,0,-1"
				"OnTrigger" "pop_interface,$PauseWaveSpawn,Wave3_Subwave1_SupportCrew,0.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\norm\medic_mvm_jeers11.mp3,2.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\norm\medic_mvm_jeers11.mp3,2.5,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$TeleportToEntity,spawnbot,4.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_tele_deliver.wav,4.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,mvm/mvm_tele_deliver.wav,4.5,-1"
				"OnTrigger" "@p@LimitbreakerPart1Target,$BotCommand,despawn,5,-1"
			}
		}

		LimitbreakerTether
		{
			OnSpawnOutput
			{
				Target LimitBreakerTetherBuilding
				Action $SetOwner
				Param !parent
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "LimitbreakerTetherBuilding"
				Action "SetHealth"
				Param 1000
                Delay 0.1
			}
			obj_dispenser
			{
				"targetname" "LimitbreakerTetherBuilding"
				"angles" "-70 0 0"
				"origin" "-25 0 90"
				"teamnum" "3"
				"defaultupgrade" "2"
				"solid" "0"
				"$radiusmult" "0.01"
                "$cannotbesapped" "1"
                "$dispensermodelprefix" "models/buildables/amplifier_test/amplifier.mdl"

				"OnDestroyed" "LimitbreakerTetherBreakRelay,Trigger,,0,-1"
			}
		}

		LimitBreakerTetherPatient
		{
			OnSpawnOutput
            {
                Target patienttarget
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			info_target
            {
                "TargetName" "patienttarget"
                "origin" "0 0 0"
            }

			OnParentKilledOutput
			{
				Target LimitBreakerPatientBreakRelay
				Action Trigger
				Delay -1
			}

			prop_dynamic // Limitbreaker Tether Beam End Point
            {
                "targetname" "LimitbreakerTetherEnd"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 100"                
            }

			training_annotation
			{
				"targetname" "TetherIntroNote1"
				"origin" "0 0 200"
				"display_text" "This giant has been Reforged!"
				"lifetime" "5"
			}
			training_annotation
			{
				"targetname" "TetherIntroNote2"
				"origin" "0 0 200"
				"display_text" "He will become stronger over time, but you can break the tether powering his strength!"
				"lifetime" "5"
			}
		}
		
		//// Head Technician Part 1 PTs ////

		TechnicianPart1_Attacks
		{
			OnSpawnOutput
            {
                Target HeadTechnicianPart1Target
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			OnSpawnOutput
            {
                Target "ClawBomb"
                Action "$SetOwner"
                Param  "!activator"
                Delay  0
            }

			info_target
			{
				"targetname" "HeadTechnicianPart1Target"
			}

			// Attack Pool

			logic_case
			{
				"targetname" "attackphasesAll"
				"OnCase01" "!activator,$ChangeAttributes,RapidPomson,0,-1"
				"OnCase02" "!activator,$ChangeAttributes,BurstRanger,0,-1" 
				"OnCase03" "!activator,$ChangeAttributes,Panicmode,0,-1" 
				"OnCase04" "!activator,$ChangeAttributes,BallsofDoomAndDespair,0,-1"
				"OnCase05" "!activator,$ChangeAttributes,OoohWhatsThis,0,-1" 
				"OnCase06" "!activator,$ChangeAttributes,ThunderStorm,0,-1" 
			}

			// Claw Bomb Attack

			logic_relay
			{
				"targetname" "HomingClaws"
				"OnTrigger" "!activator,$TauntFromItem,Taunt: Texan Trickshot,0,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,vo/mvm/norm/engineer_mvm_littlesentry01.mp3,0,-1"
				"OnTrigger" "ClawBomb,firemultiple,5,0.1,-1"
				"OnTrigger" "ClawBomb,firemultiple,5,1.2,-1"
				"OnTrigger" "ClawBomb,firemultiple,5,2.1,-1"
				"OnTrigger" "ClawBomb,DetonateStickies,,3.3,-1"
				"OnTrigger" "ClawBomb,disable,,3.5,-1"
			}
			
			tf_point_weapon_mimic
			{
				"targetname" "ClawBomb"
				"origin"          "-15 0 150"
                "angles"           "0 0 0"
				"weapontype"		"0"
                "teamnum"          "3"
				"damage"			"0"
                "$weaponname"    "Engie_Clawbomb"
                "$firetime"      "1.0" 
                "$weaponnosound" "1"
			}
			tf_point_weapon_mimic
			{
				"targetname" 	  "ClawBomb"
				"origin"          "-15 0 150"
                "angles"           "0 0 0"
				"weapontype"		"0"
                "teamnum"          "3"
				"damage"			"0"
                "$weaponname"    "Engie_Clawbomb"
                "$firetime"      "1.0" 
                "$weaponnosound" "1"
			}

			// Thunder Storm Attack
			
			logic_relay
			{
				"targetname" "SmiteThee"
				"OnTrigger" "!activator,$PlaySequence,taunt_drg_melee,0,-1" //taunt_drg_melee
				"OnTrigger"	"tf_gamerules,PlayVO,vo/mvm/norm/engineer_mvm_laughlong01.mp3,0,-1"
				"OnTrigger" "Engi_Lightning,firemultiple,3,1.3,-1"
				"OnTrigger" "Engi_Lightning,firemultiple,3,2.3,-1"
				"OnTrigger" "Engi_Lightning,firemultiple,3,3.3,-1"
				"OnTrigger" "Engi_Lightning,firemultiple,3,4.3,-1"
				"OnTrigger" "Engi_Lightning,disable,,4.6,-1"
			}
			tf_point_weapon_mimic
            {
                "targetname" "Engi_Lightning"
                "origin" "-15 0 150"
                "angles" "270 0 0"
                "speedmin" "10"
                "speedmax" "10"
                "teamnum" "3"
                "damage" "0"
                "$weaponname" "Engie_DazeLightning"
                "$firetime" "0.33"
                "$weaponnosound" "1"
                "$preventshootparent" "1"
                "$OnFire" "LightningRainTargetSpawner,ForceSpawnAtEntityOrigin,!activator,0,-1"
            }
			env_entity_maker
            {
                "targetname" "LightningRainTargetSpawner"
                "entitytemplate" "LightningRainTarget"
                "$autoparent" "1"
            }
		}

		LightningRainTarget
        {
            RemoveIfKilled "LightningTarget"
            KeepAlive 1

            info_target
            {
                "targetname" "LightningTarget"
            }
            OnParentKilledOutput
            {
                Target "LightningRainAttack"
                Action "ForceSpawnAtEntityOrigin"
                Param "LightningTarget"
                Delay 0.1
                Repeats 1
                Cooldown -1
            }
            OnParentKilledOutput
            {
                Target "LightningTarget"
                Action Kill
                Delay 0.5
                Repeats 1
                Cooldown -1
            }
        }

		LightningRainAttack
		{
			KeepAlive 1
			RemoveIfKilled "LightningAttackPoint"

			OnSpawnOutput
			{
				Target "LightningAttackPoint"
				Action "$setkey$angles"
                Param "180 0 0"
                Delay 0.1
			}
			prop_dynamic
            {
                "targetname" "LightningAttackPoint"
                "origin" "0 0 12"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "3"
                "skin" "1"
