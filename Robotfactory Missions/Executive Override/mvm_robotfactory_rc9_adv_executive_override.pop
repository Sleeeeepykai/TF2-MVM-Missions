		Wave3_PlayerBombCarrierLogic1
		{
			KeepAlive 1
			
			RemoveIfKilled "Wave3_ExtraBombTeamFlag"

			OnSpawnOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action SetParent
				Param !activator
				Delay 0.02
			}
			OnSpawnOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action SetParentAttachment
				Param "flag"
				Delay 0.05
			}

			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action ClearParent
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action $TeleportToEntity
				Param !activator
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action $SetLocalAngles
				Param "0 0 0"
				Delay 0.05
			}
			
			item_teamflag // Dropped Extra Bomb
			{
				"targetname" "Wave3_ExtraBombTeamFlag"
				"origin" "0 0 0"
				"flag_model" "models\props_td\atom_bomb_blue2.mdl"
				"modelscale" "1"
				"TeamNum" "2"
				"startdisabled" "1"

				"OnPickup1" "!activator,$PlaySoundToSelf,items/gunpickup2.wav,0,-1"
				"OnPickup1" "Wave3_ExtraBombArrow,HideSprite,,0,-1"
				"OnPickup1" "Wave3_FirstBombPlantHint,Enable,,0,-1"
				"OnPickup1" "Wave3_FirstBombPlantAnnotation,Show,,0,-1"
				"OnPickup1" "tf_gamerules,PlayVO,mvm/executive_override/butler_wave3_secondbombpickedup.mp3,0,-1"
				"OnPickup1" "tf_gamerules,PlayVO,mvm/executive_override/butler_wave3_secondbombpickedup.mp3,0,-1"
				"OnPickup1" "Wave3_SecondBombPickedUpSubtitlesRelay,Trigger,,0,-1"
				"OnReturn" "Wave3_FirstBombPlantExplosionRelay,Trigger,,0,-1"
				"OnReturn" "!self,Kill,,0.2,-1"
			}
			tf_glow // Extra Bomb Glow
			{
				"targetname" "Wave3_ExtraBombGlow"
				"target" "Wave3_ExtraBombTeamFlag"
				"GlowColor" "0 176 199 255"
				"startdisabled" "1"
			}
			env_sprite // Extra Bomb Arrow Sprite
			{
				"targetname" "Wave3_ExtraBombArrow"
				"origin" "0 0 100"
				"model" "materials/hud/arrow_big_down.vmt"
				"scale" "0.2"
			}

			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action Enable
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action SetTeam
				Param 3
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombGlow"
				Action Enable
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombArrow"
				Action ShowSprite
			}
		}
