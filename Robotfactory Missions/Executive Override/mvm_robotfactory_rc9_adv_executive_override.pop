	DisableSound "Announcer.MVM_Tank_Alert_Halfway"
	DisableSound "Announcer.MVM_Tank_Alert_Halfway_Multiple"
	DisableSound "Announcer.MVM_Tank_Alert_Near_Hatch"
	DisableSound "Announcer.MVM_Tank_Alert_Deploying"
	DisableSound "Announcer.MVM_Tank_Planted" 
	DisableSound "Announcer.MVM_General_Destruction"

	DisableSound "Announcer.RoundBegins5Seconds"
	DisableSound "Announcer.RoundBegins4Seconds"
	DisableSound "Announcer.RoundBegins3Seconds"
	DisableSound "Announcer.RoundBegins2Seconds"
	DisableSound "Announcer.RoundBegins1Seconds"

	//// CUSTOM WEAPONS ////

	CustomWeapon
	{
		"Batsaber_Range_Weapon"
		{
			OriginalItemName "The Rescue Ranger"
			"damage penalty" 0.875
			"no damage falloff" 1
			"add damage type" 128
			"remove damage type" 2
			"custom projectile size" 24

			"fire rate bonus" 0.8
			"faster reload rate" 0.8
			"clip size bonus" 1.5

			"penetrate teammates" 1
			"projectile speed decreased" 0.4
			"projectile gravity" -1
			"arrow hit kill time" 0.1

			"custom item model" "models/workshop/weapons/c_models/c_invasion_bat/c_invasion_bat.mdl"
			"custom projectile model" "models/weapons/w_models/w_drg_ball.mdl"
			"custom weapon fire sound" "common/null.wav"
			"custom kill icon" "batsaber"
		}
	}

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PTs
		{
			OnSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
						::DispatchParticleEffectOn <- function(hEntity, sName)
						{
							if(!sName) { hEntity.AcceptInput(`DispatchEffect`, `ParticleEffectStop`, null, null); return }
							local hParticle = Entities.CreateByClassname(`trigger_particle`)
							NetProps.SetPropBool(hParticle, `m_bForcePurgeFixedupStrings`, true)
							hParticle.KeyValueFromString(`particle_name`, sName)
							hParticle.KeyValueFromInt(`attachment_type`, 1)
							hParticle.KeyValueFromInt(`spawnflags`, 64)
							hParticle.DispatchSpawn()
							hParticle.AcceptInput(`StartTouch`, null, hEntity, hEntity)
							hParticle.Kill()
						}
					  "
            }
			OnSpawnOutput
			{
				Target tube_bot_model
				Action Disable
			}
			OnSpawnOutput
			{
				Target robot_arm
				Action SetAnimation
				Param Idle
			}

			point_populator_interface
			{
				"targetname" "pop_interface"
			}

			logic_relay
			{
				"targetname" "SentryBusterVoiceRelay"

				"OnTrigger" "SentryBusterVoiceCase,PickRandom,,0,-1"
				"OnTrigger" "SentryBusterVoiceRelay,Disable,,0,-1"
				"OnTrigger" "SentryBusterVoiceRelay,Enable,,2,-1"
			}
			logic_case
			{
				"targetname" "SentryBusterVoiceCase"

				"OnCase01" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound.mp3"
				"OnCase01" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound.mp3"
				"OnCase02" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound2.mp3"
				"OnCase02" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound2.mp3"
				"OnCase03" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound3.mp3"
				"OnCase03" "tf_gamerules,PlayVO,mvm/executive_override/butler_sentrybusterinbound3.mp3"
			}

			logic_relay // Subtitle Toggle Menu Relay
			{
				"targetname" "SubtitlesMenuRelay"

				"OnTrigger" "SubtitlesMenu,$DisplayMenu,!activator,0,-1"
			}
			logic_case // Subtitle Toggle Menu
			{
				"targetname" "SubtitlesMenu"

				"case16" "Enable or Disable Subtitles|30|Cancel"

				"case01" "Enable Subtitles"
				"case02" "Disable Subtitles"

				"OnCase01" "Wave2,Enable,,0,-1"
				"OnCase02" "Wave2,Disable,,0,-1"
			}

