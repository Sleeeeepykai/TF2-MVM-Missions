#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 800
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	WaveStartCountdown 7

	//// PRECACHES ////

	// Precached Models

	PrecacheModel "models/mvm/barrier/barrier_spawn_blue1.mdl"
	PrecacheModel "models\props_td\atom_bomb_blue2.mdl"

	// Precached Narrative Voicelines
	PrecacheSound "mvm/executive_override/butler_wave1setup.mp3"
	PrecacheSound "mvm/executive_override/butler_wave2setup.mp3"
	PrecacheSound "mvm/executive_override/butler_wave3setup.mp3"
	PrecacheSound "mvm/executive_override/butler_wave4setup.mp3"

	PrecacheSound "mvm/executive_override/butler_wave3_secondbomb.mp3"
	PrecacheSound "mvm/executive_override/butler_wave3_secondbombpickedup.mp3"
	PrecacheSound "mvm/executive_override/butler_wave3_thirdbomb.mp3"
	PrecacheSound "mvm/executive_override/butler_wave3_thirdbombpickedup.mp3"
	PrecacheSound "mvm/executive_override/butler_wave3_manufactorybreached.mp3"

	PrecacheSound "mvm/executive_override/butler_wave4start.mp3"

	// Precached Mission Support Voicelines
	PrecacheSound "mvm/executive_override/butler_sentrybusterinbound.mp3"
	PrecacheSound "mvm/executive_override/butler_sentrybusterinbound2.mp3"
	PrecacheSound "mvm/executive_override/butler_sentrybusterinbound3.mp3"

	PrecacheSound "mvm/executive_override/butler_spiesinbound2.mp3"
	PrecacheSound "mvm/executive_override/butler_spiesinbound3.mp3"
	PrecacheSound "mvm/executive_override/butler_spiesdestroyed2.mp3"
	PrecacheSound "mvm/executive_override/butler_spiesdestroyed3.mp3"

	// Precached Tank Voicelines
	PrecacheSound "mvm/executive_override/butler_tankinbound2.mp3"

	PrecacheSound "mvm/executive_override/butler_tankdestroyed.mp3"

	// Precached Wave Announcer Voicelines
	PrecacheSound "mvm/executive_override/butler_firstwavebegin.mp3"
	PrecacheSound "mvm/executive_override/butler_genericwavebegin.mp3"
	PrecacheSound "mvm/executive_override/butler_genericwavebegin2.mp3"
	PrecacheSound "mvm/executive_override/butler_genericwavebegin3.mp3"

	PrecacheSound "mvm/executive_override/butler_wavecompleted.mp3"

	//// DISABLED VOICELINES ////

	DisableSound "Announcer.MVM_Wave_End"
    DisableSound "Announcer.MVM_Final_Wave_End"
	DisableSound "Announcer.MVM_Bonus"
	DisableSound "Announcer.MVM_Get_To_Upgrade"

	DisableSound "Announcer.MVM_Bomb_Alert_Near_Hatch"
	DisableSound "Announcer.MVM_Robots_Planted"
	DisableSound "Announcer.MVM_Wave_Lose"
	DisableSound "Announcer.MVM_Game_Over_Loss"
	DisableSound "Announcer.MVM_Bomb_Reset"

	DisableSound "Announcer.MVM_Sentry_Buster_Alert"
	DisableSound "Announcer.MVM_Sentry_Buster_Alert_Another"
	DisableSound "Announcer.MVM_Spy_Alert"
	DisableSound "Announcer.mvm_spybot_death"
	DisableSound "Announcer.mvm_spybot_death_all"
	DisableSound "Announcer.MVM_First_Engineer_Teleport_Spawned"
	DisableSound "Announcer.MVM_Another_Engineer_Teleport_Spawned"
