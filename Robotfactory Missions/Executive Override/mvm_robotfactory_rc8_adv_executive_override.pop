    //// CUSTOM WEAPONS ////

    CustomWeapon
    {
        "BatsaberThrow"
        {
            OriginalItemName "The Rescue Ranger"
            "projectile gravity" -1
            "projectile speed increased" 0.4
            "arrow hit kill time" 0.1

            "no damage falloff" 1
            "damage bonus" 1

            "fire rate bonus" 1
            "faster reload rate" 1

            "add damage type" 128
            "remove damage type" 2

            "custom item model" "models/workshop/weapons/c_models/c_invasion_bat/c_invasion_bat.mdl"
            "custom projectile model" "models/weapons/w_models/w_drg_ball.mdl"
            "custom weapon fire sound" "common/null.wav"
            "custom kill icon" "batsaber"
        }
        "ThrowingKnife"
        {
            OriginalItemName "The Flying Guillotine"
            "projectile gravity" -1
            "projectile speed decreased" 0.3
            "arrow hit kill time" 0.1

            "no damage falloff" 1
            "damage bonus" 1

            "override projectile type" 18
            "effect bar recharge rate increased" -1

            "add damage type" 128
            "remove damage type" 2

            "custom item model" "models/workshop/weapons/c_models/c_switchblade/c_switchblade.mdl"
            "custom projectile model" "models/weapons/w_models/w_drg_ball.mdl"
            "custom weapon fire sound" "common/null.wav"
            "custom kill icon" "big_earner"
        }
    }

