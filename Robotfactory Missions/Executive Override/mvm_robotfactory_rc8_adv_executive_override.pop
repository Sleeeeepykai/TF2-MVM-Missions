#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 1000
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No

    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

    //// PRECACHES ////

    //// PRECACHED MODELS ////

    PrecacheModel "models/mvm/barrier/barrier_spawn_blue1.mdl"

    //// PRECACHED SOUNDS ////

    PrecacheSound "freeze_cam/mvm_demoman_detonator_windup.wav"
    PrecacheSound "freeze_cam/spy_boss_teleport_in.wav"
    PrecacheSound "freeze_cam/spy_boss_teleport_out.wav"

    //// PRECACHED PARTICLES ////
    PrecacheParticle "utaunt_electricity_discharge"

    //// TANK PATHS ////
