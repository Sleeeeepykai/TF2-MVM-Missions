            {
                //// PHASE 1 ////
                Phase1MainRevolverAttack // His Favourite Gun (Basically Faster Stock)
                {
                    WeaponRestrictions PrimaryOnly
                    Item "TTG Sam Revolver"
                    Item "TF_WEAPON_KNIFE"

                    ItemAttributes
                    {
                        ItemName "TTG Sam Revolver"
                        "fire rate bonus" 0.75
