					{
						Target "-1536 1606 -191"
						Delay 0.1
						Repeats 0
						Cooldown 5
						Duration 5
						Distance 100
					}

                    FireInput
                    {
                        Target !self
                        Action $ChangeAttributes
                        Param Phase1BurstRevolverAttack
                        Delay 10
                        Repeats 1
                        Cooldown -1
                    }
                }
