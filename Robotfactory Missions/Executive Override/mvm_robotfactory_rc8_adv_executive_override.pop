        //// WAVE 1 ////

        Wave1LockdownSetup
        {
            logic_relay // Setup Relay
            {
                "targetname" "Wave1SetupRelay"
                "OnTrigger" "hatch_shortcut_A_fix_relay,Trigger,,0,-1"
                "OnTrigger" "hatch_shortcut_B_fix_relay,Trigger,,0,-1"

                "OnTrigger" "A_route_wall_1_fix_relay,Trigger,,0,-1"
                "OnTrigger" "A_route_wall_2_fix_relay,Trigger,,0,-1"
                "OnTrigger" "A_route_wall_3_fix_relay,Trigger,,0,-1"
                "OnTrigger" "A_route_wall_4_fix_relay,Trigger,,0,-1"

                "OnTrigger" "C1_wall_fix_relay,Trigger,,0.25,-1"
                "OnTrigger" "B1_wall_fix_relay,Trigger,,0.25,-1"

                "OnTrigger" "B1_door_lock_relay,Trigger,,0.5,-1"
                "OnTrigger" "A2_door_lock_relay,Trigger,,0.5,-1"
                "OnTrigger" "A1_door_lock_relay,Trigger,,0.5,-1"

                "OnTrigger" "C1_door,SetAnimation,open,0.5,-1"
                "OnTrigger" "C1_door,DisableCollision,,0.5,-1"

                "OnTrigger" "door_front_l,Close,,0.5,-1"
                "OnTrigger" "door_front_r,Close,,0.5.-1"
