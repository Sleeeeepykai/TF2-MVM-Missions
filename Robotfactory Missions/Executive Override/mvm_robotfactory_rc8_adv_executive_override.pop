    //// MISSION BOTS ////

    Mission // Sentry Buster (Wave 1-3)
    {
        Objective DestroySentries
        Where spawnbot_doora1_giant [$SIGSEGV]
        BeginAtWave 1
        RunForThisManyWaves 3
        DesiredCount 1

        InitialCooldown 30
        CooldownTime 30

        TFBot
        {
            Template T_TFBot_SentryBuster
        }   
    }
    Mission // Sniper (Wave 4)
    {
        Objective Sniper
        Where spawnbot_A_route_giant [$SIGSEGV]
        BeginAtWave 4
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 8
        CooldownTime 32

        TFBot
        {
            Class Sniper
        }
    }
    Mission // Sentry Buster (Wave 4-5)
    {
        Objective DestroySentries
        Where spawnbot_breach_giant [$SIGSEGV]
        BeginAtWave 4
        RunForThisManyWaves 2
        DesiredCount 1

        InitialCooldown 30
        CooldownTime 30

        TFBot
        {
            Template T_TFBot_SentryBuster
        } 
    }
    Mission // Sentry Buster (Wave 6-8)
    {
        Objective DestroySentries
        Where spawnbot_right_tank [$SIGSEGV]
        BeginAtWave 6
        RunForThisManyWaves 3
        DesiredCount 1

        InitialCooldown 30
        CooldownTime 30

        TFBot
        {
            Template T_TFBot_SentryBuster
        } 
    }
    Mission // Spy (Wave 6)
    {
        Objective Spy
        Where spawnbot_right
        BeginAtWave 6
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 8
        CooldownTime 32

        TFBot
        {
            Class Spy
        }
    }
    Mission // Sniper (Wave 7)
    {
        Objective Sniper
        Where spawnbot_left_tank
        BeginAtWave 7
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 16
        CooldownTime 32

        TFBot
        {
            Class Sniper
        }
    }
    Mission // Engineer (Wave 7-8)
    {
        Objective Engineer
        Where spawnbot_right
        BeginAtWave 7
        RunForThisManyWaves 1
        DesiredCount 1

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Engineer_Sentry_Teleporter
            Attributes TeleportToHint
            TeleportWhere spawnbot_right
            TeleportWhere spawnbot_left
            TeleportWhere spawnbot_left_tank
            TeleportWhere spawnbot_right_tank
        }
    }

    //// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `Executive Override (Adv)`)
                    EntFire(`Wave1LockdownSetup`, `ForceSpawn`)
                    EntFire(`Wave1SetupRelay`, `Trigger`)
                  "
        }
        StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`C1_door_unlock_relay`, `Trigger`)
                    EntFire(`B1_door_unlock_relay`, `Trigger`)
                    EntFire(`A2_door_unlock_relay`, `Trigger`)
                    EntFire(`A1_door_unlock_relay`, `Trigger`)
                    EntFire(`A1_door_barrier`, `Enable`)
                    EntFire(`B1_door_barrier`, `Enable`)
                  "
		}
	    DoneOutput					
		{
			Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                    EntFire(`C1_door_unlock_relay`, `Trigger`)
                  "
		}

