        {
            Name "Wave3_Subwave2_GBurst"
            WaitForAllSpawned "Wave3_Subwave1_BlackBoxConchSquad"
            Where spawnbot_doora1_giant [$SIGSEGV]
            TotalCount 3
            MaxActive 3
            SpawnCount 3
            WaitBeforeStarting 12
            WaitBetweenSpawns 0
            TotalCurrency 60

            FirstSpawnWarningSound "vo/mvm_another_bomb06.mp3"

            FirstSpawnOutput
            {
                Target W3BombIncoming
                Action Show
            }

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Soldier_Spammer_Reload
                    Action Mobber
                    Tag bot_giant

                    AlwaysGlow 1

                    SpawnTemplate
                    {
                        Name Wave3BombProp
                        Bone bip_spine_2
                    }
                    SpawnTemplate
                    {
                        Name Wave3BombLogic1
                    }

                    InterruptAction
                    {
                        Target "1279 -2817 0"
                        Delay 0.1
                        Duration 2
                        Repeats 1
                        Cooldown 0
                        WaitUntilDone 1
                        OnDoneChangeAttributes "DeployBomb"
                    }
                    
                    EventChangeAttributes
                    {
                        DeployBomb
                        {
                            ActionOverride Idle
                            
                            CharacterAttributes
                            {
                                "move speed bonus" 0.001
                                "no_jump" 1
                            }

                            FireInput
							{
								Target !self
								Action $PlaySequence
								Param "melee_deploybomb"
								Delay 0
								Repeats 1
								Cooldown -1
							}
							FireInput
							{
								Target tf_gamerules
								Action PlayVO
								Param "mvm/mvm_deploy_giant.wav"
								Delay 0
								Repeats 1
								Cooldown -1
							}
                            FireInput
                            {
                                Target bomb_deploy_relay
                                Action Trigger
                                Delay 2
                                Repeats 1
                                Cooldown -1 
                            }
                        }
                    }
                }
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Fist
                }
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Fist
                }
            }
        }
