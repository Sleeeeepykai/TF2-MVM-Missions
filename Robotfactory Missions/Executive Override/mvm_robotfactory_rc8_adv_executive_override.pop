            {
                "targetname" "pop_interface"
            }
            tf_point_nav_interface
            {
                "targetname" "nav_interface"
            }

            logic_auto // Primarily for Wallbreaker Section
            {
                "targetname" "wallbreakerrelay"

                "OnMapSpawn" "wallbreaker_path_1,AddOutput,OnPass b1_wall_lockdown_relay:Trigger::0:-1,0,-1"

                "OnMapSpawn" "wallbreaker_path_2,AddOutput,OnPass drilltank_watermine:SetSpeed:1.5:0:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_2,AddOutput,OnPass B1_wall_drill_relay:Trigger::0:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_2,AddOutput,OnPass b1_wall_destroy_relay:Trigger::59:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_2,AddOutput,OnPass b1_wall_destroy_animation:$setkey$renderfx:5:72:-1,0,-1"

                "OnMapSpawn" "wallbreaker_path_3,AddOutput,OnPass drilltank_watermine:SetSpeed:75:0:-1,0,-1"

                "OnMapSpawn" "wallbreaker_path_4,AddOutput,OnPass drilltank_watermine:SetSpeed:1.5:0:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_4,AddOutput,OnPass C1_wall_drill_relay:Trigger::0:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_4,AddOutput,OnPass c1_wall_destroy_relay:Trigger::59:-1,0,-1"
                "OnMapSpawn" "wallbreaker_path_4,AddOutput,OnPass c1_wall_destroy_animation:$setkey$renderfx:5:72:-1,0,-1"

                "OnMapSpawn" "wallbreaker_path_5,AddOutput,OnPass drilltank_watermine:SetSpeed:75:0:-1,0,-1"
            }

            logic_relay
            {
                "targetname" "LockdownCleanupRelayWave4"

                "OnTrigger" "W3Bomb*,Kill,,0,-1"
            }
            logic_relay
            {
                "targetname" "LockdownCleanupRelayWave5"

                "OnTrigger" "W3Bomb*,Kill,,0,-1"
                "OnTrigger" "W4Breach*,Kill,,0,-1"
