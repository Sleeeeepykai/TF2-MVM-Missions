    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`Wave8LockdownSetup`, `ForceSpawn`)
                    EntFire(`Wave8SetupRelay`, `Trigger`)
                    IncludeScript(`seel_ins.nut`,getroottable())
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`Wave8BossIntroRelay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        // Boss Phase 1
        WaveSpawn // Spy Boss
