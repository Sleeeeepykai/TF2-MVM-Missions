				"OnTrigger" "B1_wall_fix_relay,Trigger,,0,-1"
				"OnTrigger" "C1_wall_fix_relay,Trigger,,0,-1"
				"OnTrigger" "B1_wall_fix_relay,Trigger,,0.2,-1"
				"OnTrigger" "C1_wall_fix_relay,Trigger,,0.2,-1"

				"OnTrigger" "hatch_shortcut_A_fix_relay,Trigger,,0,-1"
				"OnTrigger" "hatch_shortcut_B_fix_relay,Trigger,,0,-1"

				"OnTrigger" "A_route_wall_1_fix_relay,Trigger,,0,-1"
				"OnTrigger" "A_route_wall_2_fix_relay,Trigger,,0,-1"
				"OnTrigger" "A_route_wall_3_fix_relay,Trigger,,0,-1"
				"OnTrigger" "A_route_wall_4_fix_relay,Trigger,,0,-1"

				"OnTrigger" "A1_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "A2_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,1,-1"

				"OnTrigger" "bridge_flank_door_A_lock_relay,Trigger,,0,-1"
				"OnTrigger" "bridge_flank_door_B_lock_relay,Trigger,,0,-1"
				"OnTrigger" "bridge_flank_door_C_lock_relay,Trigger,,0,-1"

				"OnTrigger" "carrier_lift_raise_relay,Trigger,,0,-1"
				"OnTrigger" "carrier_door_front_close_relay,Trigger,,0,-1"
				"OnTrigger" "container_lift_raise_relay,Trigger,,0,-1"

				"OnTrigger" "door_front_l,Lock,,0,-1"
				"OnTrigger" "door_front_r,Lock,,0,-1"
				"OnTrigger" "door_front_l,Close,,0.1,-1"
				"OnTrigger" "door_front_r,Close,,0.1,-1"
			}
		}

		// Wave 2
		Wave2_PTs
		{
			logic_relay // Wave 2 Setup
			{
