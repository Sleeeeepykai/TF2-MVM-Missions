	//// SPAWNED POINT TEMPLATES ////

	//// EXTRA TANK PATHS ////

	//// EXTRA SPAWNPOINTS ////

	// Stage 1 Spawns
	ExtraSpawnPoint // Left
    {
        Name "spawnbot_stage1_left"
        TeamNum 3
        X "-1024"                     
        Y "-960"                  
        Z "64"        
    }
	ExtraSpawnPoint // Right
	{
		Name "spawnbot_stage1_right"
		TeamNum 3
		X "320"
		Y "-256"
		Z "64"
	}

	//// ROBOT TEMPLATES ////

	//// MISSION BOTS ////

	Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_stage1_left [$SIGSEGV]
		BeginAtWave 1
		RunForThisManyWaves 1
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}

	//// WAVES ////

	// Stage 1
	Wave
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`Stage1_PTs`, `ForceSpawn`)
					EntFire(`Wave1_PTs`, `ForceSpawn`)
					EntFire(`Wave1_SetupRelay`, `Trigger`)
					EntFire(`Relay_D`, `Trigger`)
					EntFire(`holograms`, `Disable`, null, 0.2)
					EntFire(`D_E_holograms`, `Disable`, null, 0.2)
			  	  "
		}
		StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`Stage1_StartRelay`, `Trigger`)
					EntFire(`wave_start_relay`, `Trigger`)
				  "
		}
		DoneOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`Stage1_FinishRelay`, `Trigger`)
					EntFire(`wave_finished_relay`, `Trigger`)
				  "
		}

		// Subwave 1
		WaveSpawn // 4 Homewrecker Pyros
		{
			Name "Wave1_Subwave1_Homewreckers"
			Where spawnbot_stage1_right [$SIGSEGV]
			TotalCount 4
			MaxActive 4
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 4
			TotalCurrency 100

			TFBot
			{
				Template T_TFBot_Pyro_Homewrecker
			}
		}
		WaveSpawn // 16 Pomson Engineers
		{
			Name "Wave1_Subwave1_Pomsons"
			Where spawnbot_stage1_left [$SIGSEGV]
			TotalCount 16
			MaxActive 8
			SpawnCount 4
			WaitBeforeStarting 0
			WaitBetweenSpawns 4
			TotalCurrency 40

			TFBot
			{
				Template T_TFBot_Engineer_Pomson
			}
		}

		WaveSpawn // 1 GPyro
		{
			Name "Wave1_Subwave1_GPyro"
			WaitForAllSpawned "Wave1_Subwave1_Homewreckers"
			Where spawnbot_stage1_left [$SIGSEGV]
			TotalCount 1
			MaxActive 1
