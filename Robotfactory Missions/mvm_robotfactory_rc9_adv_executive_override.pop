				"OnTrigger" "A_route_wall_2_fix_relay,Trigger,,0,-1"
				"OnTrigger" "A_route_wall_3_fix_relay,Trigger,,0,-1"
				"OnTrigger" "A_route_wall_4_fix_relay,Trigger,,0,-1"

				"OnTrigger" "A1_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "A2_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,1,-1"

				"OnTrigger" "bridge_flank_door_A_lock_relay,Trigger,,0,-1"
				"OnTrigger" "bridge_flank_door_B_lock_relay,Trigger,,0,-1"
				"OnTrigger" "bridge_flank_door_C_lock_relay,Trigger,,0,-1"

				"OnTrigger" "carrier_lift_raise_relay,Trigger,,0,-1"
				"OnTrigger" "carrier_door_front_close_relay,Trigger,,0,-1"
				"OnTrigger" "container_lift_raise_relay,Trigger,,0,-1"

				"OnTrigger" "door_front_l,Lock,,0,-1"
				"OnTrigger" "door_front_r,Lock,,0,-1"
				"OnTrigger" "door_front_l,Close,,0.1,-1"
				"OnTrigger" "door_front_r,Close,,0.1,-1"
			}

			env_shake // Explosion Shake
			{
				"targetname" "Wave3_BombPlantExplosionShake"
				"amplitude"  "10"
				"frequency"  "15"
				"duration"   "10"
				"radius"     "2000"
				"spawnflags" "5"
			}

			// 1st Bomb Plant Sequence
			func_flagdetectionzone // Bomb Plant Zone
			{
				"targetname" "Wave3_FirstBombPlantZone"
				"origin" "1408 -1168 28"
				"mins" "-80 -64 -32"
				"maxs" "80 64 32"
				"TeamNum" "2"

				"OnStartTouchFlag" "Wave3_ExtraBombTeamFlag,ForceDrop,,0,-1"
				"OnStartTouchFlag" "Wave3_ExtraBombArrow,HideSprite,,0,-1"

				"OnDroppedFlag" "Wave3_ExtraBombTeamFlag,SetTeam,2,0,-1"
				"OnDroppedFlag" "Wave3_ExtraBombTeamFlag,SetReturnTime,10,0,-1"
				"OnDroppedFlag" "Wave3_FirstBombPlantHint,Disable,,0,-1"
			}
			prop_dynamic // Bomb Hint Prop
			{
				"targetname" "Wave3_FirstBombPlantHint"
				"origin" "1407 -1176 28"
				"angles" "0 270 0"
				"model" "models\props_td\atom_bomb_blue2.mdl"
				"modelscale" "1.5"
				"solid" "0"
				"renderfx" "15"
				"disablebonefollowers" "1"
				"disableshadows" "1"
				"disablereceiveshadows" "1"
				"startdisabled" "1"
			}
			info_particle_system // Bomb Plant Explosion
			{
				"targetname" "Wave3_FirstBombPlantExplosion"
				"origin" "1408 -1168 28"
				"effect_name" "cinefx_goldrush"
				"start_active" "0"
			}
			info_particle_system // Bomb Plant Explosion
			{
				"targetname" "Wave3_FirstBombPlantExplosion"
				"origin" "1408 -1168 28"
				"effect_name" "fireSmoke_Collumn_mvmAcres"
				"start_active" "0"
			}
		}

		Wave3_ExtraBotBomb
		{
			OnSpawnOutput
			{
				Target "Wave3_ExtraBotBombProp"
				Action TurnOn
			}
			prop_dynamic_ornament
			{
				"targetname" "Wave3_ExtraBotBombProp"
				"model" "models\props_td\atom_bomb_blue2.mdl"
				"solid" "0"
				"disablebonefollowers" "1"
				"disableshadows" "1"
			}
		}

		Wave3_PlayerBombCarrierLogic1
		{
			KeepAlive 1
			
			item_teamflag // Dropped Extra Bomb
			{
				"targetname" "Wave3_ExtraBombTeamFlag"
				"origin" "0 0 0"
				"flag_model" "models\props_td\atom_bomb_blue2.mdl"
				"modelscale" "1"
				"TeamNum" "2"
				"startdisabled" "1"

				"OnPickup1" "!activator,$PlaySoundToSelf,items/gunpickup2.wav,0,-1"
				"OnPickup1" "Wave3_ExtraBombArrow,HideSprite,,0,-1"
				"OnPickup1" "Wave3_FirstBombPlantHint,Enable,,0,-1"
			}
			tf_glow // Extra Bomb Glow
			{
				"targetname" "Wave3_ExtraBombGlow"
				"target" "Wave3_ExtraBombTeamFlag"
				"GlowColor" "0 176 199 255"
				"startdisabled" "1"
			}
			env_sprite // Extra Bomb Arrow Sprite
			{
				"targetname" "Wave3_ExtraBombArrow"
				"origin" "0 0 100"
				"model" "materials/hud/arrow_big_down.vmt"
				"scale" "0.2"
			}

			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action Enable
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombTeamFlag"
				Action SetTeam
				Param 3
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombGlow"
				Action Enable
			}
			OnParentKilledOutput
			{
				Target "Wave3_ExtraBombArrow"
				Action ShowSprite
			}
		}
		Wave3_PlayerBombCarrierLogic2
		{
			KeepAlive 1
			
			item_teamflag // Dropped Extra Bomb
			{
				"targetname" "Wave3_ExtraBombTeamFlag"
				"origin" "0 0 0"
				"flag_model" "models\props_td\atom_bomb_blue2.mdl"
				"modelscale" "1"
				"TeamNum" "2"
				"startdisabled" "1"
			}
			tf_glow // Extra Bomb Glow
			{
				"targetname" "Wave3_ExtraBombGlow"
				"target" "Wave3_ExtraBombTeamFlag"
				"GlowColor" "0 176 199 255"
				"startdisabled" "1"
			}
			env_sprite // Extra Bomb Arrow Sprite
			{
