#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 800
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	BodyPartScaleSpeed 8

	//// PRECACHES ////

	// Precached Models

	PrecacheModel "models/mvm/barrier/barrier_spawn_blue1.mdl"
	PrecacheModel "models\props_td\atom_bomb_blue2.mdl"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Map Stage PTs ////

		Stage1_PTs
		{
			// Stage 1 Relays
			logic_relay // Stage 1 Start
			{
				"targetname" "Stage1_StartRelay"

				"OnTrigger" "tf_gamerules,PlayVO,ambient\levels\labs\electric_explosion1.wav,0,-1"
				"OnTrigger" "Stage1RespawnBarrier_Left,Enable,,0,-1"
				"OnTrigger" "Stage1RespawnBarrier_Right,Enable,,0,-1"
				"OnTrigger" "B1_door_unlock_relay,Trigger,,0,-1"
				"OnTrigger" "A1_door_unlock_relay,Trigger,,0,-1"
			}
			logic_relay // Stage 1 Finish
			{
				"targetname" "Stage1_FinishRelay"

				"OnTrigger" "tf_gamerules,PlayVO,ambient\levels\labs\electric_explosion5.wav,0,-1"
				"OnTrigger" "Stage1RespawnBarrier_Left,Disable,,0,-1"
				"OnTrigger" "Stage1RespawnBarrier_Right,Disable,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,1,-1"
				"OnTrigger" "A1_door_lock_relay,Trigger,,0,-1"
			}

			// Stage 1 Respawn Rooms
			trigger_multiple // Left Spawn Room
			{
				"targetname" "Stage1RespawnRoom_Left"
