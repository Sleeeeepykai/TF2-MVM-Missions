				"mins" "-760 -760 -336"
				"maxs" "760 760 336"
				"wait" "0.5"
				"spawnflags" "64"

				"filtername" "blue_team_filter"

				"OnStartTouch" "!activator,$Addcond,51,0,-1"
				"OnStartTouch" "!activator,$AddPlayerAttribute,no_attack|1,0,-1"
				"OnEndTouch" "!activator,$Removecond,51,0,-1"
				"OnEndTouch" "!activator,$RemovePlayerAttribute,no_attack,0,-1"
