                Param "nuker_hitbox"
            }
            OnSpawnOutput
            {
                Target "nuke_range"
                Action "$SetLocalAngles"
                Param "0 0 0"
                delay 0.2
            }
            OnParentKilledOutput
            {
                Target "nuke_range"
