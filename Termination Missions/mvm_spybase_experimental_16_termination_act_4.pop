            }
            logic_relay
            {
                "targetname" "judgement"
                "OnTrigger" "kablooey,PlaySound,,0.5,1"
                "OnTrigger" "kablooey,StopSound,,1.49,1"
                "OnTrigger" "kablooey,PlaySound,,1.5,1"
                "OnTrigger" "kablooey,StopSound,,2.49,1"
                "OnTrigger" "kablooey,PlaySound,,2.5,1"
                "OnTrigger" "kablooey,StopSound,,3.49,1"
                "OnTrigger" "kablooey,PlaySound,,3.5,1"
