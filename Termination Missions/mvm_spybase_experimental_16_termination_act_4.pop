				Item "Blast Defense"
				Item "The Juggernaut Jacket"
				
				ItemAttributes
				{
					ItemName "Upgradeable TF_WEAPON_GRENADELAUNCHER"
					"faster reload rate" -1
					"fire rate bonus" 0.75
				}
				CharacterAttributes
				{
					"never gib" 1
				}
				ExtAttr IgnoreNPC // does not target tank
				Action Mobber
			}
        }
