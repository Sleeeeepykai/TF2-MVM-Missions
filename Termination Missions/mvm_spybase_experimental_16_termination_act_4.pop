        DemoChiefNukeLogic
        {
            OnSpawnOutput
            {
                Target judgement
                Action Trigger
                Delay 0.017
            }
            OnSpawnOutput
            {
                Target "boss_about_to_blow"
                Action Start
                Delay 1
            }
            ambient_generic
            {
                "targetname" "kablooey"
                "message" "items\cart_explode_trigger.wav"
