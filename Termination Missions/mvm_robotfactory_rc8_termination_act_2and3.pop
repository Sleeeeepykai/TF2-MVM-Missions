    //// POINT TEMPLATES ////

    PointTemplates
    {
		//// ASSETS ACROSS ALL WAVES ////

		CoreAssets
		{
			// Interface Templates
			point_populator_interface
            {
                "targetname" "pop_interface"
            }
			tf_point_nav_interface
			{
				Name nav_interface
			}

			// Ragdoll Remover
			logic_timer
			{
				"targetname"    "ragdollremover"
				"RefireTime"    "7"
				"OnTimer"       "tf_ragdoll*,kill,,0,-1"
			}

			// Disabling Shadows
			OnSpawnOutput
            {
                Target lift_*
                Action $setkey$disableshadows
                Param 1
                Delay 0.1
            }
            OnSpawnOutput
            {
                Target carrier_*
                Action $setkey$disableshadows
                Param 1
                Delay 0.1
            }

			// Disabling Hidden Australium Tank Collision
			OnSpawnOutput
			{
				Target australium_tank_model_main
				Action "DisableCollision"
			}

			NoFixup 1
			logic_relay // Double Trigger to Resolve Relay Issues?
			{
				"targetname" "Relay_DoubleTrigger"
				"OnTrigger" "B1_wall_fix_relay,Trigger,,0,-1"
				"OnTrigger" "C1_wall_fix_relay,Trigger,,0,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,0.2,-1"
				"OnTrigger" "C1_door_lock_relay,Trigger,,0.2,-1"
				"OnTrigger" "B1_door_lock_relay,Trigger,,0.4,-1"
