	Wave
	{
		CustomWaveNumber 4
		CustomMaxWaveNumber 7

		SpawnTemplate Wave4Setup

		InitWaveOutput
		{
			Target wave_start_relay // gamerules or tf_gamerules, depending on the map
			Action RunScriptCode
			Param "
				EntFire(`Wave4Assets`, `ForceSpawn`)
				EntFire(`Wave4SetupRelay`, `Trigger`)
				Convars.SetValue(`tf_playergib`, 0)
				"
		}
		StartWaveOutput
		{
			Target wave_start_relay
			Action Trigger
		}
		DoneOutput
		{
			Target wave_finished_relay
			Action Trigger
		}

