				AddCond { Name TF_COND_STEALTHED_USER_BUFF_FADING } 
				StripItemSlot 0
				StripItemSlot 1
				StripItemSlot 2
				UseCustomModel "models/empty.mdl"
				FireInput
					{
						Target !self //targets the bot this is on
						Action $Suicide
						Delay 0.1
					}
				CharacterAttributes 
				{
					"cancel falling damage" 1 
					"cannot be sapped" 1		
					"not solid to players" 1 
					"rage giving scale" 0
					"no_jump" 1
					"move speed bonus" 0.001
					"cannot pick up intelligence" 1
					"voice pitch scale" 0
					"damage force reduction" 0.001
					"airblast vulnerability multiplier" 0.0001
					"dmg from melee increased" 0.0001
					"dmg taken from fire reduced" 0.0001
					"dmg from ranged reduced" 0.0001
					"afterburn immunity" 1
					"wet immunity" 1
				}
			}
