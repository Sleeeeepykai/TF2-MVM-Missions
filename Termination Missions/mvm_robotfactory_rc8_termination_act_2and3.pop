			Param "
			EntFire(`Wave2Assets`, `ForceSpawn`)
			EntFire(`Wave2ControlPoints`, `ForceSpawn`)
			EntFire(`Wave2SetupRelay`, `Trigger`)
			Convars.SetValue(`tf_playergib`, 0)
