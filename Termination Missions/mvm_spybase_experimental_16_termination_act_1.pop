        // For Sentry Buster Destroying Side Props at Spawn
        SentryBusterPropDestruction
        {
            OnParentKilledOutput
			{
				Target "flavour_front*"
				Action Kill
				Delay 0
			}
        }

        // For GHeavy Bomb Carrier
        BotBombCarrierProp
        {
            OnSpawnOutput
			{
				Target "bossbombattack"
				Action TurnOn
			}
            prop_dynamic_ornament
			{
				"targetname" "bossbombattack"
				"model" "models\props_td\atom_bomb.mdl"
				"solid" "0"
				"disablebonefollowers" "1"
				"disableshadows" "1"
			}
        }

        // For Player Bomb Carrier
        PlayerBombCarrierLogic
        {
            KeepAlive 1
			OnSpawnOutput
			{
				Target "voicelinesfordroppedbomb"
				Action Trigger
				Delay 25
			}
			logic_relay
			{
				"targetname" "voicelinesfordroppedbomb"
				"OnTrigger"  "bignetrunscriptcodePrecacheSound(`ui/quest_alert.wav`);EmitSoundEx({sound_name=`ui/quest_alert.wav`,special_dsp = 56,filter_type=5})01"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_bombpickup.mp3`,special_dsp = 56,filter_type=5})1.41"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_bombpickup.mp3`,special_dsp = 56,filter_type=5})1.41"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_bombpickup.mp3`,special_dsp = 56,filter_type=5})1.41"
			}
            item_teamflag // Bomb Flag Entity
			{
				"targetname" "bomb1_timed"
				"TeamNum" "2"
				"StartDisabled" "1"
				"modelscale" "1"
				"flag_model" "models\props_td\atom_bomb.mdl"
				"origin" "0 0 0"
				"OnReturn" "!self,Kill,,0.1,-1"
				"OnReturn" "02_door,kill,,0.2,-1"
				"OnReturn" "meantoblowup*,kill,,0.2,-1"
				"OnReturn" "bombexplosionsequence,trigger,,0,1"
				"OnPickup1" "!activatorRunScriptCodeClientPrint(self, 4, `YOU PICKED UP THE BOMB! PLACE IT NEXT TO THE CONTAINERS!`)0-1"
				"OnPickup1" "!activatorRunScriptCodeClientPrint(self, 4, `YOU PICKED UP THE BOMB! PLACE IT NEXT TO THE CONTAINERS!`)4-1"
				"OnPickup1" "!activator,$PlaySoundToSelf,ui\item_bag_pickup.wav,0,-1"
				"OnPickup1" "hologrambomb,enable,,0,-1"
				"OnPickup1" "res2,hidesprite,,0,-1"	
			}
            tf_glow // Bomb Flag Glow
            {
                "GlowColor" "0 176 199 255"
                "target" "bomb1_timed"
				"targetname" "flag_glow"
				"startdisabled" "1"
