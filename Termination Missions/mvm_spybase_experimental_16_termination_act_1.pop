    //// MISSION INIT OUTPUTS ///

    // Gib Remover
    MissionUnloadOutput
	{
		Target "wave_start_relay"
		Action "runscriptcode"
		Param "Convars.SetValue(`tf_playergib`, 1)"
		Delay -1
	}

	//// SPAWNED TEMPLATES ////
    SpawnTemplate Wave1Assets
    SpawnTemplate Wave1Setup

    Wave
    {
        CustomMaxWaveNumber 7

		InitWaveOutput
		{
			Target wave_start_relay
			Action RunScriptCode
			Param "
			IncludeScript(`claudz_logic_v3`)
			Convars.SetValue(`tf_playergib`, 0)
			"
		}
		StartWaveOutput
		{
			Target wave_start_relay
			Action RunScriptCode
			Param "
			EntFire(`elevator_breaker`,`lock`)
            EntFire(`disablethesewavespawns`, `Trigger`)
			EntFire(`wave_start_relay`, `Trigger`)
			EntFire(`hudtimer`, `enable`, null, 0.5)
			EntFire(`startingdoorbutton`, `enable`)
			EntFire(`heytouchthis`, `enable`)
			EntFire(`startingdoorbutton`, `unlock`)
			"
		}
		DoneOutput
		{
			Target wave_finished_relay
			Action Trigger
		}

