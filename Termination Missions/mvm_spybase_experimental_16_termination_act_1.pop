	//// ROBOT TEMPLATES ////

	Templates
	{
		T_TFBot_Chief_Technician
		{
			Name "Chief Technician"
			Class Engineer
			ClassIcon engineer_hyper
			Health 20000
			Scale 1.75
			Skill Expert
			Attributes MiniBoss
			Attributes UseBossHealthBar
			WeaponRestrictions MeleeOnly
			Tag giant
			MaxVisionRange 1500
			Action Mobber

			SpawnTemplate ChiefTechnicianIndicator
			SpawnTemplate ChiefTechnicianRingAttackMaker

			Item "The Rescue Ranger"
			Item "The Eureka Effect"

			Item "Hazard Handler"
			Item "Cargo Constructor"

			CharacterAttributes
			{
				"move speed bonus" 0.001
				"never gib" 1
				"no_jump" 1
				"damage force reduction" 0.5
				"airblast vulnerability multiplier" 0.5
				"override footstep sound set" 4
				"voice pitch scale" 0.75
				"displace touched enemies" 1
			}
			ItemAttributes
			{
				ItemName "The Rescue Ranger"
				"fire rate bonus" 0.8
				"faster reload rate" 0.5
				"clip size bonus" 2
				"hold fire until full reload" 1
				"never gib" 1
			}
			FireInput // Sets Starting Position
			{
				Target !self
				Action $SetLocalOrigin
				Param "-2048 6624 704"
				Delay 0
				Repeats 1
				Cooldown -1
			}
			AddAttribute // Makes Him Start Moving
			{
				Item Player  
				Name "move speed bonus"
				Value 0.5
				Delay 10
			}
			FireInput // Voiceline
			{
				Target tf_gamerules
				Action PlayVO
				Param "vo/mvm/norm/engineer_mvm_dominationscout12.mp3"
				Delay 2.5
				Repeats 1
				Cooldown -1
			}
			FireInput // Taunt
			{
				Target !self
				Action $PlaySequence
				Param "taunt_highFiveStart"
				Delay 5
				Repeats 1
				Cooldown -1
			}
			FireInput // Voiceline
			{
				Target tf_gamerules
				Action PlayVO
				Param "vo/mvm/norm/engineer_mvm_go03.mp3"
				Delay 5
				Repeats 1
				Cooldown -1
			}
			AddCond // Temporary Invincibility
			{
				Index 51
			}
			InterruptAction // Moves to the Main Console
			{
				Target "-2048 6624 704"
				Delay 0
				Repeats 1
				Duration 1
				Cooldown 0
				AimTarget "-2035 7193 688"
				AlwaysLook 1
				WaitUntilDone 0
			}
			InterruptAction // Moves to the Main Console
			{
				Target "-5850 5279 512"
				Delay 10.1
				Repeats 1
				Duration 1
				Cooldown 0
				WaitUntilDone 1
				OnDoneChangeAttributes "BossIdle"
			}
			ChangeAttributes // Boss Fight Trigger
			{
				Name "BossFightStart"
				Delay 0
				Repeats 1
				Cooldown -1
				IfHealthBelow 19999
			}

			EventChangeAttributes
			{
				BossIdle
				{
					FireInput
					{
						Target !self
						Action $SetLocalOrigin
						Param "-4940 1789 536"
						Delay 0
						Repeats 1
						Cooldown -1
					}
					FireInput
					{
						Target !self
						Action $RemoveCond
						Param 51
						Delay 0
						Repeats 1
						Cooldown -1
					}
					Taunt
					{
						Delay 1
						Cooldown -1
						Repeats 1
						Duration 999
						Name "Rancho Relaxo Taunt"
					}
				}
				BossFightStart
				{
					FireInput
					{
						Target "nowtherealfightbegins"
						Action Trigger
						Delay 0
						Repeats 1
						Cooldown -1
					}
					FireInput
					{
						Target !self
						Action RunScriptCode
						Param "self.StopTaunt(false);"
						Delay 0.25
					}
					ChangeAttributes
					{
						Name "BossFightPattern"
						Delay 8
						Repeats 1
						Cooldown -1
					}
				}
				BossFightPattern
				{
					InterruptAction // Keeps the Boss Stationary
					{
						Target "-5067 1783 536"
						Delay 0.1
						Repeats 0
						Cooldown 5
						Duration 5
						Distance 50
					}
					WeaponSwitch
					{
						Delay 0
						Cooldown 14
						Repeats 1
