        ChiefTechnicianRingAttackMaker
        {
            NoFixUp 1

            OnSpawnOutput // Sets RingMaker Owner
            {
                target "!activator"
                action "RunScriptCode"
                param "CzUtil.AddTracking(`ChiefTechnicianRingAttackMaker`, self)"
                delay 0.0
            }
            OnParentKilledOutput // Removes RingMaker Owner
            {
                target "ring_maker"
                action "RunScriptCode"
                param "CzUtil.RemoveTracking(`ChiefTechnicianRingAttackMaker`)"
                delay 0.0
            }
            env_entity_maker // RingMaker Entity
            {   
                "targetname" "ring_maker"
                "entitytemplate" "ChiefTechnicianRingAttackLogic"
            }
        }
        ChiefTechnicianRingAttackLogic
        {
            KeepAlive 1

            env_beam // Ring Attack Indicator Beam
            {
                "parentname" ""
                "targetname" "roundbeamtest"
                "BoltWidth" "4"
                "LightningStart" "ringmarkerone"
                "LightningEnd" "ringmarkertwo"
                "origin" "0 0 30"
                "renderamt" "200"
                "rendercolor" "200 200 255"
                "damage" "0"
                "NoiseAmplitude" "4"
                "dissolvetype" "1"
                "texture" "sprites/laserbeam.spr"
                "life" "4"
                "spawnflags" "8" //8
                "TouchType" "1"
            }
            prop_dynamic // Ring Attack Bounding Prop
            {
                "parentname" ""
                "targetname" "ringmarkerone"
                "model" "models/empty.mdl"
                "solid" "0"
                "origin" "0 0 30"                
            }
            prop_dynamic // Ring Attack Bounding Prop
            {
                "parentname" ""
                "targetname" "ringmarkertwo"
                "model" "models/empty.mdl"
                "solid" "0"
                "angles" "0 180 0"
                "origin" "0 0 30"
            }
            OnSpawnOutput // Ring Attack Firing Sound
            {
                target "tf_gamerules"
                action "PlayVO"
                Param "npc\combine_gunship\gunship_ping_search.wav"
                delay "0.0"
            }
            OnSpawnOutput // ???
            {
                target "roundbeamtest"
                action "StrikeOnce"
                delay "0"
            }
            OnSpawnOutput // Registers RingMaker Owner
            {
                target "roundbeamtest"
                action "RunScriptCode"
                param "RingRegister(self,80,CzUtil.GetTracking(`ChiefTechnicianRingAttackMaker`))"
                delay 0.0
            }
            OnSpawnOutput // Sets Bounding Prop to be Non-Solid?
            {
                target "ringmarkerone"
                action "RunScriptCode"
                param "SetMoveIgnoreSolid(self, 120)"
            }
            OnSpawnOutput // Sets Bounding Prop to be Non-Solid?
            {
                target "ringmarkertwo"
                action "RunScriptCode"
                param "SetMoveIgnoreSolid(self, 120)"
            }
            OnSpawnOutput // Turns Off Ring Beam Entity
            {
                target "roundbeamtest"
                action "TurnOff"
                delay "4.5"
            }
            OnSpawnOutput // Despawns Ring Beam Entity
            {
                target "roundbeamtest"
                action "kill"
                delay "5.0"
            }
            OnSpawnOutput // Despawns Bounding Prop
            {
                target "ringmarkerone"
                action "kill"
                delay "5.5"
            }
            OnSpawnOutput // Despawns Bounding Prop
            {
                target "ringmarkertwo"
                action "kill"
                delay "5.5"
            }
        }

