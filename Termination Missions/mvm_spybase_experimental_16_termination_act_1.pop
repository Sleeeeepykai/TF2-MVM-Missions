        Wave1Setup
        {
            // Disabling Shadows
            OnSpawnOutput
            {
                Target lift_*
                Action $setkey$disableshadows
                Param 1
                Delay 1
            }
            OnSpawnOutput
            {
                Target carrier_*
                Action $setkey$disableshadows
                Param 1
                Delay 1
            }

            OnSpawnOutput
			{
				Target ambient_timer
				Action enable
			}
			OnSpawnOutput // Locks Starting Door Button
			{
				Target startingdoorbutton
				Action Lock
			}
            OnSpawnOutput // Disable Alarm Light
			{
				Target "door_alarm_light"
				Action "TurnOff"
			}
			OnSpawnOutput // Disable Alarm Light
			{
				Target "door_alarm_light_2"
				Action "Color"
				Param "0 0 0"
			}

            logic_relay // Wavespawn Disabler
			{
				"targetname" "disablethesewavespawns"
				"OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave1_SniperFodder,0,1"
				"OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave1_ChiefTechnician,0,1"
				"OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave3_BombCarrierGiant,0,1"
				"OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave4_DrillTank,0,1"
                "OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave6_Bowmen,0,1"
                "OnTrigger"  "pop_interface,$PauseWavespawn,Wave1_Subwave7_GRapidSquad,0,1"
			}
			logic_relay
			{
				"targetname" "voicelinesithink"
				"OnTrigger"  "bignetrunscriptcodePrecacheSound(`ui/quest_alert.wav`);EmitSoundEx({sound_name=`ui/quest_alert.wav`,special_dsp = 56,filter_type=5})01"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_emptankfired.mp3`,special_dsp = 56,filter_type=5})1.41"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_emptankfired.mp3`,special_dsp = 56,filter_type=5})1.41"
				"OnTrigger"  "bignetrunscriptcodeEmitSoundEx({sound_name=`saxtonhale/saxton_hale_emptankfired.mp3`,special_dsp = 56,filter_type=5})1.41"
			}
            logic_auto // Sets up Multiple Aspects of the Mission
            {
				"OnMapSpawn" "red_lift_spawn,disable,,0.1,-1"
                "OnMapSpawn" "red_rev_mission_relay,trigger,,0.1,-1"
				"OnMapSpawn" "carrier_disable_relay,trigger,,0,-1"
				"OnMapSpawn" "drydock_open_relay,trigger,,0,-1"
				"OnMapSpawn" "shortcut_bridge_retract_relay,trigger,,0,-1"
				"OnMapSpawn" "01_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "02_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "03_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "04_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "05_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "06_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "08_door_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "02_door_flank_1_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "02_door_flank_2_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "03_door_flank_1_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "03_door_flank_2_lock_relay,trigger,,0,-1"
				"OnMapSpawn" "silo_door_close,trigger,,0,-1"
                "OnMapSpawn" "telezone,disable,,1,-1"
                "OnMapSpawn" "telezone,enable,,0.1,-1"
                "OnMapSpawn" "carrier_lift,setspeed,99999,0,-1"
                "OnMapSpawn" "01_door,setspeed,99999,0,-1"
                "OnMapSpawn" "01_door,setspeed,50,1,-1"
				"OnMapSpawn" "tf_objective_resource,$SetClientProp$m_iszMvMPopfileName,Termination - Indium Infiltration,0,-1"
				"OnMapSpawn" "emp_tank_path_8,AddOutput,OnPass emp_tank:SetSpeed:0:0:-1,0,-1"
				"OnMapSpawn" "emp_tank_path_8,AddOutput,OnPass 03_door_unlock_relay:trigger::13:-1,0,-1"
