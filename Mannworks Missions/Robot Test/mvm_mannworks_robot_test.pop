#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop

WaveSchedule
{
    StartingCurrency 5000
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No

    Wave
    {
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`bombpath_arrows_clear_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`bombpath_wavefinished`, `Trigger`)        
                  "
        }

        WaveSpawn
        {
            Name "Wave1"
            Where spawnbot
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Class Soldier
            }
        }
    }
    Wave
    {
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`bombpath_arrows_clear_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`bombpath_wavefinished`, `Trigger`)        
                  "
        }

        WaveSpawn
        {
            Name "Wave2"
            Where spawnbot
            TotalCount 2
            MaxActive 2
            SpawnCount 2

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Soldier
                }
                TFBot
                {
                    Template T_TFBot_Giant_Medic_Charged
                }
            }
        }
    }
}