#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 800
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No
    WaveStartCountdown 5

    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

    //// WAVESCHEDULE EXTRA KEYVALUES ////

    BotHumansHaveEyeGlow 1

    //// PRECACHES ////

    //// PRECACHED MODELS ////
    PrecacheModel "models/bots/skeleton_sniper/skeleton_sniper.mdl"

    //// PRECACHED EXTRAS ////

    PrecacheGeneric "materials/colorcorrection/nightlight.raw"
    PrecacheGeneric "materials/skybox/sky_deathraidbk.vtf"
    PrecacheGeneric "materials/skybox/sky_deathraidbk.vmt"
    PrecacheGeneric "materials/skybox/sky_deathraidft.vtf"
    PrecacheGeneric "materials/skybox/sky_deathraidft.vmt"
    PrecacheGeneric "materials/skybox/sky_deathraidlf.vtf"
    PrecacheGeneric "materials/skybox/sky_deathraidlf.vmt"
    PrecacheGeneric "materials/skybox/sky_deathraidrt.vtf"
    PrecacheGeneric "materials/skybox/sky_deathraidrt.vmt"
    PrecacheGeneric "materials/skybox/sky_deathraidup.vtf"
    PrecacheGeneric "materials/skybox/sky_deathraidup.vmt"
    PrecacheGeneric "materials/skybox/sky_deathraiddn.vmt"

    //// POINT TEMPLATES ////

    PointTemplates
    {
        MainMissionAssets
        {
            logic_relay
            {
                "targetname" "MainSetupRelay"

                "OnTrigger" "init_skybox_change,Trigger,,0,-1"
                "OnTrigger" "skybox_clouds,Disable,,0,-1"
                "OnTrigger" "sky_normal_player_fix,Disable,,0,-1"
                "OnTrigger" "night_sky_fixer,Enable,,0,-1"
                "OnTrigger" "PlayerRunScriptCodeTermination_SkyCamera.SetSkyCamera(`night_sky_camera`, self)0.5-1"
            }

            skybox_swapper
            {
                "targetname" "init_skybox_change"
                "skyboxname" "sky_deathraid"
            }
            color_correction
            {
                "targetname" "nightlight"
                "origin" "0 0 0"
                "minfalloff" "-1"
                "maxfalloff" "-1"
                "fadeInDuration" "0"
                "fadeOutDuration" "0"
                "filename" "materials/colorcorrection/nightlight.raw"
            }
            sky_camera
            {
                "fogmaxdensity" "1"
                "origin"        "7744 6400 -15"
                "angles"        "0 0 0"
                "fogcolor"      "24 19 32"
                "fogdir"        "1 0 0"
                "fogenable"     "1"
                "fogend"        "30000"
                "fogstart"      "1500"
                "scale"         "16"       
                "targetname"    "night_sky_camera"
            }
            logic_eventlistener
            {
                "targetname" "night_sky_fixer"
                "eventname" "player_spawn"
                "teamnum" "2"

                "OnEventFired" "PlayerRunScriptCodeTermination_SkyCamera.SetSkyCamera(`night_sky_camera`, self)0.5-1"
            }

            logic_relay
            {
                "targetname" "WaveStartClockRelay"

                "OnTrigger" "tf_gamerules,PlayVO,misc/halloween/clock_tick.wav,0,-1"
                "OnTrigger" "tf_gamerules,PlayVO,misc/halloween/clock_tick.wav,1,-1"
                "OnTrigger" "tf_gamerules,PlayVO,misc/halloween/clock_tick.wav,2,-1"
                "OnTrigger" "tf_gamerules,PlayVO,misc/halloween/clock_tick.wav,3,-1"

                "OnTrigger" "tf_gamerules,PlayVO,vo/halloween_boss/knight_laugh04.mp3,4,-1"
            }
        }
    }

    //// SPAWNED TEMPLATES ////

    SpawnTemplate MainMissionAssets

    //// ROBOT TEMPLATES ////

    Templates
    {
        T_TFBot_Skeleton_Easy
        {
            Name "Skeleton"
            Class Sniper
            ClassIcon dead_blu_lite
            Health 150
            Scale 1.001

            UseCustomModel "models/bots/skeleton_sniper/skeleton_sniper.mdl"
            Skin 2
            CustomEyeGlowColor "0 240 255"
            DeathSound "misc/halloween/skeleton_break.wav"

            CharacterAttributes
            {
                "voice pitch scale" 0
                "bombinomicon effect on death" 1
            }
            ItemAttributes
            {
                ItemName "tf_weapon_club"
                "custom kill icon" "spellbook_skeleton"
                "is invisible" 1
            }
        }
        T_TFBot_Skeleton_Hard
        {
            Name "Skeleton"
            Class Sniper
            ClassIcon dead_blu_lite
            Health 150
            Scale 1.001

            UseCustomModel "models/bots/skeleton_sniper/skeleton_sniper.mdl"
            Skin 2
            CustomEyeGlowColor "255 180 36"
            DeathSound "misc/halloween/skeleton_break.wav"

            CharacterAttributes
            {
                "voice pitch scale" 0
                "bombinomicon effect on death" 1
            }
            ItemAttributes
            {
                ItemName "tf_weapon_club"
                "custom kill icon" "spellbook_skeleton"
                "is invisible" 1
            }
        }
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_left
        BeginAtWave 1
        RunForThisManyWaves 6
        DesiredCount 1

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Skeleton_Hard
			Name "Sentry Buster Skeleton"
            Class Demoman
            ClassIcon sentry_buster
			Health 2500
            Scale 1.75
            Skill Expert
			WeaponRestrictions MeleeOnly
			Attributes MiniBoss

            Item "The Ullapool Caber"

			CharacterAttributes
			{
				"move speed bonus" 2
				"damage force reduction" 0.5
				"airblast vulnerability multiplier" 0.5
				"override footstep sound set" 7
				"cannot be backstabbed" 1
			}
        }  
    }

    //// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `(Adv) Death Raid`)
                    EntFire(`MainSetupRelay`, `Trigger`)
                    EntFire(`bombpath_right_relay`, `Trigger`)
                  "
        }
        StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                    EntFire(`WaveStartClockRelay`, `Trigger`)
                  "
		}
	    DoneOutput					
		{
			Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
		}

        // Subwave 1
        WaveSpawn // 32 Melees on Left and Right
        {
            Name "Wave1_Subwave1_Melee"
            Where spawnbot_left
            Where spawnbot_right
            TotalCount 32
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 1
            TotalCurrency 200

            TFBot
            {
                Template T_TFBot_Skeleton_Hard
                Skill Hard
                WeaponRestrictions MeleeOnly
                Action Mobber
            }
        }
        WaveSpawn // 32 Grenadiers on Main
        {
            Name "Wave1_Subwave1_Grenadier"
            Where spawnbot
            TotalCount 32
            MaxActive 8
            SpawnCount 2
            WaitBeforeStarting 4
            WaitBetweenSpawns 2
            TotalCurrency 160

            TFBot
            {
                Template T_TFBot_Skeleton_Easy
                Name "Grenadier Skeleton"
                Class Demoman
                ClassIcon demo
                Health 175
                Skill Normal
                WeaponRestrictions PrimaryOnly

                UseHumanAnimations 1

                Item "The Buccaneer's Bicorne"
                Item "The Gaelic Garb"
                Item "The Gaelic Golf Bag"
            }
        }

        // Subwave 2
        WaveSpawn // 4 Steelweights and 16 Rocketeers on Main
        {
            Name "Wave1_Subwave2_Steels"
            WaitForAllSpawned "Wave1_Subwave1_Grenadier"
            Where spawnbot
            TotalCount 20
            MaxActive 10
            SpawnCount 5
            WaitBeforeStarting 16
            WaitBetweenSpawns 8
            TotalCurrency 120

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Skeleton_Hard
                    Name "Steelweight Skeleton"
                    Class Heavy
                    ClassIcon heavy_steelfist
                    Health 900
                    Scale 1.5
                    Skill Hard
                    WeaponRestrictions MeleeOnly

                    UseHumanAnimations 1
                    
                    Item "Pugilist's Protector"
                    Item "Bone-Cut Belt"
                    Item "Fists of Steel"
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Rocketeer Skeleton"
                    Class Soldier
                    ClassIcon soldier
                    Health 200
                    Skill Normal
                    WeaponRestrictions PrimaryOnly

                    UseHumanAnimations 1

                    Item "Full Metal Helmet"
                    Item "Attack Packs"
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Rocketeer Skeleton"
                    Class Soldier
                    ClassIcon soldier
                    Health 200
                    Skill Normal
                    WeaponRestrictions PrimaryOnly

                    UseHumanAnimations 1

                    Item "Full Metal Helmet"
                    Item "Attack Packs"
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Rocketeer Skeleton"
                    Class Soldier
                    ClassIcon soldier
                    Health 200
                    Skill Normal
                    WeaponRestrictions PrimaryOnly

                    UseHumanAnimations 1

                    Item "Full Metal Helmet"
                    Item "Attack Packs"
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Rocketeer Skeleton"
                    Class Soldier
                    ClassIcon soldier
                    Health 200
                    Skill Normal
                    WeaponRestrictions PrimaryOnly

                    UseHumanAnimations 1

                    Item "Full Metal Helmet"
                    Item "Attack Packs"
                }
            }
        }
        WaveSpawn // 16 Scatterguns on Right
        {
            Name "Wave1_Subwave2_Scouts"
            WaitForAllSpawned "Wave1_Subwave1_Grenadier"
            Where spawnbot_right
            TotalCount 16
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 2
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Skeleton_Easy
                Name "Scattergun Skeleton"
                Class Scout
                ClassIcon scout
                Health 125
                Skill Normal
                WeaponRestrictions PrimaryOnly

                UseHumanAnimations 1

                Item "Batter's Helmet"
                Item "The Boston Boom-Bringer"
            }
        }

        // Subwave 3
        WaveSpawn // 3 Giant Rocketeers and 9 Bigheals on Main
        {
            Name "Wave1_Subwave3_GRocketeer"
            WaitForAllSpawned "Wave1_Subwave2_Steels"
            Where spawnbot
            TotalCount 12
            MaxActive 8
            SpawnCount 4
            WaitBeforeStarting 16
            WaitBetweenSpawns 16
            TotalCurrency 120

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Skeleton_Hard
                    Name "Giant Rocketeer Skeleton"
                    Class Soldier
                    ClassIcon soldier_giant
                    Health 3800
                    Scale 1.75
                    Skill Expert
                    WeaponRestrictions PrimaryOnly
                    Attributes HoldFireUntilFullReload
                    Attributes MiniBoss
                    
                    UseHumanAnimations 1

                    Item "Full Metal Helmet"
                    Item "Attack Packs"

                    CharacterAttributes
                    {
                        "move speed bonus"	0.5
                        "damage force reduction" 0.4
                        "airblast vulnerability multiplier" 0.4
                        "override footstep sound set" 3
                    }
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Bigheal Skeleton"
                    Class Medic
                    ClassIcon medic
                    Health 175
                    Skill Normal

                    UseHumanAnimations 1

                    Item "The Surgeon's Stahlhelm"
                    Item "The Medic Mech-bag"

                    CharacterAttributes
                    {
                        "heal rate bonus" 10
                    }
                    ItemAttributes
                    {
                        ItemName "The Quick-Fix"
                        "ubercharge rate bonus" 0.1
                    }
                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_SYRINGEGUN_MEDIC"
                        "damage penalty" 0.1
                    }
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Bigheal Skeleton"
                    Class Medic
                    ClassIcon medic
                    Health 175
                    Skill Normal

                    UseHumanAnimations 1

                    Item "The Surgeon's Stahlhelm"
                    Item "The Medic Mech-bag"

                    CharacterAttributes
                    {
                        "heal rate bonus" 10
                    }
                    ItemAttributes
                    {
                        ItemName "The Quick-Fix"
                        "ubercharge rate bonus" 0.1
                    }
                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_SYRINGEGUN_MEDIC"
                        "damage penalty" 0.1
                    }
                }
                TFBot
                {
                    Template T_TFBot_Skeleton_Easy
                    Name "Bigheal Skeleton"
                    Class Medic
                    ClassIcon medic
                    Health 175
                    Skill Normal

                    UseHumanAnimations 1

                    Item "The Surgeon's Stahlhelm"
                    Item "The Medic Mech-bag"

                    CharacterAttributes
                    {
                        "heal rate bonus" 10
                    }
                    ItemAttributes
                    {
                        ItemName "The Quick-Fix"
                        "ubercharge rate bonus" 0.1
                    }
                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_SYRINGEGUN_MEDIC"
                        "damage penalty" 0.1
                    }
                }
            }
        }
        WaveSpawn // Support Miniguns on Left
        {
            Name "Wave1_Subwave3_Miniguns"
            WaitForAllSpawned "Wave1_Subwave2_Steels"
            Where spawnbot_left
            Support Limited
            TotalCount 24
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 2
            TotalCurrency 120

            TFBot
            {
                Template T_TFBot_Skeleton_Easy
                Name "Minigun Skeleton"
                Class Heavy
                ClassIcon heavy
                Health 300
                Skill Easy
                WeaponRestrictions PrimaryOnly

                UseHumanAnimations 1

                Item "Officer's Ushanka"
                Item "Bone-Cut Belt"
            }
        }
    }
}