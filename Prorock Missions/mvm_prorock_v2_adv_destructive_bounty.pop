	//// WAVES ////

	// General Notes
	// No fixed respawn time, set time to 2
	// Remove increased bot limit, not necessary at all

	// Wave 1 Notes
	// Whip soldiers & loch demos probably taken out
	// Heavies turned into projectile bots to make better gameplay in the outside
	// Take out engies
	Wave
	{
		WaitWhenDone	65
		Checkpoint	Yes
		StartWaveOutput
