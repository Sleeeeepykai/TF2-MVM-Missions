        }

        // Wave End Sequence
        WaveSpawn // Wave End Preventer
        {
            Name "Wave1_DummyBot"
            WaitForAllSpawned "Wave1_Subwave3_ChampionSoldier"
            Where spawnbot_e
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 0

            Squad
            {
                Squad
                {
                    TFBot
                    {
                        Name "Jimbo"
                        Template T_TFBot_Demoman_Knight
                    }
                }
            }
        }
        WaveSpawn // Transition Annotation
        {
            Name "Wave1_Transition"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 5

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        SendGlobalGameEvent(`show_annotation`, {
                            WorldPosX = -160
                            WorldPosY = -448
                            WorldPosZ = 1952
                            id = `MasterTransition`
                            text = `Reality is breaking at the seams...`
                            lifetime = 5
                            play_sound = `ambient/levels/citadel/strange_talk9.wav`
                        })
                      "
            }
        }
        WaveSpawn // Transition Sound
        {
            Name "Wave1_Transition"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 7

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`master_transition_shake`, `StartShake`)

                        EmitSoundEx({
                            sound_name = `weapons/bottlehit1.wav`
                            channel = 6
                            volume = 1
                            pitch = 75
                            special_dsp = 7
                            filter_type = 5
                        })
                      "
            }
        }
        WaveSpawn // Transition Sound
        {
            Name "Wave1_Transition2"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 8

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`master_transition_shake`, `StartShake`)

                        EmitSoundEx({
                            sound_name = `weapons/bottlehit3.wav`
                            channel = 6
                            volume = 1
                            pitch = 75
                            special_dsp = 7
                            filter_type = 5
                        })
