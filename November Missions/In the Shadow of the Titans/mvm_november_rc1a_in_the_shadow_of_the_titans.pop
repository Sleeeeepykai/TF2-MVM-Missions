            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EmitSoundEx({
                            sound_name = `vo/mvm/mght/soldier_mvm_m_dominationengineer03.mp3`
                            channel = 6
                            volume = 1
                            pitch = 85
                            special_dsp = 22
                            filter_type = 5
                        })
                        EmitSoundEx({
                            sound_name = `vo/mvm/mght/soldier_mvm_m_dominationengineer03.mp3`
                            channel = 6
                            volume = 1
                            pitch = 85
                            special_dsp = 22
                            filter_type = 5
                        })
                      "
            }
        }

        WaveSpawn // Champion Giant Tutorial
        {
            Name "Wave1_Subwave3_ChampionTutorial"
            WaitForAllSpawned "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 5

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        SendGlobalGameEvent(`show_annotation`, {
                            WorldPosX = -2400
                            WorldPosY = -352
                            WorldPosZ = 496
                            id = `MasterTutorial`
                            text = `Champion Robots will instantly capture the point! Don't let them reach it!`
                            lifetime = 5
                            play_sound = `ui/hint.wav`
                        })
                      "
            }
        }

        WaveSpawn // 2 Soldiers and 2 Full-Uber Medics
        {
            Name "Wave1_Subwave3_Soldiers"
            WaitForAllSpawned "Wave1_Subwave3_ChampionSoldier"
            Where spawnbot_e
            TotalCount 4
            MaxActive 3
            SpawnCount 2
            WaitBeforeStarting 10
            WaitBetweenSpawns 8
            TotalCurrency 20

            Squad
            {
                TFBot
                {
                    Class Soldier
                    Skill Expert
                    Attributes IgnoreFlag
                    BehaviorModifiers Push
                    Tag capbot
                }
                TFBot
                {
                    Template T_TFBot_Medic_Uber
                }
            }
        }
        WaveSpawn // 2 Soldiers and 2 Full-Uber Medics
        {
            Name "Wave1_Subwave3_Soldiers"
            WaitForAllSpawned "Wave1_Subwave3_ChampionSoldier"
            Where spawnbot_e
