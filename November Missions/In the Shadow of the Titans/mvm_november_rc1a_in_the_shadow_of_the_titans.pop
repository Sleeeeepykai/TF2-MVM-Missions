        }
        WaveSpawn // Transition Sound
        {
            Name "Wave1_Transition3"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 9

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`master_transition_shake`, `StartShake`)

                        EmitSoundEx({
                            sound_name = `weapons/bottlehit2.wav`
                            channel = 6
                            volume = 1
                            pitch = 75
                            special_dsp = 7
                            filter_type = 5
                        })
                      "
            }
        }

        WaveSpawn // Transition Sequence
        {
            Name "Wave1_FullTransition"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 10

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`master_transition_fade`, `Fade`)
                        EntFire(`env_soundscape*`, `AddOutput`, `soundscape November.Void`)
                        SetSkyboxTexture(`sky_lust_02`)

                        EmitSoundEx({
                            sound_name = `physics/glass_sheet_break2.wav`
                            channel = 6
                            volume = 1
                            pitch = 75
                            special_dsp = 7
                            filter_type = 5
                        })
                        EmitSoundEx({
                            sound_name = `ambient/explosions/explode_1.wav`
                            channel = 6
                            volume = 1
                            pitch = 75
                            special_dsp = 7
                            filter_type = 5
                        })
                      "
            }
        }

        WaveSpawn
        {
            Name "Wave1_TransitionComplete"
            WaitForAllDead "Wave1_Subwave3_ChampionSoldier"
            WaitBeforeStarting 15

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        ::MaxPlayers <- MaxClients().tointeger()

                        for (local i = 1; i <= MaxPlayers; i++)
                        {
                            local Player = PlayerInstanceFromIndex(i)
                            if (Player == null)
                                continue

                            if ((Player.GetTeam()) == 3)
                            {
                                Player.TakeDamage(99999, 0, null)
                            }
                        }
                      "
            }
        }
    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    IncludeScript(`mvm_november_master_script`, getroottable())
                    MVMNovember_MasterScripting.NovemberMasterInit()

                    SetSkyboxTexture(`sky_lust_02`)
                    EntFire(`env_soundscape*`, `AddOutput`, `soundscape November.Void`)

