            Where spawnbot_flank_a
            TotalCount 3
            MaxActive 3
            SpawnCount 3
            WaitBeforeStarting 7
            WaitBetweenSpawns 0
            TotalCurrency 60

            Squad
            {
                NoWaitForFormation 1 [$SIGSEGV]

                TFBot
                {
                    Template T_TFBot_Giant_Soldier_Burst
                    Attributes IgnoreFlag
					BehaviorModifiers Push
					Tag capbot
                }
                TFBot
                {
                    Class Demoman
                    Skill Expert
                    Attributes IgnoreFlag
					BehaviorModifiers Push
