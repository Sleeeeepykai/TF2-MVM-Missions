        // Wave End Sequence
        WaveSpawn // Transition Annotation
        {
            Name "Wave2_Transition"
            WaitForAllSpawned "Wave2_CompleteCheck"
            WaitBeforeStarting 0

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`populator`, `$KillWaveSpawn`, `Wave2_SupportSpies`)
                        EntFire(`populator`, `$FinishWaveSpawn`, `Wave2_SupportSpies`)

                        PrecacheSound(`ambient/levels/citadel/strange_talk9.wav`)

                        SendGlobalGameEvent(`show_annotation`, {
                            WorldPosX = -160
                            WorldPosY = -448
                            WorldPosZ = 1952
                            id = `MasterTransition`
                            text = `Reality is breaking at the seams...`
                            lifetime = 5
                            play_sound = `ambient/levels/citadel/strange_talk9.wav`
                        })
                      "
            }
        }
        WaveSpawn // Transition Sound
        {
            Name "Wave2_Transition"
            WaitForAllSpawned "Wave2_CompleteCheck"
            WaitBeforeStarting 5

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EntFire(`master_transition_shake`, `StartShake`)
                        PrecacheSound(`weapons/bottle_hit1.wav`)

                        EmitSoundEx({
                            sound_name = `weapons/bottle_hit1.wav`
                            channel = 6
                            volume = 1
                            pitch = 100
                            special_dsp = 7
                            filter_type = 5
                        })
                      "
            }
        }
