#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop

WaveSchedule
{
    StartingCurrency 0
    RespawnWaveTime 1
    FixedRespawnWaveTime Yes
    CanBotsAttackWhileInSpawnRoom No
    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

    WaveStartCountdown 7

    ForceRedMoney 1

    //// RESTRICTIONS ////

    ClassLimit
	{
		Medic 0
	}

    //// DISABLED SOUNDS ////

    DisableSound "Announcer.MVM_Wave_End"
    DisableSound "Announcer.MVM_Final_Wave_End"	
	DisableSound "Announcer.MVM_Bonus"
    DisableSound "Announcer.MVM_Get_To_Upgrade"
    DisableSound "Announcer.MVM_All_Dead"
    DisableSound "Announcer.MVM_Wave_Lose"

    DisableSound "music.mvm_start_wave"
    DisableSound "music.mvm_start_mid_wave"
    DisableSound "music.mvm_start_tank_wave"
    DisableSound "music.mvm_start_last_wave"					   						   
    DisableSound "music.mvm_end_wave"
    DisableSound "music.mvm_end_tank_wave"
    DisableSound "music.mvm_end_mid_wave"
    DisableSound "music.mvm_end_last_wave"						   
    DisableSound "music.mvm_lost_wave"					   	   

    //// PRECACHES ////

    // Precached Skybox //

    PrecacheGeneric "sky_void_01bk.vmt"
    PrecacheGeneric "sky_void_01bk.vtf"
    PrecacheGeneric "sky_void_01dn.vmt"
    PrecacheGeneric "sky_void_01dn.vtf"
    PrecacheGeneric "sky_void_01ft.vmt"
    PrecacheGeneric "sky_void_01ft.vtf"
    PrecacheGeneric "sky_void_01lf.vmt"
    PrecacheGeneric "sky_void_01lf.vtf"
    PrecacheGeneric "sky_void_01rt.vmt"
    PrecacheGeneric "sky_void_01rt.vtf"
    PrecacheGeneric "sky_void_01up.vmt"
    PrecacheGeneric "sky_void_01up.vtf"

    // Precached Soundscape //

    PrecacheGeneric "scripts/soundscapes_mvm_november_rc1a.txt"

    //// ROBOT TEMPLATES ////
    
    Templates
    {
        T_TFBot_Giant_Soldier_Champion
        {
            Name "Champion Soldier"
            Class Soldier
            ClassIcon soldier_champion_kai
            Skill Expert
            Health 7600
            Scale 1.8
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes HoldFireUntilFullReload
            WeaponRestrictions PrimaryOnly

            Tag ChampionGiant

            Item "Prince Tavish's Crown"
            Item "Forgotten King's Pauldrons"
            
            CharacterAttributes
            {
                "move speed penalty" 0.4
                "damage force reduction" 0.1
                "airblast vulnerability multiplier" 0.1
                "override footstep sound set" 3
            }

            ItemAttributes
            {
                ItemName "TF_WEAPON_ROCKETLAUNCHER"
                "damage bonus" 1.5
                "fire rate bonus" 0.3
                "faster reload rate" 0.1
                "clip size upgrade atomic" 4
                "projectile speed decreased" 0.9
            }
        }
        T_TFBot_Giant_Demoman_Champion
        {
            Name "Champion Demoman"
            Class Demoman
            ClassIcon demo_champion_kai
            Skill Expert
            Health 6600
            Scale 1.8
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes HoldFireUntilFullReload
            WeaponRestrictions PrimaryOnly

            Tag ChampionGiant

            Item "Prince Tavish's Crown"
            Item "Forgotten King's Pauldrons"

            CharacterAttributes
            {
                "move speed penalty" 0.4
                "damage force reduction" 0.1
                "airblast vulnerability multiplier" 0.1
                "override footstep sound set" 4
            }

            ItemAttributes
            {
                ItemName "TF_WEAPON_GRENADELAUNCHER"
                "damage bonus" 1.5
                "mult projectile count" 4
                "projectile spread angle penalty" 3
                "faster reload rate" 0.5
            }
        }
        T_TFBot_Giant_Pyro_Champion
        {
            Name "Champion Pyro"
            Class Pyro
            ClassIcon pyro_champion_kai
            Skill Expert
            Health 6000
            Scale 1.8
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes HoldFireUntilFullReload
            WeaponRestrictions PrimaryOnly

            MaxVisionRange 1200

            Tag ChampionGiant

            Item "Prince Tavish's Crown"
            Item "Forgotten King's Pauldrons"

            Item "The Dragon's Fury"

            CharacterAttributes
            {
                "move speed penalty" 0.5
                "damage force reduction" 0.1
                "airblast vulnerability multiplier" 0.1
                "override footstep sound set" 6
            }

            ItemAttributes
            {
                ItemName "The Dragon's Fury"
                "damage bonus" 1.75
                "afterburn duration bonus" 3
                "mult_item_meter_charge_rate" 1.25
            }
        }
        T_TFBot_Giant_Heavy_Champion
        {
            Name "Champion Heavy"
            Class Heavy
            ClassIcon heavy_champion_kai
            Skill Expert
            Health 10000
            Scale 1.8
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Attributes HoldFireUntilFullReload
            WeaponRestrictions PrimaryOnly

            MaxVisionRange 1200

            Tag ChampionGiant

            Item "Prince Tavish's Crown"
            Item "Forgotten King's Pauldrons"

            CharacterAttributes
            {
                "move speed penalty" 0.3
                "damage force reduction" 0.1
                "airblast vulnerability multiplier" 0.1
                "override footstep sound set" 2
            }

            ItemAttributes
            {
                ItemName "TF_WEAPON_MINIGUN"
                "damage bonus" 1.5
                "weapon spread bonus" 0.75
            }
        }

        T_TFBot_Heavy_Rocketeer
        {
            Name "Rocketeer Heavy"
            Class Heavy
            ClassIcon heavy_rocket
            Skill Expert
            AimAt Body
            AimOffset "0 0 20"

            ItemAttributes
            {
                ItemName "TF_WEAPON_MINIGUN"
                "damage bonus" 5
                "fire rate penalty" 3
                "override projectile type" 2
                "mini rockets" 1
                "spread offset pattern" "22 0 -27"
            }
        }
        T_TFBot_Pyro_Flaregun_Burst
        {
            Name "Burst Flare Pyro"
            Class Pyro
            ClassIcon pyro_flare_burst_nys
            Skill Hard
            Health 500
            Scale 1.3
            WeaponRestrictions SecondaryOnly
            
            Item "The Flare Gun"

            ItemAttributes
            {
                ItemName "The Flare Gun"

                "mult projectile count" 3
                "projectile spread angle penalty" 1
            }
        }
        T_TFBot_Giant_Pyro_Homewrecker
        {
			Name "Giant Homewrecker Pyro"
			Class Pyro
			ClassIcon pyro_homewrecker_lite_giant
			Skill Expert
			Health 3000
			Attributes MiniBoss
			WeaponRestrictions MeleeOnly

            Item "The Homewrecker"

			CharacterAttributes
			{
				"move speed penalty" 0.75
				"damage force reduction" 0.6
				"airblast vulnerability multiplier" 0.6
				"override footstep sound set" 6
			}
            ItemAttributes
            {
                ItemName "The Homewrecker"

                "dmg bonus vs buildings" 5
            }
        }
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_sentrybuster_a
        Where spawnbot_sentrybuster_b
        Where spawnbot_sentrybuster_c
        Where spawnbot_sentrybuster_d
        Where spawnbot_sentrybuster_e
		BeginAtWave 1
		RunForThisManyWaves 10
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}

    // General Design Notes

    // More minigiants in general, having slower but bulkier robots will help the master difficulty
    // Champions could do 100% damage bonus to live up to their name (Trying out 50% for now)
    // Burst fire patterns and high burst DPS are generally more effective at punishing turtling
    // Stand-in Tanks :)

    //// WAVES ////

    // Notes for Wave 1
    //
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    NetProps.SetPropString(Entities.FindByClassname(null, `tf_objective_resource`), `m_iszMvMPopfileName`, `In the Wake of the Titans`)

                    IncludeScript(`mvm_november_master_script`, getroottable())
                    MVMNovember_MasterScripting.NovemberMasterInit()

                    EntFire(`advexp_spawn_ab_relay`, `Trigger`)
                    EntFire(`spawn_a_arrows_flank_enable`, `Disable`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

        WaveSpawn // Tutorial
        {
            Name "Wave1_Tutorial"
            WaitBeforeStarting 0

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        SendGlobalGameEvent(`show_annotation`, {
                            WorldPosX = -160
                            WorldPosY = -448.5
                            WorldPosZ = 212
                            id = `MasterTutorial`
                            text = `The Facility's been sabotaged! Capture Time shortened!`
                            lifetime = 5
                            play_sound = `ui/hint.wav`
                        })
                      "
            }
        }

		// Subwave 1
		WaveSpawn // 2 Demomen and 2 Full-Uber Medics
		{
			Name "Wave1_Subwave1_DemoSquads"
			WaitForAllSpawned "Wave1_Tutorial"
			Where spawnbot_a
			TotalCount 4
			MaxActive 4
			SpawnCount 4
			WaitBeforeStarting 5
			WaitBetweenSpawns 0
			TotalCurrency 40

			Squad
			{
				TFBot
				{
					Class Demoman
					Skill Expert
					Attributes IgnoreFlag
					BehaviorModifiers Push
					Tag capbot
				}
				TFBot
				{
					Template T_TFBot_Medic_Uber
				}
			}
		}
		WaveSpawn // 6 Soda Popper Scouts
		{
			Name "Wave1_Subwave1_SodaScouts"
			WaitForAllSpawned "Wave1_Tutorial"
			Where spawnbot_b
			TotalCount 6
			MaxActive 6
			SpawnCount 3
			WaitBeforeStarting 5
			WaitBetweenSpawns 2
			TotalCurrency 10

			TFBot
			{
				Template T_TFBot_Scout_Popper
                Attributes IgnoreFlag
				BehaviorModifiers Push
				Tag capbot
			}
		}
        WaveSpawn // 2 Shortstop Scouts
		{
			Name "Wave1_Subwave1_ShortstopScouts"
			WaitForAllSpawned "Wave1_Tutorial"
			Where spawnbot_b
			TotalCount 2
			MaxActive 2
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 2
			TotalCurrency 10

			TFBot
			{
				Template T_TFBot_Scout_Shortstop
                Health 500
                Attributes IgnoreFlag
				BehaviorModifiers Push
				Tag capbot
			}
		}

        WaveSpawn // 2 Demomen and 2 Full-Uber Medics
		{
			Name "Wave1_Subwave1_DemoSquads2"
			WaitForAllSpawned "Wave1_Subwave1_DemoSquads"
			Where spawnbot_a
			TotalCount 4
			MaxActive 4
			SpawnCount 4
			WaitBeforeStarting 4
			WaitBetweenSpawns 0
			TotalCurrency 40

			Squad
			{
				TFBot
				{
					Class Demoman
					Skill Expert
					Attributes IgnoreFlag
					BehaviorModifiers Push
