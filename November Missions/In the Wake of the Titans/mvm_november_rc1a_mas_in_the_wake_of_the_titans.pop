			{
				TFBot
				{
					Template T_TFBot_Demoman_Stickybomb
					Attributes IgnoreFlag
					BehaviorModifiers Push
					Tag capbot
				}
				TFBot
				{
					Template T_TFBot_Medic_Uber
				}
			}
        }
        WaveSpawn // 1 Sticky Demo and 1 Full-Uber Medic
        {
            Name "Wave1_Subwave2_DemoSquads"
