            WaitForAllDead "Wave5_Subwave2_SteelGauntlets"
        }

        // Subwave 3
        WaveSpawn // 1 Champion Soldier
        {
            Name "Wave5_Subwave3_ChampionSoldier"
            WaitForAllSpawned "Wave5_Subwave2_Check"
            Where spawnbot_c
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 0
            TotalCurrency 20

            TFBot
            {
                Template T_TFBot_Giant_Soldier_Champion
                Attributes IgnoreFlag
                BehaviorModifiers Push
                Tag capbot
            }

            FirstSpawnOutput
            {
                Target BigNet
                Action RunScriptCode
                Param "
                        EmitSoundEx({
                            sound_name = `vo/mvm/mght/soldier_mvm_m_specialcompleted05.mp3`
                            channel = 6
                            volume = 1
                            pitch = 90
                            special_dsp = 22
                            filter_type = 5
                        })
                        EmitSoundEx({
                            sound_name = `vo/mvm/mght/soldier_mvm_m_specialcompleted05.mp3`
                            channel = 6
                            volume = 1
                            pitch = 90
                            special_dsp = 22
                            filter_type = 5
                        })
                      "
            }
        }
        WaveSpawn // 1 GBuff Soldier
        {
            Name "Wave5_Subwave3_GBuffSoldier"
            WaitForAllSpawned "Wave5_Subwave3_ChampionSoldier"
            Where spawnbot_c
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 10

            TFBot
            {
                Template T_TFBot_Giant_Soldier_Extended_Buff_Banner
                Attributes IgnoreFlag
                BehaviorModifiers Push
                Tag capbot
            }
        }
        WaveSpawn // 1 GConch Soldier
        {
            Name "Wave5_Subwave3_GConchSoldier"
            WaitForAllSpawned "Wave5_Subwave3_ChampionSoldier"
            Where spawnbot_c
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 10

            TFBot
            {
                Template T_TFBot_Giant_Soldier_Extended_Concheror
                Attributes IgnoreFlag
                BehaviorModifiers Push
                Tag capbot
            }
        }

        WaveSpawn // 4 Heavies and 8 Loch Demos
        {
            Name "Wave5_Subwave3_LochDemos"
            WaitForAllSpawned "Wave5_Subwave3_ChampionSoldier"
            Where spawnbot_c
            TotalCount 12
            MaxActive 6
            SpawnCount 3
            WaitBeforeStarting 5
            WaitBetweenSpawns 3
            TotalCurrency 20

            Squad
            {
                TFBot
                {
                    Class Heavy
                    Skill Easy
                    Attributes IgnoreFlag
                    BehaviorModifiers Push
                    Tag capbot
                }
                TFBot
                {
                    Template T_TFBot_Demoman_LochnLoad
                    Attributes IgnoreFlag
                    BehaviorModifiers Push
                    Tag capbot
                }
                TFBot
                {
                    Template T_TFBot_Demoman_LochnLoad
                    Attributes IgnoreFlag
                    BehaviorModifiers Push
                    Tag capbot
                }
            }
        }
        WaveSpawn // 6 Heavies
        {
            Name "Wave5_Subwave3_Heavies"
            WaitForAllSpawned "Wave5_Subwave3_ChampionSoldier"
            Where spawnbot_d
            TotalCount 6
            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 5
            WaitBetweenSpawns 4
            TotalCurrency 10

            TFBot
            {
                Class Heavy
                Skill Easy
                Attributes IgnoreFlag
                BehaviorModifiers Push
                Tag capbot
            }
        }
        WaveSpawn // 4 Shortstop Scouts
        {
            Name "Wave5_Subwave3_ShortstopScouts"
            WaitForAllSpawned "Wave5_Subwave3_ChampionSoldier"
            Where spawnbot_d
            TotalCount 4
            MaxActive 3
            SpawnCount 1
            WaitBeforeStarting 5
            WaitBetweenSpawns 3
            TotalCurrency 10
            
            TFBot
            {
                Template T_TFBot_Scout_Shortstop
                Attributes IgnoreFlag
                BehaviorModifiers Push
                Tag capbot
                Tag flankbot
            }
        }
    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    IncludeScript(`mvm_november_master_script`, getroottable())
                    MVMNovember_MasterScripting.NovemberMasterInit()
                    MVMNovember_MasterScripting.NovemberMasterVoidInit()

                    EntFire(`advexp_spawn_cd_relay` `Trigger`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }        
    }
