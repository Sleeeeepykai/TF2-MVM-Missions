            }
        }
    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`advexp_spawn_ad_relay` `Trigger`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

        // Subwave 1
        WaveSpawn // 1 GDemo and 2 Pyros
        {
            Name "Wave2_Subwave1_GDemo"
            Where spawnbot_d
            TotalCount 3
            MaxActive 3
            SpawnCount 3
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 40

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Demoman_Spammer
                }
                TFBot
                {
                    Class Pyro
                    Skill Expert
                    
                    Item "Traffic Cone"
                }
                TFBot
                {
                    Class Pyro
                    Skill Expert
                    
                    Item "Traffic Cone"
                }
            }
        }
        WaveSpawn // 16 Scouts
        {
            Name "Wave2_Subwave1_Scouts"
            WaitForAllSpawned "Wave2_Subwave1_GDemo"
            Where spawnbot_d
            TotalCount 16
            MaxActive 8
            SpawnCount 4
            WaitBeforeStarting 0
            WaitBetweenSpawns 5
            TotalCurrency 20

            TFBot
            {
                Class Scout
                Skill Easy
            }
        }

        WaveSpawn // 12 Flare Pyros
        {
            Name "Wave2_Subwave1_FlarePyros"
            WaitForAllSpawned "Wave2_Subwave1_GDemo"
            Where spawnbot_a
            TotalCount 12
            MaxActive 8
            SpawnCount 6
            WaitBeforeStarting 0
            WaitBetweenSpawns 10
            TotalCurrency 20
            
            TFBot
            {
                Template T_TFBot_Pyro_Flaregun
            }
        }
        WaveSpawn // 5 Steel Gauntlets
        {
            Name "Wave2_Subwave1_SteelGauntlets"
            WaitForAllSpawned "Wave2_Subwave1_GDemo"
            Where spawnbot_flank_a
            TotalCount 5
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 4
            TotalCurrency 20

            TFBot
            {
                Template T_TFBot_Heavy_SteelFist
            }
        }
    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`advexp_spawn_bc_relay` `Trigger`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
