// Bloodmoon Mission: Cast-Iron Calamity (By Sleeeepykai, in collaboration with Sergeant Table & Snurper Bob)

// Credits:
// Sleeeepykai: Lead Mission Dev
// Sergeant Table: [TBD]
// Snurper Bob: [TBD]
// Reudina: Vortex Models (Bleached them for correct colouring)
// Bazooks: Educating me on making the custom halo in Blender
// CTriggerHurt: Enhanced Medic Model with Legs (For Final Boss)

// Robot Spawns: spawnbot, spawnbot_left, spawnbot_right, spawnbot_flank, spawnbot_invasion, spawnbot_arena, spawnbot_boss

// Starting Cash: $2,000
// Endurance Wave Payout: $4,000
// Endurance Phase 1 Payout: $1,250
// Endurance Phase 2 Payout: $1,250
// Endurance Phase 3 Payout: $1,500

#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 2000
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom no
	WaveStartCountdown 3
	TextPrintTime 10
	NoCritPumpkin 1

	AddSentryBusterWhenDamageDealtExceeds 3000
	AddSentryBusterWhenKillCountExceeds 10

	// Soldier Miniboss Voicelines
	PrecacheSound "freeze_cam/soldierapostleboss_battlecry.wav"
	PrecacheSound "freeze_cam/soldierapostleboss_death.wav"

	// Sniper Miniboss Voicelines
	PrecacheSound "freeze_cam/sniperacolyteboss_battlecry.wav"
	PrecacheSound "freeze_cam/sniperacolyteboss_death.wav"

	// Scout Miniboss Voicelines
	PrecacheSound "freeze_cam/scoutdiscipleboss_battlecry.wav"
	PrecacheSound "freeze_cam/scoutdiscipleboss_death.wav"

	// Heavy Mainboss Voicelines
	PrecacheSound "freeze_cam/heavydeaconboss_battlecry.wav"
	PrecacheSound "freeze_cam/heavydeaconboss_berserk.wav"
	PrecacheSound "freeze_cam/heavydeaconboss_death.wav"

	// Demo Mainboss Voicelines
	PrecacheSound "freeze_cam/demoecclesiasticboss_battlecry.wav"
	PrecacheSound "freeze_cam/demoecclesiasticboss_grenade.wav"
	PrecacheSound "freeze_cam/demoecclesiasticboss_death.wav"

	// Pyro Mainboss Voicelines
	PrecacheSound "freeze_cam/pyroarchbishopboss_battlecry.wav"
	PrecacheSound "freeze_cam/pyroarchbishopboss_callforhelp.wav"
	PrecacheSound "freeze_cam/pyroarchbishopboss_death.wav"
	
	// Vortex Models
	PrecacheModel "models/reudina/vortex_reu.mdl"
	PrecacheModel "models/reudina/wof_reu.mdl"
	
	// Halo Model
	PrecacheModel "models/cast_iron_calamity/hallowed_halo.mdl"

	// Combat Tank Models
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_combat_tank_chassis.mdl"
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_minigun.mdl"
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_fireball.mdl"

	// Colour Correction
	PrecacheGeneric "materials/colorcorrection/divineaurafarming.raw"

    Templates
    {
        T_TFBot_Soldier_ApostleBoss
        {
            Class Soldier
            Name "Apostle of Modesty"
            ClassIcon soldier_barrage_infinity
            Health 17500
            Scale 2
            Skill Expert
            WeaponRestrictions PrimaryOnly
            Attributes MiniBoss
            Attributes HoldFireUntilFullReload
            Attributes UseBossHealthBar

			SpawnTemplate HaloGlow

            Item "The Hardy Laurel"
			Item "The Diplomat"
			Item "The Man in Slacks"
			Item "Potato of Labor"

			ItemModel
			{
				ItemName "Potato of Labor"
				Model "models/cast_iron_calamity/hallowed_halo.mdl"
			}

            CharacterAttributes
            {
                "damage bonus" 1.0
                "projectile speed increased" 0.4
                "move speed bonus" 0.5
                "damage force reduction" 0.4
                "airblast vulnerability multiplier" 0.4
                "airblast vertical vulnerability multiplier" 0.4
                "override footstep sound set" 3
            }
            ItemAttributes
            {
                ItemName "TF_WEAPON_ROCKETLAUNCHER"
                "clip size upgrade atomic" 26.0
                "faster reload rate" -1
                "fire rate bonus" 0.2
                "projectile spread angle penalty" 5
            }

            FireInput // Battlecry Voiceline
            {
                Target Player
                Action $PlaySoundtoSelf
                Param "freeze_cam/soldierapostleboss_battlecry.wav"
                Delay 0.25
                Repeats 2
                Cooldown -1
            }
            FireInput // Death Voiceline
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/soldierapostleboss_death.wav"
				Delay 0.25
				Repeats 2
                Cooldown -1
				IfHealthBelow 1500
			}
        }
        
        T_TFBot_Heavy_DeaconBoss
        {
            Class Heavy
            Name "Deacon of Diligence"
            ClassIcon heavy_brass_armored_nys
            Health 25000
            Scale 2
            Skill Expert
            WeaponRestrictions MeleeOnly
            Attributes MiniBoss
            Attributes UseBossHealthBar

			SpawnTemplate HaloGlow

            Item "The Brass Beast"
            Item "Fists of Steel"

            Item "The Hardy Laurel"
            Item "Batter's Bracers"
            Item "The Mann of the House"
            Item "Siberian Tigerstripe"
			Item "Potato of Labor"

			ItemModel
			{
				ItemName "Potato of Labor"
				Model "models/cast_iron_calamity/hallowed_halo.mdl"
			}

            CharacterAttributes
            {
                "move speed bonus" 0.5
                "damage force reduction" 0.3
                "airblast vulnerability multiplier" 0.3
                "override footstep sound set" 2
                "cannot pick up intelligence" 1
            }
            Addcond
            {
                Index 19
                Duration -1
            }

            ItemAttributes
            {
                ItemName "The Brass Beast"
                "damage bonus" 1.5
            }
            ItemAttributes
            {
                ItemName "Fists of Steel"
                "melee attack rate bonus" 0.8
            }

            EventChangeAttributes
            {
                BerserkPhase
                {
                    WeaponRestrictions PrimaryOnly
                    ActionOverride FetchFlag

                    CharacterAttributes
                    {
                        "cannot pick up intelligence" 0
                    }
                    FireInput
                    {
                        Target Player
                        Action $SetProp$m_iszClassIcon
                        Param heavy_brass_nys_giant
                        Delay 0.25
                        Repeats 1
                        Cooldown -1
                    }
                    FireInput
                    {
                        Target !Self
                        Action $Removecond
                        Param 19
                        Delay 0.25
                        Repeats 1
                        Cooldown -1
                    }
                }
            }

            FireInput // Battlecry
            {
                Target Player
                Action $PlaySoundtoSelf
                Param "freeze_cam/heavydeaconboss_battlecry.wav"
                Delay 0.25
                Repeats 3
                Cooldown -1
            }
            FireInput // Change Icon to Punchie
            {
                Target Player
                Action $SetProp$m_iszClassIcon
                Param heavy_steelfist
                Delay 0.25
                Repeats 1
                Cooldown -1
            }
            FireInput // Berserker Phase Voiceline
            {
                Target Player
                Action $PlaySoundtoSelf
                Param "freeze_cam/heavydeaconboss_berserk.wav"
                Delay 0.25
                Repeats 3
                Cooldown -1
                IfHealthBelow 12500
            }
            FireInput // Berserker Phase Visual Warning
            {
                Target Player
                Action $SetProp$m_iszClassIcon
                Param heavy_brass_armored_hyper_nys
                Delay 0.25
                Repeats 1
                Cooldown -1
                IfHealthBelow 12500
            }
            FireInput // Berserker Phase Audio Warning
            {
                Target Player
                Action $PlaySoundtoSelf
                Param "mvm/mvm_cpoint_klaxon.wav"
                Delay 0.25
                Repeats 1
                Cooldown -1
                IfHealthBelow 12500
            }
            FireInput // Berserker Phase Change
			{
				Target !Self
				Action $ChangeAttributes
				Param BerserkPhase
				Delay 1.5
				Repeats 1
				Cooldown -1
				IfHealthBelow 12500
			}
            FireInput // Death Voiceline
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/heavydeaconboss_death.wav"
				Delay 0.25
				Cooldown -1
				Repeats 3
				IfHealthBelow 1500
			}
        }

        T_TFBot_Sniper_AcolyteBoss
        {
            Class Sniper
            Name "Acolyte of Reticence"
            ClassIcon sniper_armored
            Health 25000
            Scale 2
            Skill Expert
            UseCustomModel "models/bots/sniper_boss/bot_sniper_boss.mdl"
            WeaponRestrictions PrimaryOnly
            MaxVisionRange 2500
            Attributes MiniBoss
            Attributes UseBossHealthBar
            Action Sniper

			SpawnTemplate HaloGlow

            Item "The AWPer Hand"

            Item "The Hardy Laurel"
            Item "Starduster"
            Item "The Triggerman's Tacticals"
            Item "The Teufort Tooth Kicker"
			Item "Potato of Labor"

			ItemModel
			{
				ItemName "Potato of Labor"
				Model "models/cast_iron_calamity/hallowed_halo.mdl"
			}

            CharacterAttributes
            {
                "move speed bonus" 0.4
                "damage force reduction" 0.6
                "airblast vulnerability multiplier" 0.6
                "override footstep sound set" 5
            }

            ItemAttributes
            {
                ItemName "The AWPer Hand"
                "damage bonus" 1.5
                "faster reload rate" 1.5
            }

            EventChangeAttributes
            {
                BombCarrier
                {
                    Action FetchFlag
                    UseCustomModel "models/bots/sniper_boss/bot_sniper_boss.mdl"
                    ItemAttributes
                    {
                        ItemName "The AWPer Hand"
                        "damage bonus" 1.5
                        "faster reload rate" 1.5
                        "sniper aiming movespeed decreased" 1
                        "no_jump" 1
                    }
                    FireInput // Zoom In
                    {
                        Target !self
                        Action $AddCond
                        Param "1"
                        Delay 0.1
                        Repeats 0
                        Cooldown 1.1
                        IfSeeTarget 1
                    }
                    FireInput // Zoom Out
                    {
                        Target !self
                        Action $RemoveCond
                        Param "1"
                        Delay 1.2
                        Repeats 0
                        Cooldown 1.1
                        IfNoTarget 1
                    }
                    FireWeapon
                    {
                        Delay 1
                        Cooldown 1
                        Repeats 0
                        Duration 0.1
                        Type "Primary" 
                        IfSeeTarget 1
                    }	
                }
            }

            FireInput // Battlecry
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/sniperacolyteboss_battlecry.wav"
				Delay 0.25
				Repeats 3
                Cooldown -1
			}
			FireInput // Death Voiceline
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/sniperacolyteboss_death.wav"
				Delay 0.25
				Repeats 3
                Cooldown -1
				IfHealthBelow 1500
			}
        }

        T_TFBot_Demo_EcclesiasticBoss
        {
            Class Demoman
            Name "Ecclesiastic of Purity"
            ClassIcon demoknight_golden_armored_lite
            Health 30000
            Scale 2
            Skill Expert
            WeaponRestrictions MeleeOnly
            Attributes MiniBoss
            Attributes UseBossHealthBar

			SpawnTemplate HaloGlow

            Item "Ali Baba's Wee Booties"
            Item "The Chargin' Targe"
            Item "The Eyelander"

            Item "The Hardy Laurel"
            Item "The King of Scotland Cape"
            Item "EOTL_demopants"
			Item "Potato of Labor"

			ItemModel
			{
				ItemName "Potato of Labor"
				Model "models/cast_iron_calamity/hallowed_halo.mdl"
			}

            SpawnTemplate DemoBossExplosion

            CharacterAttributes
            {
                "move speed bonus" 0.5
                "damage force reduction" 0.5
                "airblast vulnerability multiplier" 0.5
                "override footstep sound set" 4
            }

            ItemAttributes
            {
                ItemName "The Eyelander"
                "critboost on kill" 3
                "damage bonus" 1.25
                "item style override" 1
                "is australium item" 1
            }

            ItemAttributes
            {
                ItemName "The Chargin' Targe"
                "Attack not cancel charge" 1
                "dmg taken from fire reduced" 1
                "dmg taken from blast reduced" 1
            }

            EventChangeAttributes
            {
                GrenadePhase
                {
                    Item "TF_WEAPON_GRENADELAUNCHER"
                    Item "TF_WEAPON_PIPEBOMBLAUNCHER"
                    WeaponRestrictions PrimaryOnly
                    Attributes HoldFireUntilFullReload

                    ItemAttributes
                    {
                        ItemName "TF_WEAPON_GRENADELAUNCHER"
                        "faster reload rate" 0.22
				        "fire rate bonus" 0.2
				        "clip size upgrade atomic" 26.0
				        "projectile spread angle penalty" 5
				        "Projectile speed increased"	0.5
                    }
                }
                
                NuclearPhaseWarning
                {
                    Item "Ali Baba's Wee Booties"
                    Item "The Tide Turner"
                    Item "The Ullapool Caber"
                    ActionOverride Mobber

                    Addcond
                    {
                        Index 14
                        Duration 5.25
                    }
                    CharacterAttributes
                    {
                        "cannot pick up intelligence" 1
                    }
                }
                NuclearPhaseBoom
                {
                    Item "Ali Baba's Wee Booties"
                    Item "The Tide Turner"
                    Item "The Ullapool Caber"
                    ActionOverride Mobber

                    Addcond
                    {
                        Index 51
                    }

                    ItemAttributes
                    {
                        ItemName "The Tide Turner"
                        "Attack not cancel charge" 1
                    }
                    CharacterAttributes
                    {
                        "charge recharge rate increased" 2
                        "cannot pick up intelligence" 1
                    }

					FireInput
					{
						Target player
						Action $PlaySoundtoSelf
						Param "weapons/det_pack_timer.wav"
						Delay -1
						Cooldown 0.5
						Repeats 3
						IfHealthBelow 1500
					}
					FireInput
					{
						Target demobossexplodequake
						Action StartShake
						Delay 1.9
					}
					FireInput
					{
						Target demobossexplodeeffect
						Action Start
						Delay 1.9
					}
					FireInput
					{
						Target demobossexplodeeffect
						Action Stop
						Delay 6.9
					}
					FireInput
					{
						Target demobossexplodesound
						Action PlaySound
						Delay 1.9
					}
					FireInput
					{
						Target demobossexplodedamage
						Action Enable
						Delay 1.9
					}
					FireInput
					{
						Target demobossexplodedamage
						Action Disable
						Delay 2.2
					}
					FireWeapon
					{
						Delay 1.9
						Cooldown 1.9
						Repeats 0
						Duration 0.5
						Type "Primary"
					}
                    FireInput
					{
						Target Classic_Mode_Intel
						Action ForceReset
						Delay 1.9
						Repeats 1
						Cooldown -1
					}
					FireInput
					{
						Target !Self
						Action $Suicide
						Delay 2
						Cooldown -1
						Repeats 1
					}
                }
            }

            FireInput // Battlecry
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/demoecclesiasticboss_battlecry.wav"
				Delay 0.25
				Cooldown -1
				Repeats 3
			}
			FireInput // Change Icon to Sword
			{
				Target Player
				Action $SetProp$m_iszClassIcon
				Param demoknight_golden_lite
				Delay 0.25
				Repeats 1
				Cooldown -1
			}
			FireInput // Grenade Phase Voiceline
			{
				Target Player
				Action $PlaySoundToSelf
				Param "freeze_cam/demoecclesiasticboss_grenade.wav"
				Delay 0.25
				Cooldown -1
				Repeats 3
				IfHealthBelow 15000
			}
			FireInput // Grenade Phase Visual Warning
			{
				Target Player
				Action $SetProp$m_iszClassIcon
				Param demoknight_golden_armored_hyper_lite
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 15000
			}
			FireInput // Grenade Phase Audio Warning
			{
				Target Player
				Action $PlaySoundToSelf
				Param "mvm/mvm_cpoint_klaxon.wav"
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 15000
			}
			FireInput // Grenade Phase Change
			{
				Target !Self
				Action $ChangeAttributes
				Param GrenadePhase
				Delay 2.5
				Repeats 1
				IfHealthBelow 15000
			}
			FireInput // Death Voiceline
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/demoecclesiasticboss_death.wav"
				Delay 0.25
				Cooldown -1
				Repeats 1
				IfHealthBelow 1500
			}
			FireInput // Nuke Phase Warning Change
			{
				Target !Self
				Action $ChangeAttributes
				Param NuclearPhaseWarn
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 1500
