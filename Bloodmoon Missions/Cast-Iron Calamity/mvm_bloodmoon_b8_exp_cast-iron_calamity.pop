			{
				Target pop_interface
				Action $PauseWavespawn
				Param Wave1P3_PyroMainBossGiantSupport
				Delay 0.25
			}
			FireInput // Support Spawn-In Voiceline
			{
				Target Player
				Action $PlaySoundtoSelf
				Param "freeze_cam/pyroarchbishopboss_callforhelp.wav"
				Delay 0.25
				Repeats 3
				Cooldown -1
				IfHealthBelow 25000
			}
			FireInput // Support Spawn-In Phase Warning
			{
				Target Player
				Action $PlaySoundToSelf
				Param "mvm/mvm_cpoint_klaxon.wav"
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 25000
			}
			FireInput // Support Spawn-In Phase Change
			{
				Target !Self
				Action $ChangeAttributes
				Param SupportCall
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 25000
			}
			FireInput // Magic Overload Phase Warning
			{
				Target Player
				Action $PlaySoundToSelf
				Param "mvm/mvm_cpoint_klaxon.wav"
				Delay 0.25
				Repeats 1
				Cooldown -1
				IfHealthBelow 15000
			}
			FireInput // Magic Overload Phase Change
			{
				Target !Self
				Action $ChangeAttributes
				Param MagicOverload
				Delay 1.5
				Repeats 1
				Cooldown -1
				IfHealthBelow 15000
			}
			FireInput // Death Voiceline
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/pyroarchbishopboss_death.wav"
				Delay 0.25
				Repeats 3
				Cooldown -1
				IfHealthBelow 1500
			}
        }
    }

