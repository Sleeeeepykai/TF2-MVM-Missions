// Bloodlust Mission: Cast-Iron Calamity (By Sleeeepykai, Sergeant Table & Snurper Bob)

// Credits:
// Sleeeepykai: Lead Mission Dev
// Sergeant Table: [TBD]
// Snurper Bob: [TBD]
// Reudina: Vortex Models (Bleached them for correct colouring)
// CTriggerHurt: Enhanced Medic Model with Legs (For Final Boss)

// Robot Spawns: spawnbot, spawnbot_tank, spawnbot_mission_sniper, spawnbot_mission_spy, spawnbot_mission_sentrybuster, spawnbot_underworld, spawnbot_underworld_support

// Starting Cash: $2,500
// Endurance Wave Payout: $3,500
// Endurance Phase 1 Payout: $1,000
// Endurance Phase 2 Payout: $1,250
// Endurance Phase 3 Payout: $1,250

#base robot_standard.pop
#base robot_giant.pop
#base kai_testing_restrictions.pop

WaveSchedule
{
    StartingCurrency 2500
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom no
	WaveStartCountdown 5
	TextPrintTime 10
	NoCritPumpkin 1



	// Music
	PrecacheSound "facing_sinister_divinity.mp3"

	// Soldier Miniboss Voicelines
	PrecacheSound "freeze_cam/soldierapostleboss_battlecry.wav"
	PrecacheSound "freeze_cam/soldierapostleboss_death.wav"

	// Sniper Miniboss Voicelines
	PrecacheSound "freeze_cam/sniperacolyteboss_battlecry.wav"
	PrecacheSound "freeze_cam/sniperacolyteboss_death.wav"

	// Scout Miniboss Voicelines
	PrecacheSound "freeze_cam/scoutdiscipleboss_battlecry.wav"
	PrecacheSound "freeze_cam/scoutdiscipleboss_death.wav"

	// Heavy Mainboss Voicelines
	PrecacheSound "freeze_cam/heavydeaconboss_battlecry.wav"
	PrecacheSound "freeze_cam/heavydeaconboss_berserk.wav"
	PrecacheSound "freeze_cam/heavydeaconboss_death.wav"

	// Demo Mainboss Voicelines
	PrecacheSound "freeze_cam/demoecclesiasticboss_battlecry.wav"
	PrecacheSound "freeze_cam/demoecclesiasticboss_samurai.wav"
	PrecacheSound "freeze_cam/demoecclesiasticboss_death.wav"

	// Pyro Mainboss Voicelines
	PrecacheSound "freeze_cam/pyroarchbishopboss_battlecry.wav"
	PrecacheSound "freeze_cam/pyroarchbishopboss_callforhelp.wav"
	PrecacheSound "freeze_cam/pyroarchbishopboss_death.wav"
	
	// Vortex Models
	PrecacheModel "models/reudina/vortex_reu.mdl"
	PrecacheModel "models/reudina/wof_reu.mdl"

	// Combat Tank Models
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_combat_tank_chassis.mdl"
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_minigun.mdl"
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_fireball.mdl"

	// Colour Correction
	PrecacheGeneric "materials/colorcorrection/divineaurafarming.raw"


	Mission // Sentry Buster
	{
		Objective DestroySentries

		InitialCooldown 30
		Where spawnbot_mission_sentrybuster
		BeginAtWave 1
		RunForThisManyWaves 1

		CooldownTime 30         

        TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}

	Templates
	{
		T_TFBot_SoldierApostleBoss
		{
			Template T_TFBot_Giant_Soldier_SlowBarrage
