					Delay -1
					Repeats 1
					Cooldown -1
				}
				Addcond
				{
					Index 51
					Duration 2
				}
				Addcond
				{
					Index 71
					Duration 2
				}
			}
			DoneOutput
			{
				Target BigNet
				Action runscriptcode
				Param "SINS.ChangeIconFlags(`soldier_burstfire`,0)"
			}	
		}
		WaveSpawn // 1 GBurst on Boss
		{
			Name "Wave1P3_PyroBossGiantSupport2"
			WaitForAllSpawned "Wave1P3_PyroMainBoss"
			Where spawnbot_tank
			Support Limited
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 2
			WaitBetweenSpawns 0
			TotalCurrency 20


			TFBot
			{
				Template T_TFBot_Giant_Soldier_Spammer_Reload

				FireInput
				{
					Target !activator
					Action $TeleportToEntity
					Param TeleportPoint2
					Delay -1
					Repeats 1
					Cooldown -1
				}
				Addcond
				{
					Index 51
					Duration 2
				}
				Addcond
				{
					Index 71
					Duration 2
				}
			}
			DoneOutput
			{
				Target BigNet
				Action runscriptcode
				Param "SINS.ChangeIconFlags(`soldier_burstfire`,0)"
			}	
		}
		
		// ENDURANCE PHASE 3 BREAK

		WaveSpawn
		{
			Name "Wave1P3_Complete"
			WaitForAllDead "Wave1P3_PyroMainBoss"
			WaitBeforeStarting 0

			FirstSpawnOutput
			{
				Target Phase3Completion
				Action Trigger
			}
		}
		WaveSpawn
		{
			Name "Wave1P3_Sequence"
			WaitForAllDead "Wave1P3_PyroMainBoss"
			WaitBeforeStarting 40
		}
	}
	
	// FINAL BOSS WAVE
	Wave
	{
		StartWaveOutput
		{
			Target wave_start_relay
			Action Trigger
		}
	    DoneOutput					
		{
			Target wave_finished_relay
			Action trigger
		}
		InitWaveOutput
        {
            Target BigNet
            Action runscriptcode
            Param "
            IncludeScript(`tankextensions_main`, getroottable())
            IncludeScript(`tankextensions/combattank`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/fireball`, getroottable())
			IncludeScript(`tankextensions/combattank_weapons/minigun`, getroottable())
			IncludeScript(`seel_ins.nut`,getroottable())
			EntFire(`rift*`, `Kill`)
			EntFire(`bloodrift_tutorial`, `Kill`)
			EntFire(`underworld_indicators`, `Kill`)
			EntFire(`env_soundscape`, `Disable`)
            "
        }
	}
}