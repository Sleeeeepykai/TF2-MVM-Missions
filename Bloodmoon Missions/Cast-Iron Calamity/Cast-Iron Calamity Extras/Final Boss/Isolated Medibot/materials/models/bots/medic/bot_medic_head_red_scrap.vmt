VertexLitGeneric
{
	$basetexture models/bots/medic/bot_medic_head
	$bumpmap models/bots/medic/bot_medic_head_normal

	$phong 1
	$phongexponent 20
	$phongboost 4	
	$phongfresnelranges	"[.5 .7 1]"
	$halflambert 0
//	$phongexponenttexture models\bots\classes\demo_bot\demo_bot_head_exp

	$lightwarptexture models\lightwarps\robot_lightwarp

//	$basemapalphaphongmask 1

	$eyedefault				"{242 13 17}"
	$eyecolor				"{0 0 0}"
	$itemtint				"{0 0 0}"
	$playertint				"{0 0 0}"

	$lightwarptexture models\lightwarps\robot_lightwarp

//	$basemapalphaphongmask 1
	
	$rimlight 1
	$rimlightexponent 1
	$rimlightboost 2
	$rimmask 1


	$detail effects/tiledfire/fireLayeredSlowTiled512.vtf	
	$detailscale 5
	$detailblendfactor 0
	$detailblendmode 6

	$yellow 0
	$one 1
	$zero 0

	// Cloaking
	$cloakPassEnabled 1

	// Disallow $color2 from affecting the texture
	$allowdiffusemodulation	0
	$blendtintbybasealpha	1

	Proxies
	{
		spy_invis {}
		AnimatedTexture
		{
			animatedtexturevar $detail
			animatedtextureframenumvar $detailframe
			animatedtextureframerate 30
		}
		BurnLevel
		{
			resultVar $detailblendfactor
		}
		YellowLevel
		{
			resultVar $yellow
		}

		// Make use of the existing ItemTintColor proxy to color the eyes. Currently does not work on players.
		ItemTintColor {
			resultVar $itemtint
		}

		// In case Valve implements it, we also consider this.
		// https://github.com/ValveSoftware/Source-1-Games/issues/6353
		PlayerTintColor {
			resultVar $playertint
		}

		// Decide which to use - If we have a player tint, use it, otherwise default to the item tint.
		SelectFirstIfNonZero {
			srcVar1	$playertint
			srcVar2	$itemtint
			resultVar $eyecolor
		}

		// If either proxy gave us a color, use it here. Otherwise, use this VMT's default eye color.
		SelectFirstIfNonZero {
			srcVar1	$eyecolor
			srcVar2	$eyedefault
			resultVar $color2
		}

		Multiply
		{
			srcVar1		$color2
			srcVar2		$yellow
			resultVar	$color2
		}
	}
}

