	//// ROBOT TEMPLATES ////

	Templates
	{
		T_TFBot_Giant_Pyro_Djinn
		{
			Name "Djinn of the Sandstorm"
			Class Pyro
			ClassIcon pyro
			Skill Expert
			Health 3500
			Attributes MiniBoss
			Attributes SuppressFire
			WeaponRestrictions MeleeOnly

			UseCustomModel "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"

			SpawnTemplate "Djinn_PT"

			Item "The Freedom Staff"

			Item "Pyromancer's Mask"
			Item "Apparition's Aspect"
			Item "Potato of Labor"

			Item "Taunt: Second Rate Sorcery"

			FireWeapon  
			{
				Delay 0
				Type "Primary"
				IfSeeTarget 1
				IfLeftSpawn 1
				Duration 0.5
				Cooldown 1.6
			}

			CharacterAttributes
			{
				"move speed penalty" 0.5
				"damage force reduction" 0.6
				"airblast vulnerability multiplier" 0.6
				"override footstep sound set" 6
				"voice pitch scale" 0
			}

			ItemAttributes
			{
				ItemName "The Freedom Staff"

				"fire input on attack" "DjinnFireball^FireMultiple^1"
				"custom item model" "models/workshop/player/items/all_class/secondrate_sorcery/secondrate_sorcery_pyro.mdl"
				"custom kill icon" "merasmus_decap"
			}
			ItemAttributes
			{
				ItemName "Potato of Labor"

				"custom item model" "models/workshop/player/items/pyro/tw_pyrobot_armor/tw_pyrobot_armor.mdl"
			}

			FireInput
			{
				Target !self
				Action $ChangeAttributes
				Param "DjinnDefault"
				Delay 6
				Repeats 1
				Cooldown -1
			}

			EventChangeAttributes
			{
				DjinnDefault [$SIGSEGV]
				{
					FireInput
					{
						Target !self
						Action $ChangeAttributes
						Param "DjinnSummon"
						Delay 7.5
						Repeats 1
						Cooldown -1
					}
				}
				DjinnSummon [$SIGSEGV]
				{
					FireInput
					{
						Target "DjinnSummonRelay"
						Action Trigger
						Delay 0
						Repeats 1
						Cooldown -1
					}
					FireInput
					{
						Target !self
						Action $ChangeAttributes
						Param "DjinnDefault"
						Delay 3.6
						Repeats 1
						Cooldown -1
					}
				}
			}
		}
		T_TFBot_Giant_Sniper
		{
			Name "Giant Sniper"
			Class Sniper
			ClassIcon sniper_giant
			Skill Expert
			Health 3000
			Attributes MiniBoss
