			// Main Boss Phases //

			logic_relay // Attack Initialiser
			{
				"targetname" "SultanAttackInit"
				
				"OnTrigger" "SultanPhase1AttackPoolRelay,Trigger,,0,-1"
				"OnTrigger" "SultanPhase2AttackPoolRelay,Trigger,,,-1"
				"OnTrigger" "SultanPhase3AttackPoolRelay,Trigger,,0,-1"
			}

			logic_relay // Phase 1 Relay
            {
                "targetname" "SultanPhase1AttackPoolRelay"
                "spawnflags" "2"

                "OnTrigger" "SultanPhase1AttackPool,PickRandomShuffle,,0,-1"
            }
            logic_relay // Phase 2 Relay
            {
                "targetname" "SultanPhase2AttackPoolRelay"
                "spawnflags" "2"
                "startdisabled" "1"

                "OnTrigger" "SultanPhase2AttackPool,PickRandomShuffle,,0,-1"
            }
            logic_relay // Phase 3 Relay
            {
                "targetname" "SultanPhase3AttackPoolRelay"
                "spawnflags" "2"
                "startdisabled" "1"

                "OnTrigger" "SultanPhase3AttackPool,PickRandomShuffle,,0,-1"
            }

			logic_case // Phase 1 Attack Pool
			{
				"targetname" "SultanPhase1AttackPool"

				"OnCase01" "pop_interface,ChangeBotAttributes,SultanFireballRain,0,-1"
				"OnCase02" "pop_interface,ChangeBotAttributes,SultanSummon,0,-1"
				"OnCase03" "pop_interface,ChangeBotAttributes,SultanSendThemToMarianaTrench,0,-1"
			}
			logic_case // Phase 2 Attack Pool
			{
				"targetname" "SultanPhase2AttackPool"

				"OnCase01" "pop_interface,ChangeBotAttributes,SultanSummon,0,-1"
				"OnCase02" "pop_interface,ChangeBotAttributes,SultanSendThemToMarianaTrench,0,-1"
			}

