	// Wave 4 Notes
	// Can probably salvage the giant config
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_left_relay`, `Trigger`, null, 6.1)

					IncludeScript(`tankextensions_main`, getroottable())
                    IncludeScript(`tankextensions/combattank`, getroottable())
                    IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())

					TankExt.SetValueOverrides({
						COMBATTANK_ROCKETPOD_ROCKET_DAMAGE = 30
						COMBATTANK_ROCKETPOD_FIRE_DELAY = 0.2
						COMBATTANK_ROCKETPOD_SND_FIRE = `Weapon_RPG.Single`
						COMBATTANK_ROCKETPOD_ROCKET = `models/weapons/w_models/w_rocket.mdl`
					})

					TankExt.CreateLoopPaths({
						tank_patrol = [
							Vector(0, 2976, 388)
							Vector(0, 2520, 388)
							Vector(0, 356, 388)
							Vector(-28, 284, 388)
							Vector(-100, 256, 388)
							Vector(-636, 256, 388)
							Vector(-708, 228, 388)
							Vector(-736, 168, 388)
							Vector(-736, -448, 388)
							Vector(-704, -512, 388)
							Vector(-624, -608, 388)
							Vector(-512, -688, 388)
							Vector(416, -688, 388)
							Vector(496, -656, 388)
							Vector(528, -608, 388)
							Vector(544, -560, 388)
							Vector(544, -48, 388)
							Vector(512, 32, 388)
							Vector(448, 112, 388)
							Vector(368, 192, 388)
							Vector(256, 256, 388)
							Vector(-100, 256, 388)
						]
					})
            	  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
					EntFire(`tank_bust_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

