					}
				}
				TFBot
				{
					Template T_TFBot_Sniper_Huntsman

					ItemAttributes
					{
						ItemName "The Huntsman"

						"sniper no headshots" 1
					}
				}
			}
		}

		WaveSpawn // 1 GSoldier
		{
			Name "Wave1_Subwave2_GSoldier2"
			WaitForAllSpawned "Wave1_Subwave2_GSoldier"
