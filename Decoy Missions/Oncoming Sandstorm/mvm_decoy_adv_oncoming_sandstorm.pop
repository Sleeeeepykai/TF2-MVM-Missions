#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 850
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	MissionUnloadOutput
	{
		Target BigNet
		Action RunScriptCode
		Param "
				SetSkyboxTexture(`sky_badlands_01`)
				for(local Soundscape; Soundscape = Entities.FindByName(Soundscape, `sndscp_outside`);)
				{
					Soundscape.KeyValueFromString(`soundscape`, `CactusV.Outside`)
					Soundscape.DispatchSpawn()
				}

				EntFire(`fog_controller`, `SetColor`, `181 175 170`)
				EntFire(`fog_controller`, `SetMaxDensity`, 1)
				EntFire(`fog_controller`, `SetStartDist`, 1000)
				EntFire(`fog_controller`, `SetEndDist`, 12000) 
			  "
		Delay -1
	}

	//// PRECACHES ////

	// Precached Models //

	PrecacheModel "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"
	PrecacheModel "models/bots/soldier/bot_soldier_gibby.mdl"
	PrecacheModel "models/bots/sniper_boss/bot_sniper_boss.mdl"

	PrecacheModel "models/props_mvm/indicator/indicator_circle.mdl"

	// Precached Skybox //

    PrecacheGeneric "materials/skybox/sky_sandstormup.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormup.vtf"
    PrecacheGeneric "materials/skybox/sky_sandstormdn.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormdn.vtf"

	PrecacheGeneric "materials/skybox/sky_sandstormside.vtf"
    PrecacheGeneric "materials/skybox/sky_sandstormft.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormbk.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormlf.vmt"
	PrecacheGeneric "materials/skybox/sky_sandstormrt.vmt"

	// Precached Colour Correction //

	PrecacheGeneric "materials/colorcorrection/inthewakeofignis.raw"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PT
		{
			OnSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						IncludeScript(`oncoming_sandstorm`, getroottable())

						OncomingSandstorm.SandstormInit()
					  "
			}
			point_populator_interface
			{
				"targetname" "pop_interface"
			}
		}

		//// Map PTs ////

		Sandstorm_PT
		{
			OnSpawnOutput
			{
				Target decoy_aura
				Action ActivateSkybox
			}
			OnSpawnOutput
			{
				Target colorcorrectionaura
				Action Enable
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetColor
				Param "168 129 88"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetStartDist
				Param "200"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetEndDist
				Param "2000"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetMaxDensity
				Param "0.9"
			}
			sky_camera
			{
				"targetname" "decoy_aura"
				"origin" "0 8192 208"
				"angles" "0 270 0"
				"scale" "16"
				"fogenable" "1"
				"use_angles" "1"
				"fogstart" "200"
				"fogend" "2000"
				"fogmaxdensity" "1"
				"fogcolor" "168 129 88"
				"fogblend" "0"
				"fogdir" "0 1 0"
				"fogRadial" "1"
			}
			color_correction
            {
                "targetname" "colorcorrectionaura"
                "origin" "0 0 0"
                "minfalloff" "-1"
                "maxfalloff" "-1"
                "fadeInDuration" 0
                "fadeOutDuration" 5
                "StartDisabled" 1
                "filename" "materials/colorcorrection/inthewakeofignis.raw"
                "maxweight" "1"
            }
		}

		//// Robot PTs ////

		Djinn_PT
		{
			OnSpawnOutput
			{
				Target "DjinnTarget"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonTimer"
				Action "Enable"
				Delay 14.9
				Repeats 1
				Cooldown -1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonTimer"
				Action "FireTimer"
				Delay 15
				Repeats 1
				Cooldown -1
			}
			info_target
			{
				"targetname" "DjinnTarget"
				"origin" "0 0 50"
			}

			logic_timer
			{
				"targetname" "DjinnSummonTimer"
				"RefireTime" "10"
				"StartDisabled" 1

				"OnTimer" "DjinnSummonRelay,Trigger,,0,-1"
			}
			logic_relay
			{
				"targetname" "DjinnSummonRelay"

				"OnTrigger" "@p@DjinnTarget,$AddPlayerAttribute,dmg from ranged reduced|0.25,0,-1"
				"OnTrigger" "@p@DjinnTarget,$AddPlayerAttribute,dmg from melee increased|0.25,0,-1"
				"OnTrigger" "@p@DjinnTarget,$TauntFromItem,Taunt: Second Rate Sorcery,0,-1"
				"OnTrigger" "@p@DjinnTarget,$TauntFromItem,Taunt: Second Rate Sorcery,0.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_laughevil02.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_laughevil02.mp3,0,-1"
				"OnTrigger" "DjinnSummonIndicator,Enable,,0.5,-1"
				"OnTrigger" "DjinnSummonIndicator,SetAnimation,Start,,0.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_mirv_cast.wav,0.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_mirv_cast.wav,0.5,-1"
				"OnTrigger" "DjinnSpawn_PT,ForceSpawn,,2.3,-1"
				"OnTrigger" "@p@DjinnTarget,RunScriptCode,DjinnSummonTrace(self),2.3,-1"
				"OnTrigger" "DjinnSummonGeneratorBodyGuard1,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorBodyGuard2,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorMobber1,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorMobber2,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonCounter,Add,4,2.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,2.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,2.33,-1"
				"OnTrigger" "DjinnSummonIndicator,SetAnimation,end,2.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_battlecry02.mp3,3.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_battlecry02.mp3,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemovePlayerAttribute,dmg from ranged reduced,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemovePlayerAttribute,dmg from melee increased,3.5,-1"
				"OnTrigger" "DjinnSummonIndicator,Disable,,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemoveCond,7,3.5,-1"
			}

			math_counter
			{
				"targetname" "DjinnSummonCounter"
				"startvalue" "0"
				"min" "0"
				"max" "8"

				"OutValue" "DjinnCounterCompare,SetValueCompare,,0,-1"
			}
			logic_compare
			{
				"targetname" "DjinnCounterCompare"
				"CompareValue" "4"

				"OnLessThan" "DjinnSummonRelay,Enable,,0,-1"
				"OnEqualTo" "DjinnSummonRelay,Enable,,0,-1"
				"OnGreaterThan" "DjinnSummonRelay,Disable,,0,-1"
			}

			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "100 0 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "-100 0 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "0 100 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "0 -100 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }

			bot_generator
			{
				"targetname" "DjinnSummonGeneratorBodyGuard1"
				"origin" "100 0 10"
				"team" "blue"
				"class" "soldier"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnSpawned" "!activator,$BotCommand,interrupt_action -posent DjinnBodyguardPoint1 -distance 1 -duration 9999,0.5,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			bot_generator
			{
				"targetname" "DjinnSummonGeneratorBodyGuard2"
				"origin" "-100 0 10"
				"team" "blue"
				"class" "soldier"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnSpawned" "!activator,$BotCommand,interrupt_action -posent DjinnBodyguardPoint2 -distance 1 -duration 9999,0.5,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			bot_generator
			{
				"targetname" "DjinnSummonGeneratorMobber1"
				"origin" "0 100 10"
				"team" "blue"
				"class" "soldier"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			bot_generator
			{
				"targetname" "DjinnSummonGeneratorMobber2"
				"origin" "0 -100 10"
				"team" "blue"
				"class" "soldier"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			info_target
			{
				"targetname" "DjinnBodyguardPoint1"
				"origin" "100 40 25"
			}
			info_target
			{
				"targetname" "DjinnBodyguardPoint2"
				"origin" "100 -40 25"
			}
		}
		
		DjinnSpawn_PT
		{
			RemoveIfKilled "DjinnNode"

			OnSpawnOutput
			{
				Target "DjinnNode"
				Action Kill
				Delay 1
			}

			point_commentary_node
			{
				"targetname" "DjinnNode"
			}
		}
	}

	//// SPAWNED POINT TEMPLATES ////

	SpawnTemplate "Core_PT"
	SpawnTemplate "Sandstorm_PT"

	//// ROBOT TEMPLATES ////

	Templates
	{
		T_TFBot_Giant_Pyro_Djinn
		{
			Name "Djinn of the Sandstorm"
			Class Pyro
			ClassIcon pyro_dragon_fury_summoner
			Skill Expert
			Health 3500
			Attributes MiniBoss
			Attributes HoldFireUntilFullReload
			Attributes SuppressFire
			WeaponRestrictions PrimaryOnly

			UseCustomModel "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"

			SpawnTemplate Djinn_PT

			Item "TF_WEAPON_GRENADELAUNCHER"

			Item "Sharpened Volcano Fragment"

			Item "Pyromancer's Mask"
			Item "Apparition's Aspect"
			Item "Potato of Labor"

			Item "Taunt: Second Rate Sorcery"

			FireWeapon  
			{
				Delay 0
				Type "Primary"
				IfSeeTarget 1
				IfLeftSpawn 1
				Duration 0.5
				Cooldown 1.6
			}

			CharacterAttributes
			{
				"move speed penalty" 0.5
				"damage force reduction" 0.6
				"airblast vulnerability multiplier" 0.6
				"override footstep sound set" 6
				"voice pitch scale" 0
			}

			ItemAttributes
			{
				ItemName "TF_WEAPON_GRENADELAUNCHER"

				"mod max primary clip override" -1
				"grenade explode on impact" 1
				"Set DamageType Ignite" 1
				"custom item model" "models/workshop/weapons/c_models/c_rift_fire_axe/c_rift_fire_axe.mdl"
				"custom kill icon" "firedeath"
				"custom weapon fire sound" "misc/halloween/spell_fireball_cast.wav"
				"custom impact sound" "misc/halloween/spell_fireball_impact.wav"
				"custom projectile model" "models/empty.mdl"
				"projectile trail particle" "~spell_fireball_small_red"
				"projectile speed decreased" 0.65
				"projectile gravity" -1
				"mod projectile heat seek power" 360
				"mod projectile heat aim error" 360
				"mod projectile heat aim time" 0.05
				"mod projectile heat no predict target speed" 1
			}

			ItemAttributes
			{
				ItemName "Sharpened Volcano Fragment"

				"is_passive_weapon" 1
			}

			ItemAttributes
			{
				ItemName "Potato of Labor"

				"custom item model" "models/workshop/player/items/pyro/tw_pyrobot_armor/tw_pyrobot_armor.mdl"
			}
		}
	}

	//// MISSION BOTS ////

	Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot
		BeginAtWave 1
		RunForThisManyWaves 7
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}
	Mission // Spy (Wave 5)
	{
		Objective Spy
		Where spawnbot_mission_spy
		BeginAtWave 5
		RunForThisManyWaves 1
		InitialCooldown 20
		CooldownTime 30
		DesiredCount 2

		TFBot
		{
			Template T_TFBot_Spy
		}
	}

	//// WAVES ////

	// General Notes

	// Wave 1 Notes
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_left_relay`, `Trigger`, null, 6.1)
            	  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		// Subwave 1
		WaveSpawn // 4 Shield Medics and 16 Loch Demos
		{
			Name "Wave1_Subwave1_ShieldSquads"
			Where spawnbot
			TotalCount 20
			MaxActive 11
			SpawnCount 5
			WaitBeforeStarting 0
			WaitBetweenSpawns 8
			TotalCurrency 100

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Template T_TFBot_Medic_Shield
					Attributes IgnoreEnemies
					WeaponRestrictions SecondaryOnly
					Action FetchFlag

					CharacterAttributes
					{
						"move speed penalty" 0.8
					}
				}
				TFBot
				{
					Template T_TFBot_Demoman_LochnLoad
					Skill Expert

					AimAt Head
				}
				TFBot
				{
					Template T_TFBot_Demoman_LochnLoad
					Skill Expert

					AimAt Head
				}
				TFBot
				{
					Template T_TFBot_Demoman_LochnLoad
					Skill Expert

					AimAt Head
				}
				TFBot
				{
					Template T_TFBot_Demoman_LochnLoad
					Skill Expert

					AimAt Head
				}
			}
		}
		WaveSpawn // 21 Bowmen
		{
			Name "Wave1_Subwave1_Bowmen"
			Where spawnbot_left
			Where spawnbot_right
			TotalCount 21
			MaxActive 6
			SpawnCount 3
			WaitBeforeStarting 0.5
			WaitBetweenSpawns 4
			TotalCurrency 60

			TFBot
			{
				Template T_TFBot_Sniper_Huntsman

				ItemAttributes
				{
					ItemName "The Huntsman"

					"sniper no headshots" 1
				}
			}
		}

		// Subwave 2
		WaveSpawn // 1 GDemo
		{
			Name "Wave1_Subwave2_GDemo"
			WaitForAllSpawned "Wave1_Subwave1_ShieldSquads"
			Where spawnbot
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 10
			WaitBetweenSpawns 0
			TotalCurrency 200

			TFBot
			{
				Template T_TFBot_Giant_Demoman
			}
		}
		WaveSpawn // 4 Pyros and 8 Bowmen
		{
			Name "Wave1_Subwave2_Pyros"
			WaitForAllSpawned "Wave1_Subwave2_GDemo"
			Where spawnbot
			TotalCount 12
			MaxActive 9
			SpawnCount 3
			WaitBeforeStarting 2
			WaitBetweenSpawns 3
			TotalCurrency 100

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Class Pyro
					Skill Easy
					Attributes AlwaysFireWeapon

					CharacterAttributes
					{
						"move speed penalty" 0.8
					}
				}
				TFBot
				{
					Template T_TFBot_Sniper_Huntsman

					ItemAttributes
					{
						ItemName "The Huntsman"

						"sniper no headshots" 1
					}
				}
				TFBot
				{
					Template T_TFBot_Sniper_Huntsman

					ItemAttributes
					{
						ItemName "The Huntsman"

						"sniper no headshots" 1
					}
				}
			}
		}

		WaveSpawn // 1 GDemo and 1 Shield Medic
		{
			Name "Wave1_Subwave2_GDemo2"
			WaitForAllSpawned "Wave1_Subwave2_GDemo"
			Where spawnbot
			TotalCount 2
			MaxActive 2
			SpawnCount 2
			WaitBeforeStarting 16
			WaitBetweenSpawns 0
			TotalCurrency 200

			Squad
			{
				TFBot
				{
					Template T_TFBot_Giant_Demoman
				}
				TFBot
				{
					Template T_TFBot_Medic_Shield
					Attributes IgnoreEnemies
				}
			}
		}
		WaveSpawn // 8 Loch Demos
		{
			Name "Wave1_Subwave2_LochDemos"
			WaitForAllSpawned "Wave1_Subwave2_GDemo2"
			Where spawnbot
			TotalCount 8
			MaxActive 8
			SpawnCount 4
			WaitBeforeStarting 2
			WaitBetweenSpawns 4
			TotalCurrency 80

			TFBot
			{
				Template T_TFBot_Demoman_LochnLoad
				Skill Expert

				AimAt Head
			}
		}
		WaveSpawn // 6 Pyros
		{
			Name "Wave1_Subwave2_Pyros"
			WaitForAllSpawned "Wave1_Subwave2_GDemo2"
			Where spawnbot
			TotalCount 6
			MaxActive 4
			SpawnCount 2
			WaitBeforeStarting 2
			WaitBetweenSpawns 4
			TotalCurrency 60

			TFBot
			{
				Class Pyro
				Skill Easy
			}
		}
	}
	// Wave 2 Notes
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_right_relay`, `Trigger`, null, 6.1)
            	  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		// Subwave 1
		WaveSpawn // 1 Djinn Boss
		{
			Name "Wave2_Subwave1_Djinn"
			Where spawnbot
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 100

			FirstSpawnWarningSound "mvm/giant_heavy/giant_heavy_entrance.wav"

			TFBot
			{
				Name "Greater Djinn of the Sandstorm"
				Template T_TFBot_Giant_Pyro_Djinn
				Health 10000
				Scale 2
				Attributes UseBossHealthBar

				AddAttribute
				{
					Item "Player"
					Name "move speed penalty"
					Value 0.35
					Delay 15
				}
			}
		}
		WaveSpawn // Support Punchies
		{
			Name "Wave2_Subwave1_Punchies"
			WaitForAllSpawned "Wave2_Subwave1_Djinn"
			Where spawnbot_left
			Where spawnbot_right
			Support 1
