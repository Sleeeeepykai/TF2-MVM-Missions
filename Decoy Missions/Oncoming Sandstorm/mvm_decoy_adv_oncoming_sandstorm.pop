#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 850
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	MissionUnloadOutput
	{
		Target BigNet
		Action RunScriptCode
		Param "
				SetSkyboxTexture(`sky_badlands_01`)
				for(local Soundscape; Soundscape = Entities.FindByName(Soundscape, `sndscp_outside`);)
				{
					Soundscape.KeyValueFromString(`soundscape`, `CactusV.Outside`)
					Soundscape.DispatchSpawn()
				}

				EntFire(`fog_controller`, `SetColor`, `181 175 170`)
				EntFire(`fog_controller`, `SetMaxDensity`, 1)
				EntFire(`fog_controller`, `SetStartDist`, 1000)
				EntFire(`fog_controller`, `SetEndDist`, 12000) 
			  "
		Delay -1
	}

	//// PRECACHES ////

	// Precached Models //

	PrecacheModel "models/bots/pyro_boss/bot_pyro_boss_gibby.mdl"
	PrecacheModel "models/bots/demo/bot_demo_gibby.mdl"
	PrecacheModel "models/bots/pyro/bot_pyro_gibby.mdl"
	PrecacheModel "models/bots/soldier/bot_soldier_gibby.mdl"
	PrecacheModel "models/bots/demo_boss/bot_demo_boss_gibby.mdl"
	PrecacheModel "models/bots/soldier_boss/bot_soldier_boss_gibby.mdl"

	PrecacheModel "models/props_mvm/indicator/indicator_circle.mdl"

	// Precached Skybox //

    PrecacheGeneric "materials/skybox/sky_sandstormup.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormup.vtf"
    PrecacheGeneric "materials/skybox/sky_sandstormdn.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormdn.vtf"

	PrecacheGeneric "materials/skybox/sky_sandstormside.vtf"
    PrecacheGeneric "materials/skybox/sky_sandstormft.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormbk.vmt"
    PrecacheGeneric "materials/skybox/sky_sandstormlf.vmt"
	PrecacheGeneric "materials/skybox/sky_sandstormrt.vmt"

	// Precached Colour Correction //

	PrecacheGeneric "materials/colorcorrection/inthewakeofignis.raw"

	//// CUSTOM WEAPONS ////

	CustomWeapon
	{
		"SultanFireballRainAttack"
		{
			OriginalItemName "TF_WEAPON_GRENADELAUNCHER"

			"damage bonus" 1.5
			"fuse bonus" 2
			"no self blast dmg" 1
			"mod max primary clip override" -1
			"grenade explode on impact" 1
			"Set DamageType Ignite" 1
			"custom kill icon" "firedeath"
			"custom weapon fire sound" "misc/halloween/spell_fireball_cast.wav"
			"custom impact sound" "misc/halloween/spell_fireball_impact.wav"
			"custom projectile model" "models/empty.mdl"
			"projectile trail particle" "~spell_fireball_small_red"
			"projectile speed decreased" 0.65
			"projectile gravity" -1
			"projectile spread angle penalty" 45
		}
	}

	//// POINT TEMPLATES ////

	PointTemplates
	{
		//// Core PTs ////

		Core_PT
		{
			OnSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						IncludeScript(`oncoming_sandstorm`, getroottable())

						OncomingSandstorm.SandstormInit()

						IncludeScript(`tankextensions_main`, getroottable())
						IncludeScript(`tankextensions/combattank`, getroottable())
						IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
						IncludeScript(`tankextensions/combattank_weapons/cannon`, getroottable())

						TankExt.SetValueOverrides({
						COMBATTANK_ROCKETPOD_ROCKET_DAMAGE = 30
						COMBATTANK_ROCKETPOD_FIRE_DELAY = 0.2
						COMBATTANK_ROCKETPOD_SND_FIRE = `Weapon_RPG.Single`
						COMBATTANK_ROCKETPOD_ROCKET = `models/weapons/w_models/w_rocket.mdl`
						COMBATTANK_CANNON_ROCKET_SPEED = 2000
						COMBATTANK_CANNON_ROCKET_DAMAGE = 200
						})

						TankExt.CreateLoopPaths({
							tank_patrol = [
								Vector(0, 2976, 388)
								Vector(0, 2520, 388)
								Vector(0, 356, 388)
								Vector(-28, 284, 388)
								Vector(-100, 256, 388)
								Vector(-636, 256, 388)
								Vector(-708, 228, 388)
								Vector(-736, 168, 388)
								Vector(-736, -448, 388)
								Vector(-704, -512, 388)
								Vector(-624, -608, 388)
								Vector(-512, -688, 388)
								Vector(416, -688, 388)
								Vector(496, -656, 388)
								Vector(528, -608, 388)
								Vector(544, -560, 388)
								Vector(544, -48, 388)
								Vector(512, 32, 388)
								Vector(448, 112, 388)
								Vector(368, 192, 388)
								Vector(256, 256, 388)
								Vector(-100, 256, 388)
							]
						})
					  "
			}
			point_populator_interface
			{
				"targetname" "pop_interface"
			}

			// Universal Filters
            filter_activator_class // Is a Player
            {
                "targetname" "filter_is_player"
                "Negated" "0"
                "filterclass" "player"
            }
            filter_multi // Is a Red Player
            {
                "targetname" "filter_is_red_player"
                "Negated"	"0"
                "FilterType" "0"			
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_player"
            }
            filter_tf_condition // Medigun Uber Filter
            {
                "targetname" "filter_is_not_ubered"
                "Negated"	"1"
                "condition"  "5" //medigun uber
            }
            filter_tf_condition // Canteen Uber Filter
            {
                "targetname" "filter_is_not_ubered2"
                "Negated"	"1"
                "condition"  "52" //canteen uber
            }
            filter_tf_condition // MVM Spawn Uber Filter
            {
                "targetname" "filter_is_not_ubered3"
                "Negated"	"1"
                "condition"  "51" //hidden uber
            }
            filter_tf_condition // Wheel of Fate Uber ilter
            {
                "targetname" "filter_is_not_ubered4"
                "Negated"	"1"
                "condition"  "57" //WoF uber
            }
            filter_multi // Is an Un-Ubered Red Player
            {
                "targetname" "filter_redteam_nouber"
                "Negated"	"0"
                "FilterType" "0" //and				
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_not_ubered"
                "Filter03"   "filter_is_not_ubered2"
                "Filter04"   "filter_is_not_ubered3"
                "Filter05"   "filter_is_not_ubered4"
                "Filter06"   "filter_is_player"
            }
            filter_multi // Is an Un-Ubered Player
            {
                "targetname" "filter_nouber"
                "Negated"	"0"
                "FilterType" "0"
                "Filter01"   "filter_is_not_ubered"
                "Filter02"   "filter_is_not_ubered2"
                "Filter03"   "filter_is_not_ubered3"
                "Filter04"   "filter_is_not_ubered4"
                "Filter05"   "filter_is_player"
            }
		}

		//// Map PTs ////

		Sandstorm_PT
		{
			OnSpawnOutput
			{
				Target decoy_aura
				Action ActivateSkybox
			}
			OnSpawnOutput
			{
				Target colorcorrectionaura
				Action Enable
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetColor
				Param "168 129 88"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetStartDist
				Param "200"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetEndDist
				Param "2000"
			}
			OnSpawnOutput
			{
				Target fog_controller
				Action SetMaxDensity
				Param "0.9"
			}
			sky_camera
			{
				"targetname" "decoy_aura"
				"origin" "0 8192 208"
				"angles" "0 270 0"
				"scale" "16"
				"fogenable" "1"
				"use_angles" "1"
				"fogstart" "200"
				"fogend" "2000"
				"fogmaxdensity" "1"
				"fogcolor" "168 129 88"
				"fogblend" "0"
				"fogdir" "0 1 0"
				"fogRadial" "1"
			}
			color_correction
            {
                "targetname" "colorcorrectionaura"
                "origin" "0 0 0"
                "minfalloff" "-1"
                "maxfalloff" "-1"
                "fadeInDuration" 0
                "fadeOutDuration" 5
                "StartDisabled" 1
                "filename" "materials/colorcorrection/inthewakeofignis.raw"
                "maxweight" "1"
            }
		}

		//// Robot PTs ////

		Djinn_PT
		{
			RemoveIfKilled "DjinnTarget"

			KeepAlive 1
			
			OnSpawnOutput
			{
				Target "DjinnTarget"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonGeneratorBodyGuard1"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonGeneratorBodyGuard2"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonGeneratorMobber1"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonGeneratorMobber2"
				Action SetParent
				Param "!activator"
				Delay 0.1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonTimer"
				Action "Enable"
				Delay 14.9
				Repeats 1
				Cooldown -1
			}
			OnSpawnOutput
			{
				Target "DjinnSummonTimer"
				Action "FireTimer"
				Delay 15
				Repeats 1
				Cooldown -1
			}

			OnParentKilledOutput
			{
				Target "DjinnSummonGeneratorBodyGuard1"
				Action "RemoveBots"
				Delay 0.1
				Repeats 3
				Cooldown -1
			}
			OnParentKilledOutput
			{
				Target "DjinnSummonGeneratorBodyGuard2"
				Action "RemoveBots"
				Delay 0.1
				Repeats 3
				Cooldown -1
			}
			OnParentKilledOutput
			{
				Target "DjinnSummonGeneratorMobber1"
				Action "RemoveBots"
				Delay 0.1
				Repeats 3
				Cooldown -1
			}
			OnParentKilledOutput
			{
				Target "DjinnSummonGeneratorMobber2"
				Action "RemoveBots"
				Delay 0.1
				Repeats 3
				Cooldown -1
			}
			OnParentKilledOutput
			{
				Target "DjinnTarget"
				Action "Kill"
				Delay 1
				Repeats 1
				Cooldown -1
			}

			info_target
			{
				"targetname" "DjinnTarget"
				"origin" "0 0 50"
			}

			logic_timer
			{
				"targetname" "DjinnSummonTimer"
				"RefireTime" "10"
				"StartDisabled" 1

				"OnTimer" "DjinnSummonRelay,Trigger,,0,-1"
			}
			logic_relay
			{
				"targetname" "DjinnSummonRelay"

				"OnTrigger" "@p@DjinnTarget,$AddPlayerAttribute,dmg from ranged reduced|0.25,0,-1"
				"OnTrigger" "@p@DjinnTarget,$AddPlayerAttribute,dmg from melee increased|0.25,0,-1"
				"OnTrigger" "@p@DjinnTarget,$TauntFromItem,Taunt: Second Rate Sorcery,0,-1"
				"OnTrigger" "@p@DjinnTarget,$TauntFromItem,Taunt: Second Rate Sorcery,0.1,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_laughevil02.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_laughevil02.mp3,0,-1"
				"OnTrigger" "DjinnSummonIndicator,Enable,,0.5,-1"
				"OnTrigger" "DjinnSummonIndicator,SetAnimation,Start,,0.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_mirv_cast.wav,0.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_mirv_cast.wav,0.5,-1"
				"OnTrigger" "DjinnSpawn_PT,ForceSpawn,,2.3,-1"
				"OnTrigger" "@p@DjinnTarget,RunScriptCode,OncomingSandstorm.DjinnSummonTrace(self),2.3,-1"
				"OnTrigger" "DjinnSummonGeneratorBodyGuard1,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorBodyGuard2,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorMobber1,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonGeneratorMobber2,SpawnBot,,2.33,-1"
				"OnTrigger" "DjinnSummonCounter,Add,4,2.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,2.33,-1"
				"OnTrigger" "tf_gamerules,PlayVO,misc/halloween/spell_spawn_boss.wav,2.33,-1"
				"OnTrigger" "DjinnSummonIndicator,SetAnimation,end,2.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_battlecry02.mp3,3.5,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo/mvm/mght/pyro_mvm_m_battlecry02.mp3,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemovePlayerAttribute,dmg from ranged reduced,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemovePlayerAttribute,dmg from melee increased,3.5,-1"
				"OnTrigger" "DjinnSummonIndicator,Disable,,3.5,-1"
				"OnTrigger" "@p@DjinnTarget,$RemoveCond,7,3.5,-1"
			}

			math_counter
			{
				"targetname" "DjinnSummonCounter"
				"startvalue" "0"
				"min" "0"
				"max" "8"

				"OutValue" "DjinnCounterCompare,SetValueCompare,,0,-1"
			}
			logic_compare
			{
				"targetname" "DjinnCounterCompare"
				"CompareValue" "4"

				"OnLessThan" "DjinnSummonRelay,Enable,,0,-1"
				"OnEqualTo" "DjinnSummonRelay,Enable,,0,-1"
				"OnGreaterThan" "DjinnSummonRelay,Disable,,0,-1"
			}

			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "100 0 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "-100 0 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "0 100 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }
			prop_dynamic
            {
                "targetname" "DjinnSummonIndicator"
                "origin" "0 -100 10"
                "angles" "0 0 0"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
                "modelscale" "1.5"
                "skin" "1"
                "defaultanim" "start"
                "solid" "0"
				"startdisabled" "1"
                "disablebonefollowers" "1"
                "disableshadows" "1"
            }

			bot_generator
			{
				"targetname" "DjinnSummonGeneratorBodyGuard1"
				"origin" "100 0 10"
				"team" "blue"
				"class" "demoman"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnSpawned" "!activator,$BotCommand,interrupt_action -posent DjinnBodyguardPoint1 -distance 1 -duration 9999,0.5,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			bot_generator
			{
				"targetname" "DjinnSummonGeneratorBodyGuard2"
				"origin" "-100 0 10"
				"team" "blue"
				"class" "demoman"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
				"OnSpawned" "!activator,$BotCommand,interrupt_action -posent DjinnBodyguardPoint2 -distance 1 -duration 9999,0.5,-1"
				"OnBotKilled" "DjinnSummonCounter,Subtract,1,0,-1"
			}
			bot_generator
			{
				"targetname" "DjinnSummonGeneratorMobber1"
				"origin" "0 100 10"
				"team" "blue"
				"class" "demoman"
				"count" "0"
				"maxActive" "2"
				"spawnOnlyWhenTriggered" "1"

				"OnSpawned" "!activator,RunScriptCode,OncomingSandstorm.DjinnSummonInit(self),0,-1"
