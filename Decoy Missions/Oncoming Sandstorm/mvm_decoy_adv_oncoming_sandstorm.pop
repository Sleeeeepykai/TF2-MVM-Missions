			logic_relay // Phase 1 Minions Relay
			{
				"targetname" "SultanPhase1MinionsRelay"

				"OnTrigger" "!activator,$AddPlayerAttribute,dmg from ranged reduced|0.1,0,-1"
				"OnTrigger" "!activator,$AddPlayerAttribute,dmg from melee increased|0.1,0,-1"
