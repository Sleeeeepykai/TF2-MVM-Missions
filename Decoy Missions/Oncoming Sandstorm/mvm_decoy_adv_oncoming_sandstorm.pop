			// Intro //
			logic_relay
			{
				"targetname" "SultanIntroRelay"
				
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\taunts\pyro_mvm_m_highfive_success01.mp3,0,-1"
				"OnTrigger" "tf_gamerules,PlayVO,vo\mvm\mght\taunts\pyro_mvm_m_highfive_success01.mp3,0,-1"
				"OnTrigger" "!activator,$PlaySequence,taunt_lollichop,0,-1"
