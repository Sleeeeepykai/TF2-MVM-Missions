		// Subwave 1
		WaveSpawn // Support GSniper
		{
			Name "Wave5_Subwave1_PatrolSniper"
			Where spawnbot_right
			Support 1
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawnsAfterDeath 20
			TotalCurrency 0

			TFBot
			{
				Name "Dune Hunter"
				Template T_TFBot_Giant_Sniper
				Action Mobber

				IgnoreNavAvoid 1
				AlwaysGlow 1

				AimAt Head

				SpawnTemplate "SniperPatrol_PT"

				Item "The AWPer Hand"
				Item "The Razorback"
				Item "Desert Marauder"
				Item "The Conspicuous Camouflage"
				Item "The Cammy Jammies"

				FireInput
				{
					Target "!self"
					Action "$ChangeAttributes"
					Param FrontPatrol_Stage1_Dormant
					Delay 0.1
					Repeats 1
					Cooldown -1
				}

				EventChangeAttributes
				{
					// Front Patrol
					FrontPatrol_Stage1_Dormant [$SIGSEGV]
					{
						WeaponRestrictions SecondaryOnly

						MaxVisionRange 400

						FireWeapon
						{
							Type Primary
							Delay 0.1
							Cooldown 0.1
							Duration 1
							IfSeeTarget 1
							IfLeftSpawn 1
						}

						InterruptAction
						{
							Target "32 1284 665"
							Delay 0.5
							Repeats 1
							Cooldown -1
							Distance 50
							Duration 0.1
							WaitUntilDone 1
							OnDoneChangeAttributes "FrontPatrol_Stage1_Active"
						}
					}
					FrontPatrol_Stage1_Active [$SIGSEGV]
					{
						WeaponRestrictions PrimaryOnly

						MaxVisionRange 1250

						FireWeapon
						{
							Type Primary
							Delay 0.5
							Cooldown 2.25
							Duration 0.1
							IfSeeTarget 1
							IfLeftSpawn 1
						}
						FireInput
						{
							Target !self
							Action $AddCond
							Param 1
							Delay 0.1
							Cooldown 0.1
							IfSeeTarget 1
						}
