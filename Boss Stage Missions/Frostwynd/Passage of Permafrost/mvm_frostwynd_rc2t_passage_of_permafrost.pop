        {
            // Atmosphere Setting //
            logic_relay
            {
                "targetname" "MainSetupRelay"

                "OnTrigger" "bombpath_general_arrows,Disable,,0.5,-1"

                "OnTrigger" "init_skybox_change,Trigger,,0,-1"

                "OnTrigger" "fog_outside,setstartdist,500,0,-1"
                "OnTrigger" "fog_outside,setenddist,5500,0,-1"
                "OnTrigger" "fog_outside,setcolor,96 96 96,0,-1"
                "OnTrigger" "fog_outside,setcolorsecondary,96 96 96,0,-1"

                "OnTrigger" "snowstorm,Start,,0,-1"
            }

            info_particle_system
            {
                "targetname"   "snowstorm"
