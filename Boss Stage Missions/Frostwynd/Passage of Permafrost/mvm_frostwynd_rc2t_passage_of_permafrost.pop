    //// SPAWNED TEMPLATES ////

    SpawnTemplate MainMissionAssets [$SIGSEGV]
    SpawnTemplate Pickups [$SIGSEGV]

    //// TEMPLATES ////

    //// MISSION BOTS ////

    Mission
    {

    }

    //// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `Passage of Permafrost`)
                    EntFire(`MainSetupRelay`, `Trigger`)
                  "
        }
        StartWaveOutput
		{
			Target BigNet
			Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
		}
	    DoneOutput					
		{
			Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
		}

        WaveSpawn
        {
            Name "TheBoss"
            Where spawnbot
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0

            TFBot
            {

            }
        }
    }
}