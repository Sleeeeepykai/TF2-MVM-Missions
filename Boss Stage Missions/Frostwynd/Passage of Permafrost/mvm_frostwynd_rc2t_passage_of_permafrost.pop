#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 3000
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No
    WaveStartCountdown 5 [$SIGSEGV]

    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

    //// PRECACHES ////

    //// PRECACHED EXTRAS ////

    PrecacheGeneric "materials/colorcorrection/stormlight.raw" [$SIGSEGV]

    //// POINT TEMPLATES ////

    PointTemplates [$SIGSEGV]
    {
