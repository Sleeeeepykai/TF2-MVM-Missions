	//// ROBOT TEMPLATES ////

	Templates
	{
	}

	//// MISSION BOTS ////

	Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_mission_sentrybuster
		BeginAtWave 1
		RunForThisManyWaves 7
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}
	Mission // Spy (Wave 2)
	{
		Objective Spy
		Where spawnbot_mission_spy
		BeginAtWave 2
		RunForThisManyWaves 1
		InitialCooldown 16
		CooldownTime 32
		DesiredCount 2
		
		TFBot
		{
			Template T_TFBot_Spy
		}
	}

	// General Notes

	// Wave 1 Notes
	Wave
	{
		InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_left_relay`, `Trigger`, null, 6.1)

					TankExt.SetValueOverrides({
						COMBATTANK_CANNON_ROCKET_SPEED = 2000
						COMBATTANK_CANNON_ROCKET_DAMAGE = 400
					})
            	  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_classic_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		// Subwave 1
		WaveSpawn // 1 Cannon Tank
		{
			Name "Wave1_Subwave1_CannonTank"
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 100

			Tank
			{
				Template Tank_Combat_Cannon
				Health 24000
				StartingPathTrackNode "tank_path_a_1"

				OnBombDroppedOutput
				{
					Target boss_deploy_relay
					Action Trigger
				}
			}
		}

		WaveSpawn // 40 Demoknights
		{
			Name "Wave1_Subwave1_Demoknights"
			WaitForAllSpawned "Wave1_Subwave1_CannonTank"
			Where spawnbot_left
			Where spawnbot_right
			RandomSpawn 1
			TotalCount 40
			MaxActive 15
			SpawnCount 10
			WaitBeforeStarting 5
			WaitBetweenSpawns 10
			TotalCurrency 80

			TFBot
			{
				Template T_TFBot_Demoman_Knight
				Attributes AlwaysCrit
			}
		}
		WaveSpawn // 3 GHeavies
		{
			Name "Wave1_Subwave1_GHeavies"
			WaitForAllSpawned "Wave1_Subwave1_CannonTank"
			Where spawnbot
			TotalCount 3
			MaxActive 2
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 20
			TotalCurrency 80

			TFBot
			{
				Template T_TFBot_Giant_Heavy

				CharacterAttributes
				{
					"damage force reduction" 0.01
					"airblast vulnerability multiplier" 0.01
					"airblast vertical vulnerability multiplier" 0.01
				}
			}
		}

		// Subwave 2
		WaveSpawn // 1 GShield Medic and 2 GBurst Demos
		{
			Name "Wave1_Subwave2_GShieldSquad"
			WaitForAllSpawned "Wave1_Subwave1_GHeavies"
			Where spawnbot
			TotalCount 3
			MaxActive 3
			SpawnCount 3
			WaitBeforeStarting 0
			WaitBetweenSpawns 0
			TotalCurrency 120

			Squad
			{
				NoWaitForFormation 1 [$SIGSEGV]

				TFBot
				{
					Template T_TFBot_Giant_Medic_Shield
