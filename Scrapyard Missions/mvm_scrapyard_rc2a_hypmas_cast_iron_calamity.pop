#base robot_standard_vanilla_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_standard_supercharged_kai.pop
#base robot_standard_supercharged_rafmod_kai.pop
#base robot_giant_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_giant_supercharged_kai.pop
#base robot_giant_supercharged_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 1600
	RespawnWaveTime 1
	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 10

	//// PRECACHES ////

	// Precached Models

	PrecacheModel "models/bots/sniper_boss/bot_sniper_boss.mdl"

	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_combat_tank_chassis.mdl"
	PrecacheModel "models/bots/boss_bot/combat_tank_mk2/mk2_combat_tank_cannon.mdl"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		Core_PT
		{
			OnSpawnOutput
			{
				Target BigNet
				Action RunScriptCode
				Param "
						IncludeScript(`tankextensions_main`, getroottable())
						IncludeScript(`tankextensions/combattank`, getroottable())
						IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
						IncludeScript(`tankextensions/combattank_weapons/cannon`, getroottable())
					  "
			}
			point_populator_interface
			{
				"targetname" "pop_interface"
			}
			
			logic_auto
			{
				"targetname" "TankPathSetup"

				"OnMapSpawn" "tank_path_carrier_6,AddOutput,OnPass !activator:SetSpeed:0:0:-1,0,-1"
				"OnMapSpawn" "tank_path_carrier_6,AddOutput,OnPass tf_gamerules:PlayVO:hl1/ambience/steamburst1.wav:0:-1,0,-1"
				"OnMapSpawn" "tank_path_carrier_6,AddOutput,OnPass tf_gamerules:PlayVO:doors/heavy_metal_stop1.wav:0:-1,0,-1"
			}

			logic_relay
			{
				"targetname" "TankMoveRelay"

				"OnTrigger" "tank_boss*,SetSpeed,25,0,-1"
				"OnTrigger" "tank_boss*,SetSpeed,50,1.5,-1"
				"OnTrigger" "tank_boss*,SetSpeed,75,3,-1"
				"OnTrigger" "BigNetRunScriptCodePrecacheSound(`mvm/mvm_tank_horn.wav`);EmitSoundEx({sound_name=`mvm/mvm_tank_horn.wav`,pitch = 85,filter_type=5})0-1"
			}
			logic_relay
			{
				"targetname" "TankCleanupRelay"

				"OnTrigger" "tank_boss*,RemoveHealth,100000,0,-1"
			}

			// Universal Filters
            filter_activator_class // Is a Player
            {
                "targetname" "filter_is_player"
                "Negated" "0"
                "filterclass" "player"
            }
            filter_multi // Is a Red Player
            {
                "targetname" "filter_is_red_player"
                "Negated"	"0"
                "FilterType" "0"			
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_player"
            }
            filter_tf_condition // Medigun Uber Filter
            {
                "targetname" "filter_is_not_ubered"
                "Negated"	"1"
                "condition"  "5" //medigun uber
            }
            filter_tf_condition // Canteen Uber Filter
            {
                "targetname" "filter_is_not_ubered2"
                "Negated"	"1"
                "condition"  "52" //canteen uber
            }
            filter_tf_condition // MVM Spawn Uber Filter
            {
                "targetname" "filter_is_not_ubered3"
                "Negated"	"1"
                "condition"  "51" //hidden uber
            }
            filter_tf_condition // Wheel of Fate Uber ilter
            {
                "targetname" "filter_is_not_ubered4"
                "Negated"	"1"
                "condition"  "57" //WoF uber
            }
            filter_multi // Is an Un-Ubered Red Player
            {
                "targetname" "filter_redteam_nouber"
                "Negated"	"0"
                "FilterType" "0" //and				
                "Filter01"   "filter_redteam"
                "Filter02"   "filter_is_not_ubered"
                "Filter03"   "filter_is_not_ubered2"
                "Filter04"   "filter_is_not_ubered3"
                "Filter05"   "filter_is_not_ubered4"
                "Filter06"   "filter_is_player"
            }
            filter_multi // Is an Un-Ubered Player
            {
                "targetname" "filter_nouber"
                "Negated"	"0"
                "FilterType" "0"
                "Filter01"   "filter_is_not_ubered"
                "Filter02"   "filter_is_not_ubered2"
                "Filter03"   "filter_is_not_ubered3"
                "Filter04"   "filter_is_not_ubered4"
                "Filter05"   "filter_is_player"
            }
		}
	}

