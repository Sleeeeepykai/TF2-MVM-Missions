#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 800
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No

    AddSentryBusterWhenDamageDealtExceeds 5000
    AddSentryBusterWhenKillCountExceeds 15

    //// PRECACHES ////

    //// ROBOT TEMPLATES ////

    Templates
    {
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_mission_sentrybuster
        BeginAtWave 1
        RunForThisManyWaves 7
        DesiredCount 1

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_SentryBuster
        }   
    }
    Mission // Spy (Wave 2)
    {
        Objective Spy
        Where spawnbot_mission_spy
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 4

        InitialCooldown 16
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Spy
        }
    }
    Mission // Sniper (Wave 3)
    {
        Objective Sniper
        Where spawnbot_mission_sniper
        BeginAtWave 3
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 4
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Sniper
        }
    }
    //// WAVES ////
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `Highrise Havoc (Adv)`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        // Subwave 1
        WaveSpawn // 12 Shotgun Heavies
        {
            Name "Wave1_Subwave1_Shotguns"
            Where spawnbot_invasion
            TotalCount 12
            MaxActive 12
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0.1
            TotalCurrency 80

            TFBot
            {
                Name "Shotgun Heavy"
                Template T_TFBot_Heavyweapons_Shotgun
            }
        }

        WaveSpawn // 12 Shotgun Heavies
        {
            Name "Wave1_Subwave1_Shotguns2"
            WaitForAllSpawned "Wave1_Subwave1_Shotguns"
            Where spawnbot_invasion
            TotalCount 12
            MaxActive 12
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 0.1
            TotalCurrency 80

            TFBot
            {
                Name "Shotgun Heavy"
                Template T_TFBot_Heavyweapons_Shotgun
            } 
        }
        WaveSpawn // 8 Demomen
        {
            Name "Wave1_Subwave1_Demomen"
            WaitForAllSpawned "Wave1_Subwave1_Shotguns2"
            Where spawnbot
            TotalCount 8
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 0.1
            TotalCurrency 40

            TFBot
            {
                Class Demoman
                Skill Easy
            }
        }

        WaveSpawn // 12 Shotgun Heavies
        {
            Name "Wave1_Subwave1_Shotguns3"
            WaitForAllSpawned "Wave1_Subwave1_Shotguns2"
            Where spawnbot_invasion
            TotalCount 12
            MaxActive 12
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 0.1
            TotalCurrency 80

            TFBot
            {
                Name "Shotgun Heavy"
                Template T_TFBot_Heavyweapons_Shotgun
            } 
        }
        WaveSpawn // 8 Pyros
        {
            Name "Wave1_Subwave1_Pyros"
            WaitForAllSpawned "Wave1_Subwave1_Shotguns3"
            Where spawnbot
            TotalCount 8
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 0.1
            TotalCurrency 40

            TFBot
            {
                Class Pyro
                Skill Easy
            }
        }

        // Subwave 2
        WaveSpawn // 1 GBurst
        {
            Name "Wave1_Subwave2_GBurst"
