            WaitForAllSpawned "Wave1_Subwave2_GBurst"
            Where spawnbot
            TotalCount 16
            MaxActive 16
            SpawnCount 1
            WaitBeforeStarting 8
            WaitBetweenSpawns 0.1
            TotalCurrency 60

            TFBot
            {
                Class Pyro
                Skill Easy
            }
        }

        // Subwave 3
        WaveSpawn // 32 Demomen
        {
