            }
        }

        WaveSpawn // 1 GBurst and 8 Pyros
        {
            Name "Wave1_Subwave3_GBurst"
            WaitForAllSpawned "Wave1_Subwave3_Demomen"
            Where spawnbot_giant
            TotalCount 9
            MaxActive 9
            SpawnCount 9
            WaitBeforeStarting 16
            WaitBetweenSpawns 0
            TotalCurrency 80

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Demo_Burst
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
            }
        }
    }
    Wave
    {
        StartWaveOutput
