        //Conduit Logic
        conduit_logic
        {
            game_text
            {
                "origin" "1984 1984 99999"
                "message" "Clockwork of the Iron Menace"
                "targetname" "upper_text2"
                "x" "-1"
                "y" "0.4"
                "spawnflags" "1"
                "effect" "2"
                "channel" "2"
                "color" "255 150 0"
                "fxtime" "0.2"
                "fadeout" "1"
                "holdtime" "4.8"
            }
            game_text
            {
                "origin" "1984 1984 99999"
