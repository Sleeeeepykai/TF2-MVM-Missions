				"disableshadows" "1"
            }
            OnSpawnOutput
            {
                Target spawnlaser_relay
                Action Trigger
            }
            logic_case
            {
                "targetname" "spawnlaser_where"
                "OnCase01" "laser_spawn,$MoveRelative,100 0 0,0,-1"
                "OnCase02" "laser_spawn,$MoveRelative,200 0 0,0,-1"
                "OnCase03" "laser_spawn,$MoveRelative,300 0 0,0,-1"
                "OnCase04" "laser_spawn,$MoveRelative,400 0 0,0,-1"
                "OnCase05" "laser_spawn,$MoveRelative,500 0 0,0,-1"
                "OnCase06" "laser_spawn,$MoveRelative,600 0 0,0,-1"
            }
            logic_relay
            {
                "targetname" "spawnlaser_relay"
                "OnTrigger" "spawnlaser_where,PickRandom,,0,-1"
                "OnTrigger" "GigaBeam,ForceSpawnAtEntityOrigin,laser_spawn,1,-1"
                "OnTrigger" "laser_origin,kill,,1.1,-1"
            }
        }
