                Param "180 0 0"
                Delay 0
            }
            trigger_hurt
            {
                "targetname" "spam_damage"
                "parentname" "spam_indicator"
                "mins" "-50 -50 -80"
                "maxs" "50 50 80"
                "damage" "350"
                "damagetype" "2"
                "filtername" "filter_is_red_not_ubered"
                "StartDisabled" "1"
				"spawnflags" "64"
            }
            info_particle_system
            {
                "targetname" "spam_effect"
                "origin" "0 0 10"
                "effect_name" "drg_cow_explosioncore_charged_blue"
            }
            ambient_generic
            {
                "targetname" "spam_sound"
                "message" "weapons/cow_mangler_explosion_normal_03.wav"
                "health" "4"
				"pitch" "100"
				"radius" "5000"
				"spawnflags" "32"
				"origin" "0 0 100"
            }
            OnSpawnOutput
            {
                Target spam_relay
                Action Trigger
                Delay 2.5
            }
            OnSpawnOutput
            {
                Target spam_damage
                Action SetOwner
                Param @p@boss_thing
            }
            logic_relay
            {
                "targetname" "spam_relay"
                "OnTrigger" "spam_beam,StrikeOnce,,0,-1"
                "OnTrigger" "spam_effect,start,,0,-1"
                "OnTrigger" "spam_sound,playsound,,0,-1"
                "OnTrigger" "spam_damage,enable,,0.01,-1"
                "OnTrigger" "spam_damage,disable,,0.02,-1"
                "OnTrigger" "spam_effect,stop,,1,-1"
                "OnTrigger" "spam_origin,kill,,1,-1"
            }
        }
        MegaBeamSetup
        {
            RemoveIfKilled laser_origin
            KeepAlive 1
            info_target
            {
                "targetname" "laser_origin"
