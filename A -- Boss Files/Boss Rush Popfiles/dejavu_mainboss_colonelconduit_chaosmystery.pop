                "m_flRadius" "1500"
                "origin" "0 0 50"
                "thick_max" "15"
                "thick_min" "5"
                "m_SoundName" "DoSpark"
                "texture" "sprites/physbeam.vmt"
            }
            info_particle_system
            {
                "targetname" "super_release"
                "effect_name" "powerup_supernova_explode_blue"
				"start_active" "0"
				"origin" "0 0 0.3"
            }
            logic_relay
            {
                "targetname" "boss_spawns"
                "OnTrigger" "player,$PlaySoundToSelf,=75/mvm/giant_heavy/giant_heavy_entrance.wav,0,-1"
                "OnTrigger" "upper_text2,Display,,0.4,-1"
                "OnTrigger" "lower_text1,Display,,1.8,-1"
            }
            logic_relay
            {
                "targetname" "firebomb_attack_relay"
                "OnTrigger" "!activator,$AddPlayerAttribute,increased jump height|0,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_jump|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,no_attack|1,0,-1"
                "OnTrigger" "!activator,$AddPlayerAttribute,move speed bonus|0.01,0,-1"
