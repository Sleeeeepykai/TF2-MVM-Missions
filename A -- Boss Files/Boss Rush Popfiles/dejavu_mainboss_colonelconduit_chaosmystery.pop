        //Env_Beam Based Attacks
        BeamSpamSetup
        {
            RemoveIfKilled spam_spawn
            KeepAlive 1
            info_target
            {
                "targetname" "spam_spawn"
            }
            OnParentKilledOutput
            {
                Target BeamSpam
                Action ForceSpawnAtEntityOrigin
                Param spam_spawn
            }
            OnSpawnOutput
            {
                Target spam_spawn
                Action "$setKey$angles"
                Param "180 0 0"
                Delay 0
            }
            OnParentKilledOutput
            {
                Target spam_spawn
                Action Kill
                Delay 0.6
            }
        }
        BeamSpam
        {
            RemoveIfKilled spam_origin
            KeepAlive 1
            info_target
            {
                "targetname" "spam_origin"
                "origin" "0 0 0.3"
            }
            prop_dynamic
            {
                "targetname" "spam_indicator"
                "parentname" "spam_origin"
                "model" "models/props_mvm/indicator/indicator_circle.mdl"
