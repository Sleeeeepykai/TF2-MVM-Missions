		T_TFBot_Dwarven_Chieftain_Heavy
		{
			Class Heavyweapons
			Name "The Dwarven Chieftain"
			ClassIcon heavy_grenadier_buff
			Health 60000
			Scale 1.9
			Skill Hard
			Attributes MiniBoss
			Attributes UseBossHealthBar
			WeaponRestrictions SecondaryOnly
			UseHumanAnimations 1
			Item "The Huo Long Heatmaker"
			Item "The Family Business"
			Item "The Grenadier Helm"
			Item "Security Shades"
			Item "Potato of Labor"
                ItemModel 
                {
                    ItemName "Potato of Labor" 
                    Model "models/workshop_partner/player/items/demo/hero_academy_demo/hero_academy_demo.mdl"
                }

			SpawnTemplate "DwarfBossExplosion"

			Taunt
			{
				Delay 0.25
				Cooldown 0
				Repeats 1
				Name "Taunt: Unleashed Rage"
			}

			ItemAttributes
			{
				ItemName "The Huo Long Heatmaker"
				"damage bonus" 1.5
			}		
			ItemAttributes
			{
				ItemName "The Family Business"
				"damage bonus" 1.5
				"reload time decreased" 0.25

			}

			CharacterAttributes
			{
				"move speed bonus" 0.5
				"damage force reduction" 0.3
				"airblast vulnerability multiplier" 0.3
				"override footstep sound set" 2
				"torso scale" 0.75
			}

			EventChangeAttributes
			{
				MinigunEquip
				{
					WeaponRestrictions PrimaryOnly
				}
				BuffPhaseUber
				{
					Addcond
					{
						Index 51
						Duration 7
					}
				}
				MinicritsBuff
				{
					WeaponRestrictions PrimaryOnly
					Addcond
					{
						Index 16
					}
				}
				DeathPhase
				{
					Addcond
					{
						Index 14
					}
					Taunt
					{
						Delay 0.25
						Cooldown 0
						Repeats 1
						Name "Taunt: Mourning Mercs"			
					}
					FireInput
					{
						Target player
						Action $PlaySoundtoSelf
						Param "freeze_cam/dwarf_chief_deathcry.wav"
						Delay 1
						Cooldown 0.02
						Repeats 3
					}
					FireInput
					{
						Target !Self
						Action $Suicide
						Delay 4.1
						Cooldown 0.02
						Repeats 1
					}
					FireInput
					{
						Target explode_shortcut_quake
						Action StartShake
						Delay 3.95
					}
					FireInput
					{
						Target explode_shortcut_effect
						Action Start
						Delay 3.95
					}
					FireInput
					{
						Target explode_shortcut_effect
						Action Stop
						Delay 6.95
					}            
					FireInput
					{
						Target explode_shortcut_sound
						Action PlaySound
						Delay 3.95
					}
				}
			}
			FireInput
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/dwarf_chief_battlecry.wav"
				Delay 0.25
				Cooldown 0.02
				Repeats 3
			}
			Addcond
			{
				Index 51
				Duration 6
			}
			FireInput
			{
				Target !Self
				Action $ChangeAttributes
				Param MinigunEquip
				Delay 0.25
				Cooldown 0
				Repeats 1
				IfHealthBelow 30000
			}
			FireInput
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/dwarf_chief_minigunequip.wav"
				Delay 0
				Cooldown 0.02
				Repeats 3
				IfHealthBelow 30000
			}

			Taunt
			{
				Delay 0.25
				Cooldown 0
				Repeats 1
				Name "Taunt: Cheers!"
				IfHealthBelow 20000
			}
			FireInput
			{
				Target !Self
				Action $ChangeAttributes
				Param BuffPhaseUber
				Delay 0.25
				Cooldown 0
				Repeats 1
				IfHealthBelow 20000
			}
			FireInput
			{
				Target !Self
				Action $ChangeAttributes
				Param MinicritsBuff
				Delay 4
				Cooldown 0
				Repeats 1
				IfHealthBelow 20000
			}
			FireInput
			{
				Target player
				Action $PlaySoundtoSelf
				Param "freeze_cam/dwarf_chief_buff.wav"
				Delay 4
				Cooldown 0.02
				Repeats 3
				IfHealthBelow 20000
			}
			FireInput
			{
				Target player
				Action $DisplayTextChat
				Param "{blue}The Dwarven Chieftain has used his Minicrit Ale!"
				Delay 4
				Repeats 1
				IfHealthBelow 20000
			}
			
			Addcond
			{
				Index 70
			}
			FireInput
			{
				Target !Self
				Action $ChangeAttributes
				Param DeathPhase
				Delay 0.05
				Repeats 1
				IfHealthBelow 1000
			}
		}
	}

