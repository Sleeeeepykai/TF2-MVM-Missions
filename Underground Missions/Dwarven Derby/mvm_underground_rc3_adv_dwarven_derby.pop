 // Underground Mission - Dwarven Derby by Sleeeepykai
 // Spawnpoints on Underground: spawnbot, spawnbot_giant, spawnbot_side, spawnbot_giant_side, spawnbot_invasion, spawnbot_mission_sniper, spawnbot_mission_spy

#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 800
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom no
	WaveStartCountdown 5

	ExtraSpawnPoint
	{
		Name dwarfchiefspawn
		TeamNum 3

		X "1009.52"
		Y "-2249.80"
		Z "-62.57"
	}
	
	PrecacheSound "freeze_cam/dwarf_chief_battlecry.wav"
	PrecacheSound "freeze_cam/dwarf_chief_buff.wav"
	PrecacheSound "freeze_cam/dwarf_chief_minigunequip.wav"
	PrecacheSound "freeze_cam/dwarf_chief_deathcry.wav"

    Mission // Sentry Buster
	{
		Objective DestroySentries

		InitialCooldown 30
		Where spawnbot
		BeginAtWave 1
		RunForThisManyWaves 5

		CooldownTime 40            

        TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}
    Mission // Sniper Wave 2
	{
		Objective Sniper

		InitialCooldown 16
		Where spawnbot_mission_sniper
		BeginAtWave 2
		RunForThisManyWaves 1
		CooldownTime 16
		DesiredCount 2

		TFBot
		{
			Template T_TFBot_Sniper
			Skill Hard
	    }
    }
	Mission // Spy Wave 3
	{
		Objective Spy

		InitialCooldown 20
		Where spawnbot_mission_spy
		BeginAtWave 3
		RunForThisManyWaves 1
		CooldownTime 32
		DesiredCount 2

		TFBot
		{
			Class Spy
            Skill Expert
	    }
    }
    Mission // Engineer Wave 4
	{
		Objective Engineer  

		InitialCooldown 24
		Where spawnbot_side
		BeginAtWave 4
		RunForThisManyWaves 1
		CooldownTime 16
		DesiredCount 1

		TFBot
		{
			Template T_TFBot_Engineer_Sentry_Teleporter
			TeleportWhere spawnbot
			TeleportWhere spawnbot_side
			TeleportWhere spawnbot_invasion
		}
	}

