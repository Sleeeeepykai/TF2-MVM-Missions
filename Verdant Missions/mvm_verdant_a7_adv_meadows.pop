#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop
#base robot_giant_custom_kai.pop
#base robot_standard_custom_kai.pop
#base robot_standard_custom_rafmod_kai.pop
#base robot_giant_custom_rafmod_kai.pop
#base robot_tank_custom_rafmod_kai.pop

WaveSchedule
{
	StartingCurrency 2000
	RespawnWaveTime 1
	FixedRespawnWaveTime Yes

	CanBotsAttackWhileInSpawnRoom No

	AddSentryBusterWhenDamageDealtExceeds 6000
    AddSentryBusterWhenKillCountExceeds 20

	WaveStartCountdown 5

	MaxRedPlayers 6
	AllowBotExtraSlots 1
	RobotLimit 75

	BodyPartScaleSpeed 10

	//// PRECACHES ////

	//// DISABLED VOICELINES ////
	DisableSound "Announcer.MVM_Tank_Alert_Another"
	DisableSound "Announcer.MVM_Tank_Alert_Multiple"
	DisableSound "Announcer.MVM_Tank_Alert_Halfway_Multiple" 
	DisableSound "Announcer.MVM_General_Destruction"

	//// CUSTOM WEAPONS ////

	//// POINT TEMPLATES ////

	PointTemplates
	{
		MissionIntro_PTs
		{
			logic_relay
			{
				"targetname" "Intro_Relay"

				"OnTrigger" "Intro_Annotation1,Show,,0,-1"
				"OnTrigger" "Intro_Annotation2,Show,,2,-1"
				"OnTrigger" "Intro_Annotation3,Show,,6,-1"
				"OnTrigger" "Intro_Annotation4,Show,,10,-1"
			}
			training_annotation
			{
				"targetname" "Intro_Annotation1"
				"origin" "0 4478 1280"
				"display_text" "hi :)"
				"lifetime" "2"
			}
			training_annotation
			{
				"targetname" "Intro_Annotation2"
				"origin" "0 4478 1280"
				"display_text" "I wanted to let you know that there's a LOT of robots active this mission."
				"lifetime" "4"
			}
			training_annotation
			{
				"targetname" "Intro_Annotation3"
				"origin" "0 4478 1280"
				"display_text" "So, I made all non-giants Marked for Death and autocollect their money!"
				"lifetime" "4"
			}
			training_annotation
			{
				"targetname" "Intro_Annotation4"
				"origin" "0 4478 1280"
				"display_text" "Have fun! :D"
				"lifetime" "2"
			}
		}
	}

	//// SPAWNED POINT TEMPLATES ////

	SpawnTemplate "MissionIntro_PTs"

	//// ROBOT TEMPLATES ////

	Templates
	{
		T_TFBot_Heavy_SuperScout
		{
			Name "Super Fat Scout"
			Class Heavy
			ClassIcon scout_fish_nys
			Skill Easy
			Health 600
			Scale 1.4
			WeaponRestrictions MeleeOnly

			Item "Prinny Machete"
			Item "Batter's Helmet"

			CharacterAttributes
			{
				"move speed bonus" 3
			}
			ItemAttributes
			{
				ItemName "Prinny Machete"
				"fire rate bonus" 0.5
				"damage penalty" 0.54
				"custom item model" "models/workshop/weapons/c_models/c_holymackerel/c_holymackerel.mdl"
				"custom hit sound" "Weapon_HolyMackerel.HitFlesh"
				"custom kill icon" "holymackerel"
			}
		}

		T_TFBot_Giant_Soldier_SpreadShot
		{
			Name "Giant Spread-Shot Soldier"
			Class Soldier
			ClassIcon soldier_burstfire_spammer
			Skill Expert
			Health 4000
			Attributes MiniBoss
			WeaponRestrictions PrimaryOnly

			AimAt Body

			CharacterAttributes
			{
				"move speed penalty" 0.5
				"damage force reduction" 0.4
				"airblast vulnerability multiplier" 0.4
				"override footstep sound set" 3
			}

			ItemAttributes
			{
				ItemName "TF_WEAPON_ROCKETLAUNCHER"
				"fire rate bonus" 0.5
				"faster reload rate" 0.001
				"projectile speed decreased" 0.65
				"mult projectile count" 3
				"ignores other projectiles" 1
				"spread angle pattern" "5 -5 0|5 5 0|-5 0 0|0 -3 0|0 0 0|0 3 0|-5 -5 0|-5 5 0|5 0 0|0 -3 0|0 0 0|0 3 0"
				"shoot pattern reset time" 5
			}
		}

		T_TFBot_Giant_Sniper_Plasma
		{
			Name "Giant Plasma Sniper"
			Class Sniper
			ClassIcon sniper_explosion_hyper
			Skill Expert
			Health 3000
			Attributes MiniBoss
			WeaponRestrictions PrimaryOnly

			Item "The AWPer Hand"

			CharacterAttributes
			{
				"damage force reduction" 0.7
				"airblast vulnerability multiplier" 0.7
				"override footstep sound set" 5
			}

			ItemAttributes
			{
				ItemName "The AWPer Hand"

				"override projectile type" 2
			}
		}
	}

	//// MISSION BOTS ////

	Mission // Sentry Buster
	{
		Objective DestroySentries
		Where spawnbot_mission_sentrybuster
		BeginAtWave 1
		RunForThisManyWaves 8
		InitialCooldown 30
		CooldownTime 30
		DesiredCount 1
		
		TFBot
		{
			Template T_TFBot_SentryBuster
		}
	}

	//// WAVES ////

	// General Notes

	// Wave 1 Notes
	Wave
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_left_relay`, `Trigger`, null, 6.1)
				  "
		}
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
					EntFire(`Intro_Relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

