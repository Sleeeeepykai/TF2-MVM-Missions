	// Wave 4 Notes
	Wave
	{
		InitWaveOutput
		{
			Target BigNet
			Action RunScriptCode
			Param "
					EntFire(`bombpath_clearall_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_arrows_clear_relay`, `Trigger`, null, 6)
					EntFire(`bombpath_right_relay`, `Trigger`, null, 6.1)

					local ent = Entities.FindByClassname(null, `item_teamflag`)
					ent.AcceptInput(`RunScriptFile`, `bombhop.nut`, null, null)
					if (!(`SetParams` in ent.GetScriptScope())) return
					ent.GetScriptScope().SetParams(
						[`hoptime_max`, 20]
					)
				  "
		}
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)
                  "
        }

		WaveSpawn // 1 Spread Shot Soldier and 2 GRegen Medics
