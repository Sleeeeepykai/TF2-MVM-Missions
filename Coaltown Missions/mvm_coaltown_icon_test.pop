#base robot_giant_vanilla_kai.pop
#base robot_standard_vanilla_kai.pop

WaveSchedule
{
    StartingCurrency 800
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    NetProps.SetPropString(Entities.FindByClassname(null, `tf_objective_resource`), `m_iszMvMPopfileName`, `Icon Test`)
                  "
        }
		StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_combat_minigun_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_combat_dragon_fury_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_combat_railgun_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_combat_rocket_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_drill_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                Attributes MiniBoss
                ClassIcon tank_helicopter_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            Tank
            {
                Name "tankboss"
                Health 30000
                Speed 75
                StartingPathTrackNode "boss_path_1"
            }
        }

        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                ClassIcon soldier_directhit_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
                ClassIcon demo_stickybomb_kai
            }
        }
        WaveSpawn
        {
            Name "Wave1"
            TotalCount 1
            MaxActive 1
            SpawnCount 1

            TFBot
            {
                Template T_TFBot_Scout_Melee
