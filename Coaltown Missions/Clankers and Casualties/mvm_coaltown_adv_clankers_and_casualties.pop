    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action runscriptcode
            Param "
            IncludeScript(`tankextensions_main`, getroottable())
            IncludeScript(`tankextensions/combattank`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/railgun`, getroottable())

            TankExt.CreateLoopPaths({
                tank_loop = [
                Vector(64, 3648, 128)
                Vector(64, 3104, 128) // Kaboom
                Vector(64, 960, 512)
                Vector(0, 832, 544)
                Vector(-128, 736, 608)
                Vector(-224, 704, 640)
                Vector(-480, 704, 608)
                Vector(-704, 512, 608)
                Vector(-800, 288, 576)
                Vector(-928, 0, 576)
                Vector(-896, -832, 576)
                Vector(-864, -1024, 576)
                Vector(-768, -1120, 576)
                Vector(-608, -1152, 576)
                Vector(608, -1152, 576)
                Vector(864, -1120, 544)
                Vector(992, -1024, 576)
                Vector(1056, -800, 544)
                Vector(1056, -416, 576)
                Vector(1056, -32, 480)
                Vector(992, 160, 512)
                Vector(864, 352, 512)
                Vector(672, 544, 480)
                Vector(448, 704, 480)
                Vector(0, 832, 544)
                ]
            })

            EntFire(`tank_loop_2`, `AddOutput`, `OnPass tank_bust_relay:Trigger:0:-1`, 0, null)
                "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        // Subwave 1
        WaveSpawn // 4 Doctor Barrages
        {
            Name "Wave6_Subwave1_DoctorBarrage"
            Where spawnbot_giant
            TotalCount 4
            MaxActive 4
            SpawnCount 1
            WaitBeforeStarting 8
            WaitBetweenSpawns 0.1
            TotalCurrency 160

            TFBot
            {
                Template T_TFBot_Giant_Medic_SlowBarrage
            }
        }
        WaveSpawn // 12 Heavies
        {
            Name "Wave6_Subwave1_Heavies"
            Where spawnbot
            TotalCount 12
            MaxActive 12
            SpawnCount 12
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 120

            TFBot
            {
                Class Heavy
                Skill Normal
            }
        }
        WaveSpawn // 2 Colonel Barrages and 4 Uber Medics
        {
            Name "Wave4_Subwave1_ColonelBarrages"
            WaitForAllSpawned "Wave6_Subwave1_DoctorBarrage"
            Where spawnbot
            TotalCount 6
            MaxActive 6
            SpawnCount 3
            WaitBeforeStarting 16
            WaitBetweenSpawns 0
            TotalCurrency 160

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Soldier_SlowBarrage
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
            }
        }
        WaveSpawn // 12 Heavies
        {
            Name "Wave6_Subwave1_Heavies"
            WaitForAllSpawned "Wave6_Subwave1_DoctorBarrage"
            Where spawnbot
            TotalCount 12
            MaxActive 12
            SpawnCount 12
            WaitBeforeStarting 16
            WaitBetweenSpawns 0
            TotalCurrency 120

            TFBot
            {
                Class Heavy
                Skill Normal
            }
        }

        // Subwave 2
        WaveSpawn // 1 Tank
        {
            Name "Wave6_Subwave2_Tank"
            WaitForAllSpawned "Wave4_Subwave1_ColonelBarrages"
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 20
            WaitBetweenSpawns 0
            TotalCurrency 100

            FirstSpawnWarningSound "mvm/mvm_tank_start.wav"

            Tank
            {
                Name "tankboss"
                Health 30000
                Speed 75
                Skin 1
                StartingPathTrackNode "boss_path_1"

                OnBombDroppedOutput
                {
                    Target boss_deploy_relay
                    Action Trigger
                }
            }
        }
        WaveSpawn // 1 Rocket Railgun Tank
        {
            Name "Wave6_Subwave2_RocketRailgunTank"
            WaitForAllSpawned "Wave6_Subwave2_Tank"
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 8
            WaitBetweenSpawns 0
            TotalCurrency 100

            FirstSpawnWarningSound "mvm/mvm_tank_start.wav"

            Tank
            {
                Name "combattank|rocketpod|railgun"
                Health 40000
                Speed 75
                Skin 1
                StartingPathTrackNode "tank_loop_1"
                ClassIcon tank_combat_rocket_railgun [$SIGSEGV]
            }
        }
        WaveSpawn // 12 Buff Banners Flanking Left
        {
            Name "Wave6_Subwave2_BuffBanners"
            WaitForAllSpawned "Wave6_Subwave2_RocketRailgunTank"
            Where spawnbot
            TotalCount 12
            MaxActive 6
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 2
            TotalCurrency 60

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Buff_Banner
                Skill Hard
                BehaviorModifiers Push
                Tag nav_prefer_flank_left
            }
        }
        WaveSpawn // 12 Buff Banners Flanking Right
        {
            Name "Wave6_Subwave2_BuffBanners"
            WaitForAllSpawned "Wave6_Subwave2_RocketRailgunTank"
            Where spawnbot
            TotalCount 12
            MaxActive 6
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 2
            TotalCurrency 60

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Buff_Banner
                Skill Hard
                BehaviorModifiers Push
                Tag nav_prefer_flank_right
            }
        }

        // Subwave 3
        WaveSpawn // 2 GHeavies and 2 Uber Medics
        {
            Name "Wave6_Subwave3_GHeavies"
            WaitForAllSpawned "Wave6_Subwave2_BuffBanners"
            Where spawnbot
            TotalCount 4
            MaxActive 4
            SpawnCount 2
            WaitBeforeStarting 16
            WaitBetweenSpawns 0.1
            TotalCurrency 80

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Heavyweapons
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
            }
        }
        WaveSpawn // 24 Conches
        {
            Name "Wave6_Subwave3_Conches"
            WaitForAllSpawned "Wave6_Subwave2_BuffBanners"
            Where spawnbot
            TotalCount 24
            MaxActive 12
            SpawnCount 3
            WaitBeforeStarting 16
            WaitBetweenSpawns 4
            TotalCurrency 120

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Concheror
                Skill Hard
            }
        }
        WaveSpawn // 2 GHeavies and 6 Uber Medics
        {
            Name "Wave6_Subwave3_GHeavies2"
            WaitForAllSpawned "Wave6_Subwave3_GHeavies"
            Where spawnbot_giant
            TotalCount 8
            MaxActive 8
            SpawnCount 4
            WaitBeforeStarting 16
            WaitBetweenSpawns 0.1
            TotalCurrency 120

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Heavyweapons
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
                TFBot
                {
                    Template T_TFBot_Medic
                }
            }
        }
    }
}