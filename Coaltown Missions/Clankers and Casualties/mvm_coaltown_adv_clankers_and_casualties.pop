#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 400
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No
    AddSentryBusterWhenDamageDealtExceeds 5000
    AddSentryBusterWhenKillCountExceeds 15

    //// PRECACHES ////

    //// ROBOT TEMPLATES ////

    Templates
    {
        T_TFBot_Giant_Medic_SlowBarrage
        {
            Name "Doctor Barrage"
            Class Medic
            ClassIcon medic_crossbow_barrage
            Skill Expert
            Health 4000
            Scale 1.75
            WeaponRestrictions PrimaryOnly
            Attributes HoldFireUntilFullReload
            Attributes MiniBoss
            Item "The Crusader's Crossbow"
            Item "Medical Monarch"
            Item "Berliner's Bucket Helm"

            CharacterAttributes
            {
                "health regen" 37
                "move speed bonus" 0.5
                "damage force reduction" 0.4
                "airblast vulnerability multiplier" 0.4
                "override footstep sound set" 3
            }
            ItemAttributes
            {
                ItemName "The Crusader's Crossbow"
                "damage bonus" 1.5
                "fire rate bonus" 0.4
                "faster reload rate" 0.1
                "Clip size upgrade atomic" 29.0
                "Projectile speed increased" 0.25
                "projectile spread angle penalty" 5
                "projectile gravity" 10
            }
        }
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_giant
        BeginAtWave 1
        RunForThisManyWaves 6
        DesiredCount 1

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_SentryBuster
        }   
    }
    Mission // Spy (Wave 2)
    {
        Objective Spy
        Where spawnbot_mission_spy
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 4

        InitialCooldown 8
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Spy
        }   
    }
    Mission // Sniper (Wave 3)
    {
        Objective Sniper
        Where spawnbot_mission_sniper
        BeginAtWave 3
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 8
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Sniper
        }   
    }
    Mission // Spy (Wave 5)
    {
        Objective Spy
        Where spawnbot_mission_spy
        BeginAtWave 5
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 8
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Spy
        }   
    }

    //// WAVES ////

    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    NetProps.SetPropString(Entities.FindByClassname(null, `tf_objective_resource`), `m_iszMvMPopfilename`, `Clankers and Casualties (Adv)`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        // Subwave 1
        WaveSpawn // 1 Tank
        {
            Name "Wave1_Subwave1_Tank"
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 200

            FirstSpawnWarningSound "mvm/mvm_tank_start.wav"

            Tank
            {
                Name "tankboss"
                Health 20000
                Speed 75
                StartingPathTrackNode "boss_path_1"

                OnBombDroppedOutput
                {
                    Target boss_deploy_relay
                    Action Trigger
                }
            }
        }
        WaveSpawn // 32 Demomen
        {
            Name "Wave1_Subwave1_Demomen"
            Where spawnbot
            TotalCount 32
            MaxActive 8
            SpawnCount 2
            WaitBeforeStarting 0
            WaitBetweenSpawns 2
            TotalCurrency 240

            TFBot
            {
                Class Demoman
                Skill Easy
            }
        }

        WaveSpawn // 2 GSoldiers
        {
            Name "Wave1_Subwave1_GSoldier"
            WaitForAllSpawned "Wave1_Subwave1_Tank"
            Where spawnbot
            TotalCount 2
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 16
            TotalCurrency 160

            TFBot
            {
                Template T_TFBot_Giant_Soldier
            }
        }

        WaveSpawn // 1 GSoldier and 4 Pyros
        {
            Name "Wave1_Subwave2_GSoldierSquad"
            WaitForAllSpawned "Wave1_Subwave1_GSoldier"
            Where spawnbot
            TotalCount 5
            MaxActive 5
            SpawnCount 5
            WaitBeforeStarting 16
            WaitBetweenSpawns 0
            TotalCurrency 120

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_Soldier
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
                TFBot
                {
                    Class Pyro
                    Skill Easy
                }
            }
        }
        WaveSpawn // 16 Pyros
        {
            Name "Wave1_Subwave2_Pyros"
            WaitForAllSpawned "Wave1_Subwave1_GSoldier"
            Where spawnbot
            TotalCount 16
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 1
            TotalCurrency 80

            TFBot
            {
                Class Pyro
                Skill Easy
            }
        }
    }
    Wave
    {
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }
        
        // Subwave 1
        WaveSpawn // 12 Conches
        {
            Name "Wave2_Subwave1_Conches"
            Where spawnbot
            TotalCount 12
            MaxActive 12
            SpawnCount 12
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
            TotalCurrency 60

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Concheror
            }
        }
        WaveSpawn // 1 Major League
        {
            Name "Wave2_Subwave1_MajorLeague"
            Where spawnbot
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 4
            WaitBetweenSpawns 0
            TotalCurrency 140

            TFBot
            {
                Template T_TFBot_Giant_Scout_Baseball
            }
        }

        WaveSpawn // 1 Major League
        {
            Name "Wave2_Subwave1_MajorLeague2"
            WaitForAllSpawned "Wave2_Subwave1_Conches"
            Where spawnbot
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 0
            TotalCurrency 120

            TFBot
            {
                Template T_TFBot_Giant_Scout_Baseball
            }
        }
        WaveSpawn // 10 Conches and 10 Punchies
        {
            Name "Wave2_Subwave1_Conches"
            WaitForAllSpawned "Wave2_Subwave1_MajorLeague"
            Where spawnbot
            TotalCount 20
            MaxActive 20
            SpawnCount 2
            WaitBeforeStarting 16
            WaitBetweenSpawns 2
            TotalCurrency 200

            RandomChoice
            {
                Shuffle 1 [$SIGSEGV]

                TFBot
                {
                    Template T_TFBot_Soldier_Extended_Concheror
                }
                TFBot
                {
                    Template T_TFBot_Heavyweapons_Heavyweight_Champ
                }
            }
        }

        // Subwave 2
        WaveSpawn // 2 GPyros
        {
            Name "Wave2_Subwave2_GPyros"
            WaitForAllSpawned "Wave2_Subwave1_MajorLeague2"
            Where spawnbot_giant
            TotalCount 2
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 16
            TotalCurrency 120

            TFBot
            {
                Template T_TFBot_Giant_Pyro
                Attributes AlwaysFireWeapon
            }
        }
        WaveSpawn // 8 Conches
        {
            Name "Wave2_Subwave2_Conches"
            WaitForAllSpawned "Wave2_Subwave1_MajorLeague2"
            Where spawnbot
            TotalCount 8
            MaxActive 8
            SpawnCount 1
            WaitBeforeStarting 16
            WaitBetweenSpawns 1
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Concheror
            }
        }
        WaveSpawn // 16 Conches
        {
            Name "Wave2_Subwave2_Conches2"
            WaitForAllSpawned "Wave2_Subwave2_Conches"
            Where spawnbot
            TotalCount 16
            MaxActive 16
            SpawnCount 16
            WaitBeforeStarting 4
            WaitBetweenSpawns 0
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Soldier_Extended_Concheror
            }
        }
    }
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action runscriptcode
            Param "
            IncludeScript(`tankextensions_main`, getroottable())
            IncludeScript(`tankextensions/combattank`, getroottable())
            IncludeScript(`tankextensions/combattank_weapons/rocketpod`, getroottable())

            TankExt.CreateLoopPaths({
                tank_loop = [
                Vector(64, 3648, 128)
                Vector(64, 3104, 128) // Kaboom
                Vector(64, 960, 512)
                Vector(0, 832, 544)
                Vector(-128, 736, 608)
                Vector(-224, 704, 640)
                Vector(-480, 704, 608)
                Vector(-704, 512, 608)
                Vector(-800, 288, 576)
                Vector(-928, 0, 576)
                Vector(-896, -832, 576)
                Vector(-864, -1024, 576)
                Vector(-768, -1120, 576)
                Vector(-608, -1152, 576)
                Vector(608, -1152, 576)
                Vector(864, -1120, 544)
                Vector(992, -1024, 576)
                Vector(1056, -800, 544)
                Vector(1056, -416, 576)
                Vector(1056, -32, 480)
                Vector(992, 160, 512)
                Vector(864, 352, 512)
                Vector(672, 544, 480)
                Vector(448, 704, 480)
                Vector(0, 832, 544)
                ]
            })

            EntFire(`tank_loop_2`, `AddOutput`, `OnPass tank_bust_relay:Trigger:0:-1`, 0, null)
                "
