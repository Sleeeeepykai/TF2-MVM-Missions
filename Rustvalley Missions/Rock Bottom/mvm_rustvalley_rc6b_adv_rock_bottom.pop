		// Ending Sequence
		WaveSpawn // The Troll
		{
			Name "Wave5_End"
			WaitForAllSpawned "Wave5_Check"
			Where spawnbot_main_slow1
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 0
			TotalCurrency 0

			FirstSpawnWarningSound "vo/mvm/mght/demoman_mvm_m_specialcompleted02.mp3"

			TFBot
			{
				Name "The CHARGING Demo?"
				Template T_TFBot_Demoknight_Caber_Crazy
				Health 1
				Scale 2
				Attributes MiniBoss
				Attributes UseBossHealthBar

				Action Mobber

				Addcond
				{
					Index 51
				}

				CharacterAttributes
				{
					"move speed penalty" 0.5
					"damage force reduction" 0.5
					"airblast vulnerability multiplier" 0.5
					"override footstep sound set" 4
					"displace touched enemies" 1
				}

				ItemAttributes
				{
					ItemName "The Splendid Screen"
					"charge recharge rate increased" 0.0001
					"attack not cancel charge" 1
				}

				ItemAttributes
				{
					ItemName "The Ullapool Caber"
					"fire rate penalty" 2.5
					"damage bonus" 5
					"dmg bonus vs buildings" 5
					"blast dmg to self increased" 2.0
					"blast radius increased" 1.25
					"use large smoke explosion" 1
					"regenerate stickbomb" 1
					"custom impact sound" "misc/doomsday_missile_explosion.wav"
				}

				InterruptAction
				{
					Target "-1318 1250 -297"
					Delay 0.5
					Repeats 1
					Cooldown -1
					Distance 100
					Duration 0.1
					WaitUntilDone 0.1
					OnDoneChangeAttributes "Kablooey"
				}

				EventChangeAttributes
				{
					Kablooey [$SIGSEGV]
					{
						FireInput
						{
							Target !self
							Action $TauntFromItem
							Param "The Ullapool Caber"
							Delay 0.2
							Repeats 0
							Cooldown 0.5
						}
						FireInput
						{
							Target tf_gamerules
							Action PlayVO
							Param "mvm/sentrybuster/mvm_sentrybuster_spin.wav"
							Delay 0.2
							Repeats 1
							Cooldown -1
						}

						FireInput
						{
							Target !self
							Action $Suicide
							Delay 2.2
							Repeats 1
							Cooldown -1
						}
					}
				}
			}

			DoneOutput
			{
				Target "BarrierDestructionRelay"
				Action Trigger
			}
		}

		WaveSpawn
		{
			WaitForAllDead "Wave5_End"
			WaitBeforeStarting 5
		}
	}
