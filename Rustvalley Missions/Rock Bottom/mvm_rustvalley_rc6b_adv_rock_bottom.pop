			{
				Class Heavy
				Skill Easy
			}
		}
		WaveSpawn // 1 Giant Shotgun Pyro
		{
			Name "Wave1_Subwave1_GShotgun2"
			WaitForAllSpawned "Wave1_Subwave1_Heavies"
