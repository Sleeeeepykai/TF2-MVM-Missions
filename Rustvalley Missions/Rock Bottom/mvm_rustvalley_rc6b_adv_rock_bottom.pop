			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 5
			WaitBetweenSpawns 0
			TotalCurrency 40

			TFBot
			{
				Name "Giant Shotgun Pyro"
				Template T_TFBot_Giant_Pyro
				ClassIcon heavy_shotgun_giant
				Attributes HoldFireUntilFullReload
				WeaponRestrictions SecondaryOnly
			}
		}

		WaveSpawn // 10 Charging Demos
		{
			Name "Wave1_Subwave1_ChargingDemos"
			WaitForAllSpawned "Wave1_Subwave1_GShotgun2"
			Where spawnbot_left0
			TotalCount 10
			MaxActive 10
			SpawnCount 5
			WaitBeforeStarting 5
			WaitBetweenSpawns 8
			TotalCurrency 20

			TFBot
			{
				Name "Charging Demo"
				Template T_TFBot_Demoman_Knight
				ClassIcon demoknight_bottle_lite

				Item "The Splendid Screen"
				Item "TF_WEAPON_BOTTLE"
			}
		}

		// Subwave 2
		WaveSpawn // 8 GRU Heavies and 8 Kritzkrieg Medics
		{
			Name "Wave1_Subwave2_GRUHeavies"
			WaitForAllDead "Wave1_Subwave1_GShotgun2"
			Where spawnbot_mid0
			TotalCount 16
			MaxActive 8
			SpawnCount 2
			WaitBeforeStarting 4
			WaitBetweenSpawns 3
			TotalCurrency 160

			Squad
			{
				TFBot
				{
					Template T_TFBot_Heavy_Heavyweight_Champ_Fast
				}
				TFBot
				{
					Template T_TFBot_Medic_Kritzkrieg
				}
			}
		}
		WaveSpawn // 12 Heavies
		{
			Name "Wave1_Subwave2_Heavies"
			WaitForAllDead "Wave1_Subwave1_GShotgun2"
