			Tank
			{
				Name "tankboss"
				Health 40000
				Scale 0.5
				Speed 75
				DisableSmokeStack 1
				StartingPathTrackNode "path_tank_1"

				OnBombDroppedOutput
				{
					Target boss_deploy_relay
