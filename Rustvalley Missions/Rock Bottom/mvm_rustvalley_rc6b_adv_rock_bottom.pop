				}
				TFBot
				{
					Template T_TFBot_Giant_Pyro_Flare_Spammer
				}
				TFBot
				{
					Template T_TFBot_Giant_Pyro_Flare_Spammer
				}
			}
		}

		WaveSpawn // 3 GRU Heavies and 3 Kritzkrieg Medics
		{
			Name "Wave1_Subwave2_GRUHeavies2"
			WaitForAllSpawned "Wave1_Subwave2_GRapidSoldierSquad"
			Where spawnbot_left0
			TotalCount 6
			MaxActive 6
			SpawnCount 6
