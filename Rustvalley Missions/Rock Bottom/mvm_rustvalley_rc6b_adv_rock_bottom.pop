			Tank
			{
				Name "combattank_bomb|minigun|minigun$pingsound|npc/combine_gunship/ping_search.wav"
				Health 18000
				ClassIcon tank_combat_minigun_dual_kai
				Scale 0.5
				Speed 75
				DisableSmokeStack 1
				StartingPathTrackNode "path_tank_cliff_1"

