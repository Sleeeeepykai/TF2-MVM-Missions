                        "stomp player force" 270

                        // Damage applied to enemies when touching them
                        "stomp player time" 3
                        "stomp player damage" 10

                    }
                    Item "TF_WEAPON_GRENADELAUNCHER"
                    ItemAttributes
                    {
                        "add cond when active" 79
                        
                        "mult stun resistance" 0.2
