				"rendercolor" "255 0 0"
				"spawnflags" "9"
			}
            game_text
			{
				"origin" "1984 1984 99999"
				"targetname" "panic_text"
				"message" "SWITCHING LOSE CONDITIONS..."
				"x" "-1"
				"y" "0.2"
				"spawnflags" "1"
				"effect" "0"
				"channel" "2"
				"color" "255 255 255"
				"fadeout" "0.2"
				"fadein" "0.2"
				"holdtime" "0.2"
			}
            logic_relay
            {
                "targetname" "losecondtimer"
                "OnTrigger"  "switchingthatloosecond,trigger,,0,-1"
                "OnTrigger"  "!self,trigger,,60,-1"
                "spawnflags" "2"
            }
            logic_relay // Blinking Red Warning
			{
				"targetname"	"switchingthatloosecond"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,0.05,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,0.75,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,1.45,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,2.15,-1"
                "OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,2.85,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,3.55,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,0,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,0,-1"
				"OnTrigger"	"panic_fade,fade,,0.05,-1"
				"OnTrigger"	"panic_fade,fade,,0.75,-1"
				"OnTrigger"	"panic_fade,fade,,1.45,-1"
				"OnTrigger"	"panic_fade,fade,,2.15,-1"
                "OnTrigger"	"panic_fade,fade,,2.85,-1"
                "OnTrigger"	"panic_fade,fade,,3.55,-1"
                "OnTrigger"  "panic_text,display,,0.05,-1"
                "OnTrigger"  "panic_text,display,,0.75,-1"
                "OnTrigger"  "panic_text,display,,1.45,-1"
                "OnTrigger"  "panic_text,display,,2.15,-1"
                "OnTrigger"  "panic_text,display,,2.85,-1"
                "OnTrigger"  "panic_text,display,,3.55,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,7,-1"
                "OnTrigger"  "LoseConditionCase,pickrandomshuffle,,7,-1"
			}
            logic_relay // Blinking Red Warning
			{
				"targetname"	"switchingtothetimer"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,0.05,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,0.75,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,1.45,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,2.15,-1"
                "OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,2.85,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,ambient\alarms\klaxon1.wav,3.55,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,0,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,0,-1"
				"OnTrigger"	"panic_fade,fade,,0.05,-1"
				"OnTrigger"	"panic_fade,fade,,0.75,-1"
				"OnTrigger"	"panic_fade,fade,,1.45,-1"
				"OnTrigger"	"panic_fade,fade,,2.15,-1"
                "OnTrigger"	"panic_fade,fade,,2.85,-1"
                "OnTrigger"	"panic_fade,fade,,3.55,-1"
                "OnTrigger"  "panic_text,display,,0.05,-1"
                "OnTrigger"  "panic_text,display,,0.75,-1"
                "OnTrigger"  "panic_text,display,,1.45,-1"
                "OnTrigger"  "panic_text,display,,2.15,-1"
                "OnTrigger"  "panic_text,display,,2.85,-1"
                "OnTrigger"  "panic_text,display,,3.55,-1"
				"OnTrigger"	"tf_gamerules,PlayVO,mvm\mvm_warning.wav,7,-1"
                "OnTrigger"  "TimerLoseHintTimer,enable,,7,-1"
                "OnTrigger"  "TimerTriggerRelay,trigger,,7,-1"
			}
            logic_relay
            {
                "targetname" "BombLoseConditionRelay"

                "OnTrigger" "BombLoseHintTimer,Enable,,0,-1"
                "OnTrigger" "TimerLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "GateLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "TeamWipeLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "pop_interface,$ResumeWaveSpawn,thebobcarriers,0,-1"
                "OnTrigger" "RedLoseRelay,Disable,,0,-1"
            }
            logic_timer
			{
				"targetname"    "BombLoseHintTimer"
