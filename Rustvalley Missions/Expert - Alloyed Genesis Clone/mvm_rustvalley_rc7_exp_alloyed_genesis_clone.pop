        imlosingitandbyitletsjustsaymyconditions
        {
            OnSpawnOutput
			{
				Target bignet
				Action RunScriptCode
				Param "
				IncludeScript(`textualtimer_v3`, getroottable())
				TextualTimer.SetParams({
					minutes = 1
					seconds = 0
					x = -1
					y = 0.77
					color = `0 255 555`
					text_prepend = `IMMINENT DEATH AND DESTRUCTION: `
					automatic = false 
        		})
				"
			}
            logic_case
            {
                "targetname" "LoseConditionCase"
                "OnCase01" "BombLoseConditionRelay,Trigger,,0,-1"
                "OnCase02" "GateLoseConditionRelay,Trigger,,0,-1"
                "OnCase03" "TeamWipeLoseConditionRelay,Trigger,,0,-1"
