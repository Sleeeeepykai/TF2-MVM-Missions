                "targetname" "GateLoseConditionRelay"

                "OnTrigger" "BombLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "TimerLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "GateLoseHintTimer,Enable,,0,-1"
                "OnTrigger" "TeamWipeLoseHintTimer,Disable,,0,-1"
                "OnTrigger" "pop_interface,$KillWaveSpawn,thebobcarriers,0,-1"
                "OnTrigger" "pop_interface,$PauseWaveSpawn,thebobcarriers,0,-1"
