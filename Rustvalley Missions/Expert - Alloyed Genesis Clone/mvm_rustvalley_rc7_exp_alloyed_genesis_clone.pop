        T_Mighty_Miner_Charger
        {
            CLass Engineer
            classicon 	boss_mecha_miner
            Scale 1.5
            Tag bot_giant
            Health 4000
            UseMeleeThreatPrioritization 1
            Skill Expert
            Attributes	"DisableDodge"
            Name "Charging Mecha Miner"
            //Attributes UseBossHealthBar
            Attributes Miniboss
            Action FetchFlag
            SpawnTemplate templateforminers
            CharacterAttributes
            {
                "move speed bonus"	0.75
                "damage force reduction"	0.5
                "airblast vulnerability multiplier"	0.5
                "override footstep sound set"	4
                "voice pitch scale"	0
            }
            FireInput  
            {
                Target "!self"
                Action "$PlaySequence"
                Param "taunt_vehicle_allclass_start" 
                Delay 4
                Repeats 1
            }
            AddAttribute
            {
                Item Player
                Name "no_attack"
                Value 1
                Delay 4
                Repeats 1
            }
            FireInput
            {
                Target "templateforminers"
                Action "ForceSpawnAtEntityOrigin"
                Param "!activator"
                Delay  4.9
                Repeats 1
            }
            
            EventChangeAttributes
            {
                Underground
                {
                    FireInput //shake
                    {
                        Target "!self"
                        Action "runscriptcode"
                        Param "PrecacheSound(`physics/concrete/concrete_break3.wav`);EmitSoundEx({sound_name=`physics/concrete/concrete_break3.wav`,filter_type=5,origin=self.GetOrigin()})"
                        Delay 0
                        Repeats 1
                    }
                    FireInput //shake
                    {
                        Target "!self"
                        Action "runscriptcode"
                        Param "ScreenShake(self.GetOrigin(), 6, 8, 0.5, 2000, 0, true)"
                        Delay 0
                        Repeats 1
                    }
                    Attributes AlwaysFireWeapon
                   
                    CharacterAttributes
                    {
                        "attach particle effect"	3044
                        "not solid to players" 1
                        "ignored by enemy sentries" 1
                        "dmg taken from self reduced" 0.1
