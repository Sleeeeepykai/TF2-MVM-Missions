        grandfinaleforphase1
        {
            NoFixup 1
			info_target
			{
				"targetname" "alloyedgenesis"
				"origin" "0 0 0"
			}

            OnSpawnOutput
            {
                Target gostraightontothemegalaser
				Action trigger
				Delay 0
            }
			OnSpawnOutput
            {
                Target alloyedgenesis
				Action SetParent
				Param "!activator"
				Delay 0.05
            }
			OnSpawnOutput
            {
                Target temporary_solution
                Action $SetOwner
                Param "@p@alloyedgenesis"
                Delay 0.1
            }

            logic_relay
            {
                "targetname" "AlloyedGenesisAttackInit"

                "OnTrigger" "AlloyedGenesisPhase1AttackPoolRelay,Trigger,,0,-1"
                "OnTrigger" "AlloyedGenesisPhase2AttackPoolRelay,Trigger,,0,-1"
                "OnTrigger" "AlloyedGenesisPhase3AttackPoolRelay,Trigger,,0,-1"

                "spawnflags" "2"
            }

            logic_relay
            {
                "targetname" "AlloyedGenesisPhase1AttackPoolRelay"

                "OnTrigger" "AlloyedGenesisPhase1AttackPool,PickRandomShuffle,,0,-1"

                "spawnflags" "2"
            }
            logic_case
            {
                "targetname" "AlloyedGenesisPhase1AttackPool"

                "OnCase01" "pop_interface,ChangeBotAttributes,specialattackjump_obsolescence,0,-1"
                "OnCase02" "pop_interface,ChangeBotAttributes,splitting_spytosis,0,-1"
                "OnCase03" "pop_interface,ChangeBotAttributes,obsolescence_firingpattern,0,-1"
                "OnCase04" "pop_interface,ChangeBotAttributes,scrappedspybasesequence,0,-1"
                "OnCase05" "pop_interface,ChangeBotAttributes,Barry_DefaultTrolldier,0,-1"
            }

            logic_relay
            {
                "targetname" "AlloyedGenesisPhase2AttackPoolRelay"

                "OnTrigger" "AlloyedGenesisPhase2AttackPool,PickRandomShuffle,,0,-1"

                "spawnflags" "2"
                "startdisabled" "1"
            }
            logic_case
            {
                "targetname" "AlloyedGenesisPhase2AttackPool"

                "OnCase01" "pop_interface,ChangeBotAttributes,scrappedspybasesequence,0,-1"
                "OnCase02" "pop_interface,ChangeBotAttributes,MegaLaserInitPortal,0,-1"
                "OnCase03" "pop_interface,ChangeBotAttributes,axe_attack_foremann,0,-1"
                "OnCase04" "pop_interface,ChangeBotAttributes,overclockeddave_steels,0,-1"
                "OnCase05" "pop_interface,ChangeBotAttributes,john_baseball,0,-1"
                "OnCase06" "pop_interface,ChangeBotAttributes,teleportingallaroundcatchme,0,-1"
                "OnCase07" "pop_interface,ChangeBotAttributes,undergroundblitzinit,0,-1"
            }

            logic_relay
            {
                "targetname" "AlloyedGenesisPhase3AttackPoolRelay"

                "OnTrigger" "AlloyedGenesisPhase3AttackPool,PickRandomShuffle,,0,-1"

                "spawnflags" "2"
                "startdisabled" "1"
            }
            logic_case
            {
                "targetname" "AlloyedGenesisPhase3AttackPool"
            }

            logic_relay
            {
                "targetname" "Phase2TransitionRelay"

                "OnTrigger" "@p@alloyedgenesis,$RemoveCond,7,0,-1"
                "OnTrigger"  "losecondtimer,disable,,0,1"
                "OnTrigger"  "losecondtimer,cancelpending,,0,1"
                "OnTrigger"  "switchingthatloosecond,cancelpending,,0,-1"
                
                "OnTrigger" "jumpattack,CancelPending,,0,-1"
