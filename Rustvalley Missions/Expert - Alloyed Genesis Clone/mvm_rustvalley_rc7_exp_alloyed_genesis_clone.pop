        ubergeneratortutorial_template_2
		{
			RemoveIfKilled "uber_generating_for_boss"
			OnSpawnOutput
			{
				target boss_hint
				action Show
			}
			training_annotation
			{
				"targetname"   "boss_hint"
				"display_text" "Uber Generator!"
				"lifetime"     "8"
				"origin" "0 0 0"
			}
			OnSpawnOutput
			{
				Target "tf_gamerules"
				Action "PLayVO"
				Param "mvm\mvm_tele_deliver.wav"
			}
			OnSpawnOutput
			{
				Target flag_glow
				Action Enable
				Delay 1
			}
			OnSpawnOutput
			{
				Target "uber_generating_for_boss"
				Action "Sethealth"
				Param 1000 // Fuck you 6k hp // 864, It's too tanky :
			}
            OnSpawnOutput
			{
				Target "spawnsentry"
				Action "Sethealth"
				Param 400 // Fuck you 6k hp // 864, It's too tanky :
			}
			OnSpawnOutput
			{
				Target "uber_generating_for_boss"
				Action "$setmodeloverride"
				Param "models/buildables/amplifier_test/amplifier.mdl"
			}
            obj_sentrygun
            {
                "targetname" "spawnsentry"
                "origin" "0 100 0"
                "teamnum" "3"
                "spawnflags" "8"
                "SolidToPlayer" "1"
                "defaultupgrade" "2"
                "modelscale" "1"
                "$bulletweapon" "tf_weapon_rocketlauncher"
                "$fireratemult" "2.76"
                "$damagemult" "1.5"
            }
			tf_glow
            {
                "GlowColor" "0 176 199 255"
                "target" "uber_generating_for_boss"
				"targetname" "flag_glow"
				"startdisabled" "1"
            }
			obj_dispenser
			{
				"targetname" "uber_generating_for_boss"
				"origin" "0 0 0"
				"teamnum" "3"
				"SolidToPlayer" "0"
				"defaultupgrade" "1"
				"$attributeoverride" 1
				//"$radiusmult" 3
				"OnDestroyed" "ubergen2,Add,1,0,1"
				"OnDestroyed" "tf_gamerules,PlayVO,ambient\machines\thumper_shutdown1.wav,0.1,1"
                "OnDestroyed" "bignet,RunScriptCode,TextualTimer.Add(20),0,-1"
                "OnDestroyed" "tf_gamerules,PlayVO,vo\announcer_time_added.mp3,0,-1"
			}
			info_particle_system
            {
                "targetname"   "beam"
                "origin"       "0 0 0"
                "effect_name"  "teleporter_mvm_bot_persist"
                "start_active" "1"
            }
		}
        allmyteamwipes
        {
            OnSpawnOutput
            {
                Target "TeamWipeCounter"
                Action "Add"
                Param "1"
                Delay 0
                Repeats 1
                Cooldown -1
            }
            OnParentKilledOutput
            {
                Target "TeamWipeCounter"
                Action "Subtract"
                Param "1"
                Delay 0
                Repeats 1
                Cooldown -1
            }

            info_target
            {
                "targetname" "guh"
            }
        }
        damagetheboss
        {
            OnParentKilledOutput
            {
                Target "@p@alloyedgenesis"
                Action $TakeDamage
                Param "3000"
                Repeats 1
                Delay -1
            }
        }
    }
    SpawnTemplate wholemissionsetup
    PlayerSpawnTemplate allmyteamwipes
    Mission // For Wave #
    {
        Where spawnbot_scattered0
        Where spawnbot_main_slow1
        Objective Spy // Engineer,Sniper,Spy,DestroySentries
        BeginAtWave 1
        RunForThisManyWaves 1
        DesiredCount 2
    
        InitialCooldown 90
        CooldownTime 45
    
        TFBot
        { 
            Template T_TFBot_spy
        }
    }
    Mission // For Wave #
    {
        Where spawnbot_scattered0
        Where spawnbot_main_slow1
        Objective Spy // Engineer,Sniper,Spy,DestroySentries
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 3
    
        InitialCooldown 15
        CooldownTime 75
    
        TFBot
        { 
            Template T_TFBot_spy
        }
    }
    Mission // For Wave #
    {
        Where spawnbot_scattered0
        Where spawnbot_main_slow1
        Objective Engineer // Engineer,Sniper,Spy,DestroySentries
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 1
    
        InitialCooldown 75
        CooldownTime 60
    
        TFBot
        { 
            Template T_TFBot_Engineer_Sentry_Teleporter
        }
    }
    Wave // Wave 1
    {
        CustomMaxWaveNumber 3
        StartWaveOutput
        {
            Target wave_start_relay_expert
            Action Trigger
        }
        DoneOutput
        {
            Target wave_finished_relay
            Action Trigger
        }
        InitWaveOutput
        {
            Target bignet
            Action RunScriptCode
            Param "
                IncludeScript(`tankextensions_main`, getroottable())
                IncludeScript(`tankextensions/gatetank`, getroottable())
                local bomb = Entities.FindByName(null, `intel_classic`)
                bomb.AcceptInput(`RunScriptFile`, `bombhop.nut`, null, null)
            "
        }
        WaveSpawn
        {
            Name "w1a"
            Where spawnbot_boss0
            TotalCount 1
            MaxActive 1
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0
        
            TotalCurrency 50
        
            TFBot
            { 
                Template T_Mighty_Miner
                Tag bot_giant
            }
        }
        WaveSpawn
        {
            Name "w1aa"
            Where spawnbot_left0
            Where spawnbot_right0
