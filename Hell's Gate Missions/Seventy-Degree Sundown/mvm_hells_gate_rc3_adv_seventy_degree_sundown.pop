#base robot_standard.pop
#base robot_giant.pop

WaveSchedule
{
    StartingCurrency 500
    RespawnWaveTime 2
    CanBotsAttackWhileInSpawnRoom No

    AddSentryBusterWhenDamageDealtExceeds 5000
    AddSentryBusterWhenKillCountExceeds 15

    //// PRECACHES ////

    //// PRECACHED MODELS ////

    PrecacheModel "models/bots/boss_helicopter/boss_helicopter.mdl" [$SIGSEGV]

    //// ROBOT TEMPLATES ////

    Templates
    {
        // Wave 1 Templates //
        T_TFBot_Soldier_Concheror_Melee
        {
            Name "Concheror Shovel Soldier"
            Class Soldier
            ClassIcon soldier_shovel_conch_nys
            WeaponRestrictions MeleeOnly
            Attributes SpawnWithFullCharge

            Item "The Concheror"

            ItemAttributes
            {
                ItemName "The Concheror"

                "increase buff duration" 9.0
            }
        }
    }

    //// MISSION BOTS ////
    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_mission_sentrybuster
        BeginAtWave 1
        RunForThisManyWaves 8
        DesiredCount 1

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_SentryBuster
        }   
    }
    Mission // Sniper (Wave 4)
    {
        Objective Sniper
        Where spawnbot_mission_sniper
        BeginAtWave 4
        RunForThisManyWaves 1
        DesiredCount 2

        InitialCooldown 32
        CooldownTime 32

        TFBot
        {
            Template T_TFBot_Sniper
        }
    }

    //// WAVES ////
    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`tf_objective_resource`, `$SetClientProp$m_iszMvMPopfileName`, `Seventy-Degree Sundown (Adv)`)
                  "
        }
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        // Subwave 1
        WaveSpawn // 10 Punchies
        {
            Name "Wave1_Subwave1_Punchies"
            Where spawnbot_all
            TotalCount 10
            MaxActive 10
            SpawnCount 1
            WaitBeforeStarting 0
            WaitBetweenSpawns 0.1
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Heavyweapons_Heavyweight_Champ
            }
        }

        WaveSpawn // 10 Conch Shovels
        {
            Name "Wave1_Subwave1_ShovelSoldiers"
            WaitForAllSpawned "Wave1_Subwave1_Punchies"
            Where spawnbot_all
            RandomSpawn 1
            TotalCount 10
            MaxActive 10
            SpawnCount 10
            WaitBeforeStarting 8
            WaitBetweenSpawns 0
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Soldier_Concheror_Melee
            }
        }

        WaveSpawn // 16 Punchies
        {
            Name "Wave1_Subwave1_Punchies2"
