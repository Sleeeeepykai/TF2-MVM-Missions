    Wave
    {
        InitWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    IncludeScript(`tankextensions_main`, getroottable())
                    IncludeScript(`tankextensions/helicopter`, getroottable())

                    TankExt.CreateLoopPaths({
                        tank_loop = [
                            Vector(-1920, -3712, 256)
                            Vector(-576, -3712, 256)
                            Vector(-448, -3648, 256)
                            Vector(-256, -3456, 256)
                            Vector(0, -3072, 192)
                            Vector(0, -1664, 192)
                            Vector(0, -1344, 192)
                            Vector(64, -1216, 192)
                            Vector(128, -1152, 192)
                            Vector(320, -1088, 256)
                            Vector(704, -1088, 256)
                            Vector(800, -1024, 256)
                            Vector(864, -928, 256)
                            Vector(896, -192, 288)
                            Vector(800, -32, 288)
                            Vector(576, 32, 288)
                            Vector(416, 32, 320)
