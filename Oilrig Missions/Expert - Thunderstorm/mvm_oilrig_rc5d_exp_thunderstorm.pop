#base robot_giant.pop
#base robot_standard.pop
//OBS: "Left" and "Right" in spawnbots is from the robot's perspective, not RED's

WaveSchedule
{
    StartingCurrency 600 
    RespawnWaveTime 5 
    CanBotsAttackWhileInSpawnRoom No
    AddSentryBusterWhenDamageDealtExceeds 3000
    AddSentryBusterWhenKillCountExceeds 15

    //// TEMPLATES ////

    Templates
    {
        T_TFBot_Pyro_Armored
        {  
            Name "Flametosser Pyro"
            Class Pyro
            ClassIcon pyro_armored_revamp
            Skill Expert
            Health 500
            Scale 1.3
            WeaponRestrictions PrimaryOnly
            Attributes AlwaysFireWeapon

            Item "The Last Breath"
        }

        T_TFBot_Medic_BigHeal_Armored
        {  
            Name "Bigger-Heal Medic"
            Class Medic
            ClassIcon medic_armored_remix
            Skill Normal
            Health 500
            Scale 1.3

            Item "The Quick-Fix"

            Item "The Surgeon's Stahlhelm"

            ItemAttributes
			{
				ItemName "TF_WEAPON_SYRINGEGUN_MEDIC"
				"damage penalty" 0.1
			}
			ItemAttributes
			{
				ItemName "The Quick-Fix"
				"ubercharge rate bonus" 0.1
                "heal rate bonus" 10
			}
        }
    }

    //// MISSION BOTS ////

    Mission // Sentry Buster
    {
        Objective DestroySentries
        Where spawnbot_mission_sentrybuster
        BeginAtWave 1
        RunForThisManyWaves 6
        DesiredCount 1

        InitialCooldown 30
        CooldownTime 25

        TFBot
        {
            Template T_TFBot_SentryBuster
        }   
    }

    Mission // Sniper (Wave 2)
    {
        Objective Sniper
        Where spawnbot_mission_sniper
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 3

        InitialCooldown 110
        CooldownTime 15

        TFBot
        {
            Template T_TFBot_Sniper
        }
    }
    Mission // Spy (Wave 2)
    {
        Objective Spy
        Where spawnbot_mission_spy
        BeginAtWave 2
        RunForThisManyWaves 1
        DesiredCount 3

        InitialCooldown 110
        CooldownTime 15

        TFBot
        {
            Template T_TFBot_Spy
        }
    }

    //// WAVES ////
    Wave
    {
        StartWaveOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_start_relay`, `Trigger`)
                  "
        }
        DoneOutput
        {
            Target BigNet
            Action RunScriptCode
            Param "
                    EntFire(`wave_finished_relay`, `Trigger`)        
                  "
        }

        //Subwave 1
        WaveSpawn // 20 Black Boxes
        {
            Name "Wave1_Subwave1_BlackBoxes"
            Where spawnbot
            RandomSpawn 1
            TotalCount 14
            MaxActive 10
            SpawnCount 7
            WaitBeforeStarting 0
            WaitBetweenSpawns 10
            TotalCurrency 20

            TFBot
            {
                Template T_TFBot_Soldier_RocketShotgun
            }
        }
        WaveSpawn // 15 Demomen
        {
            Name "Wave1_Subwave1_Demomen"
            Where spawnbot
            TotalCount 15
            MaxActive 7
            SpawnCount 3
            WaitBeforeStarting 0
            WaitBetweenSpawns 4
            TotalCurrency 80

            TFBot
            {
                Class Demoman
                Skill Expert
            }
        }

        WaveSpawn // 10 Steel Gauntlets
        {
            Name "Wave1_Subwave1_SteelGauntlets"
            WaitForAllSpawned "Wave1_Subwave1_BlackBoxes"
            Where spawnbot
            TotalCount 10
            MaxActive 5
            SpawnCount 1
            WaitBeforeStarting 5
            WaitBetweenSpawns 2
            TotalCurrency 100

            TFBot
            {
                Template T_TFBot_Heavyweapons_Fist
                ClassIcon heavy_steelfist_armored_revamp
            }
        }
        WaveSpawn // 16 Pyros
        {
            Name "Wave1_Subwave1_Pyros"
            WaitForAllSpawned "Wave1_Subwave1_BlackBoxes"
            Where spawnbot
            TotalCount 16
            MaxActive 8
            SpawnCount 2
            WaitBeforeStarting 5
            WaitBetweenSpawns 2
            TotalCurrency 20

            TFBot
            {
                Class Pyro
                Skill Easy
            }
        }

        WaveSpawn // 20 Black Boxes
        {
            Name "Wave1_Subwave1_BlackBoxes2"
            WaitForAllSpawned "Wave1_Subwave1_SteelGauntlets"
            Where spawnbot
            RandomSpawn 1
            TotalCount 14
            MaxActive 10
            SpawnCount 7
            WaitBeforeStarting 10
            WaitBetweenSpawns 10
            TotalCurrency 20

            TFBot
            {
                Template T_TFBot_Soldier_RocketShotgun
            }
        }
        WaveSpawn // 15 Demomen
        {
            Name "Wave1_Subwave1_Demomen2"
