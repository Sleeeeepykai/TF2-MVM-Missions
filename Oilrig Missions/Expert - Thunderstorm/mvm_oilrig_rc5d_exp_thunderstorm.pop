            TotalCount 2
            MaxActive 2
            SpawnCount 1
            WaitBeforeStarting 10
            WaitBetweenSpawns 15
            TotalCurrency 80

            TFBot
            {
                Template T_TFBot_Giant_DemoMan_PrinceTavish
            }
        }
        WaveSpawn // 6 Buff Banners and 24 Soldiers
        {
            Name "Wave2_Subwave1_BuffBanners"
            WaitForAllSpawned "Wave2_Subwave1_Tank"
            Where spawnbot
            TotalCount 30
            MaxActive 10
            SpawnCount 5
            WaitBeforeStarting 10
            WaitBetweenSpawns 5
            TotalCurrency 100

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Soldier_Extended_Buff_Banner
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
            }
