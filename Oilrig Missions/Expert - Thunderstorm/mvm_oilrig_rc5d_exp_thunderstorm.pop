        WaveSpawn // 2 GPunchies, 2 Armored Big-Heal Medics and 4 Armored Pyros
        {
            Name "Wave3_Subwave1_GPunchies"
            WaitForAllSpawned "Wave3_Subwave1_Soldiers"
