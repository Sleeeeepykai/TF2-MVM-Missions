            }
        }
        WaveSpawn // 28 Sandmen
        {
            Name "Wave2_Subwave2_Sandmen"
            WaitForAllSpawned "Wave2_Subwave1_GKnights"
            Where spawnbot
            TotalCount 28
            MaxActive 10
            SpawnCount 7
            WaitBeforeStarting 20
            WaitBetweenSpawns 10
            TotalCurrency 40

            Squad
            {
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
                TFBot
                {
                    Template T_TFBot_Scout_Sandman_FastCharge
                }
            }
        }

        //Subwave 3
        WaveSpawn // 1 Tank
		{
			Name "Wave2_Subwave3_Tank"
            WaitForAllSpawned "Wave2_Subwave2_GDemo"
			TotalCount 1
			MaxActive 1
			SpawnCount 1
			WaitBeforeStarting 20
            WaitBetweenSpawns 0
            TotalCurrency 100

            FirstSpawnWarningSound "mvm/mvm_tank_start.wav"
			
			Tank
			{
				Health 17500
				Speed 75
				Name "tankboss"
				StartingPathTrackNode "tank_path_a_1" //left bomb path
				
				OnKilledOutput
				{
					Target boss_dead_relay
					Action Trigger
				}
				OnBombDroppedOutput
				{
					Target boss_deploy_relay
					Action Trigger
				}
			}
		}
        WaveSpawn // 2 GKnights and 6 Soldiers
        {
            Name "Wave2_Subwave3_GKnight"
            WaitForAllSpawned "Wave2_Subwave3_Tank"
            Where spawnbot_left
            TotalCount 8
            MaxActive 5
            SpawnCount 4
            WaitBeforeStarting 10
            WaitBetweenSpawns 25
            TotalCurrency 80
            
            Squad
            {
                TFBot
                {
                    Template T_TFBot_Giant_DemoMan_PrinceTavish
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
                }
                TFBot
                {
                    Class Soldier
                    Skill Normal
